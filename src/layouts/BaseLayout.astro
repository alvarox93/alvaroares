---
import { defaultLang, type Language } from '@i18n/ui';

const lang = (Astro.currentLocale ?? defaultLang) as Language;
const path = Astro.url.pathname;

// hreflang links for SEO
const cleanPath = path.replace(/^\/(en|es)/, '') || '/';
const enHref = cleanPath === '/' ? 'https://alvaroar.es/' : `https://alvaroar.es${cleanPath}`;
const esHref = cleanPath === '/' ? 'https://alvaroar.es/es/' : `https://alvaroar.es/es${cleanPath}`;

interface Props {
  title: string;
  description?: string;
}

const { title, description = lang === 'es'
  ? 'Álvaro Ares — Director Creativo & Motion Strategist en Bilbao.'
  : 'Álvaro Ares — Creative Director & Motion Strategist based in Bilbao.' } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" hreflang="en" href={enHref} />
    <link rel="alternate" hreflang="es" href={esHref} />
    <link rel="alternate" hreflang="x-default" href={enHref} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>

<script>
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!prefersReducedMotion) {
    document.querySelectorAll('a').forEach((link) => {
      const href = link.getAttribute('href');
      if (!href || !href.startsWith('/') || href.includes('#') || link.hasAttribute('download') || link.getAttribute('target') === '_blank') return;
      if (href === window.location.pathname) return;

      link.addEventListener('click', (e) => {
        if (e.metaKey || e.ctrlKey || e.shiftKey) return;
        e.preventDefault();
        document.body.style.transition = 'opacity 0.25s ease-in';
        document.body.style.opacity = '0';
        setTimeout(() => { window.location.href = href; }, 280);
      });
    });
  }
</script>
