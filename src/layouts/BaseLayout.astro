---
import { defaultLang, type Language } from '@i18n/ui';

const lang = (Astro.currentLocale ?? defaultLang) as Language;
const path = Astro.url.pathname;

// hreflang links for SEO
const cleanPath = path.replace(/^\/(en|es)/, '') || '/';
const enHref = cleanPath === '/' ? 'https://alvaroar.es/' : `https://alvaroar.es${cleanPath}`;
const esHref = cleanPath === '/' ? 'https://alvaroar.es/es/' : `https://alvaroar.es/es${cleanPath}`;

import PageTransition from '@components/PageTransition.astro';

interface Props {
  title: string;
  description?: string;
  transitionLine1?: string;
  transitionLine2?: string;
}

const { title, description = lang === 'es'
  ? 'Álvaro Ares — Director Creativo & Motion Strategist en Bilbao.'
  : 'Álvaro Ares — Creative Director & Motion Strategist based in Bilbao.', transitionLine1, transitionLine2 } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" hreflang="en" href={enHref} />
    <link rel="alternate" hreflang="es" href={esHref} />
    <link rel="alternate" hreflang="x-default" href={enHref} />
    <title>{title}</title>

    <script is:inline>
      (function() {
        var path = window.location.pathname;
        if (/^\/(en|es)(\/|$)/.test(path)) return;
        if (path.startsWith('/_') || path.startsWith('/api/') || path.startsWith('/@') || path.startsWith('/__')) return;

        function getCookie(name) {
          var match = document.cookie.match(new RegExp('(^| )' + name + '=([^;]+)'));
          return match ? match[2] : null;
        }
        function setCookie(name, value, days) {
          var expires = new Date(Date.now() + days * 864e5).toUTCString();
          document.cookie = name + '=' + encodeURIComponent(value) + '; expires=' + expires + '; path=/';
        }

        var cookie = getCookie('aa-lang');
        if (cookie === 'es') {
          window.location.href = '/es' + (path === '/' ? '' : path);
        } else if (!cookie) {
          var preferred = (navigator.language || '').slice(0, 2).toLowerCase();
          if (preferred === 'es') {
            setCookie('aa-lang', 'es', 365);
            window.location.href = '/es' + (path === '/' ? '' : path);
          } else {
            setCookie('aa-lang', 'en', 365);
          }
        }
      })();
    </script>
  </head>
  <body>
    <PageTransition line1={transitionLine1} line2={transitionLine2} />
    <slot />
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>

<script>
  document.querySelectorAll('a').forEach((link) => {
    const href = link.getAttribute('href');
    if (!href || !href.startsWith('/') || href.includes('#') || link.hasAttribute('download') || link.getAttribute('target') === '_blank') return;

    if (href === window.location.pathname) {
      link.addEventListener('click', (e) => {
        e.preventDefault();
      });
      return;
    }

    link.addEventListener('click', (e) => {
      if (e.metaKey || e.ctrlKey || e.shiftKey) return;

      const pt = (window as any).__pageTransition;
      const line1 = link.dataset.transitionLine1 || '';
      const line2 = link.dataset.transitionLine2 || '';

      if (line1 && pt && pt.storeLines) {
        e.preventDefault();
        pt.storeLines(line1, line2);

        // Forzar overlay blanco visible en la página actual para evitar flash
        const overlay = document.getElementById('page-transition');
        if (overlay) {
          overlay.style.opacity = '1';
          overlay.style.pointerEvents = 'all';
        }

        // Pequeña pausa para que el browser pinte el overlay antes de navegar
        setTimeout(() => {
          window.location.href = href;
        }, 60);
      }
    });
  });
</script>
