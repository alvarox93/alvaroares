---
import { Image } from 'astro:assets';
import eyesLooking from '../assets/eyesLooking.png';
import { useTranslations, defaultLang, type Language, type UIKey } from '@i18n/ui';
import FoodSlideshow from '@components/FoodSlideshow.astro';
import LapatzakGallery from '@components/LapatzakGallery.astro';

const lang = (Astro.currentLocale ?? defaultLang) as Language;
const t = useTranslations(lang);

const projects: Array<{
  href: string;
  tagKey: UIKey;
  titleKey: UIKey;
  bodyKey: UIKey;
  boldKey: UIKey;
  ctaKey: UIKey;
  transitionKey: UIKey;
  num: string;
  side: 'left' | 'right';
}> = [
  {
    href: lang === defaultLang ? '/koora' : '/es/koora',
    tagKey: 'work.koora.tag',
    titleKey: 'work.koora.title',
    bodyKey: 'work.koora.body',
    boldKey: 'work.koora.bodyBold',
    ctaKey: 'work.koora.cta',
    transitionKey: 'transition.koora.line1',
    num: '01',
    side: 'left',
  },
  {
    href: lang === defaultLang ? '/renders' : '/es/renders',
    tagKey: 'work.renders.tag',
    titleKey: 'work.renders.title',
    bodyKey: 'work.renders.body',
    boldKey: 'work.renders.bodyBold',
    ctaKey: 'work.renders.cta',
    transitionKey: 'transition.renders.line1',
    num: '02',
    side: 'right',
  },
  {
    href: lang === defaultLang ? '/lapatzak' : '/es/lapatzak',
    tagKey: 'work.lapatzak.tag',
    titleKey: 'work.lapatzak.title',
    bodyKey: 'work.lapatzak.body',
    boldKey: 'work.lapatzak.bodyBold',
    ctaKey: 'work.lapatzak.cta',
    transitionKey: 'transition.lapatzak.line1',
    num: '03',
    side: 'left',
  },
  {
    href: lang === defaultLang ? '/lab' : '/es/lab',
    tagKey: 'work.lab.tag',
    titleKey: 'work.lab.title',
    bodyKey: 'work.lab.body',
    boldKey: 'work.lab.bodyBold',
    ctaKey: 'work.lab.cta',
    transitionKey: 'transition.lab.line1',
    num: '04',
    side: 'right',
  },
];
---

<section class="relative bg-canvas" id="work">
  <div class="max-w-[1200px] mx-auto px-xl lg:px-3xl mb-3xl">
    <div class="flex items-center gap-4 mb-md">
      <span class="w-8 h-px bg-ink/20"></span>
      <span class="text-ghost text-[11px] font-medium tracking-[0.14px] uppercase">{t('nav.work')}</span>
    </div>
    <h2 class="text-[clamp(36px,5vw,60px)] font-medium leading-[1.05] tracking-[-0.04em] text-ink max-w-[800px]" set:html={t('work.heading')} />
  </div>

  <div class="max-w-[1200px] mx-auto px-xl lg:px-3xl">
    {projects.slice(0, 2).map((p) => {
      const isLeft = p.side === 'left';
      return (
        <a href={p.href} data-transition-line1={t(p.transitionKey)} data-transition-line2="" class="project-showcase group block mb-[100px]">
          <div class="grid grid-cols-1 lg:grid-cols-12 gap-xl items-center">
            {isLeft && (
              <div class="lg:col-span-7 overflow-hidden rounded-xl">
                <div class="relative" style="padding-bottom: 58%;">
                  {p.num === '01' ? (
                    <div class="absolute inset-0 project-image-wrap" style="top:-15%; height:130%;">
                      <video
                        src="/kooraShowreel.webm"
                        loop
                        muted
                        playsinline
                        autoplay
                        preload="auto"
                        class="w-full h-full object-cover"
                        style="position:absolute; inset:0;"
                      />
                      <div class="absolute inset-0 bg-ink/0 group-hover:bg-ink/[0.03] transition-colors duration-500"></div>
                    </div>
                  ) : (
                    <div class="absolute -top-[15%] left-0 w-full h-[130%] bg-surface project-image-wrap">
                      <div class="absolute inset-0 flex items-center justify-center" style="top:15%;height:60%;">
                        <span class="font-accent text-[clamp(64px,8vw,100px)] font-bold tracking-[-0.04em] text-ink/[0.04]">{p.num}</span>
                      </div>
                      <div class="absolute inset-0 bg-ink/0 group-hover:bg-ink/[0.03] transition-colors duration-500"></div>
                    </div>
                  )}
                </div>
              </div>
            )}
            <div class={isLeft ? "lg:col-span-4 lg:col-start-9" : "lg:col-span-4 lg:order-1 lg:text-right order-2"}>
              <div class="project-text-wrap">
                <span class="text-ghost text-[11px] font-medium tracking-[0.14px] uppercase mb-sm block">{t(p.tagKey)}</span>
                <h3 class="text-[clamp(28px,3.5vw,44px)] font-medium leading-[1.08] tracking-[-0.035em] text-ink mb-md group-hover:text-accent transition-colors duration-300">
                  {t(p.titleKey)}
                </h3>
                <p class="text-muted text-[16px] leading-[1.6] mb-lg">
                  <strong class="text-ink font-medium">{t(p.bodyKey)}</strong> {t(p.boldKey)}
                </p>
                <span class="project-cta inline-flex items-center gap-2 px-5 py-2.5 bg-ink text-canvas text-[12px] font-medium tracking-[-0.2px] rounded-lg transition-colors duration-300 hover:bg-ink/85 cursor-pointer">
                  <span class="cta-text">{t(p.ctaKey)}</span>
                  <svg class="cta-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="5" y1="12" x2="19" y2="12"/>
                    <polyline points="12 5 19 12 12 19"/>
                  </svg>
                </span>
              </div>
            </div>
            {!isLeft && (
              <div class="lg:col-span-7 lg:col-start-6 lg:order-2 order-1 overflow-hidden rounded-xl">
                <div class="relative" style="padding-bottom: 58%;">
                  {p.num === '02' ? (
                    <FoodSlideshow />
                  ) : (
                    <div class="absolute -top-[15%] left-0 w-full h-[130%] bg-surface project-image-wrap">
                      <div class="absolute inset-0 flex items-center justify-center" style="top:15%;height:60%;">
                        <span class="font-accent text-[clamp(64px,8vw,100px)] font-bold tracking-[-0.04em] text-ink/[0.04]">{p.num}</span>
                      </div>
                      <div class="absolute inset-0 bg-ink/0 group-hover:bg-ink/[0.03] transition-colors duration-500"></div>
                    </div>
                  )}
                </div>
              </div>
            )}
          </div>
        </a>
      );
    })}
  </div>

  <div class="relative bg-ink w-screen pt-[100px] pb-[100px] mb-[100px] overflow-hidden" style="margin-left: calc(-50vw + 50%);">
    <div aria-hidden="true" class="absolute inset-0 pointer-events-none">
      <Image src={eyesLooking} alt="" class="w-full h-full object-cover" loading="lazy" decoding="async" />
    </div>
    <div class="relative z-10 max-w-[1200px] mx-auto px-xl lg:px-3xl flex flex-col items-center text-center">
      <span class="text-canvas/50 text-[11px] font-medium tracking-[0.14px] uppercase block mb-lg">{t('home.hero.available')}</span>
      <h3 class="text-[clamp(26px,3.2vw,38px)] font-light leading-[1.15] tracking-[-0.03em] text-canvas mb-xl max-w-[620px]">
        {t('about.cta.connect.title')}
      </h3>
      <a href={`mailto:${t('footer.email')}`} class="project-cta inline-flex items-center gap-2.5 px-7 py-3.5 bg-canvas text-ink text-[14px] font-medium tracking-[-0.2px] rounded-lg transition-colors duration-300 hover:bg-canvas/90 cursor-pointer">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
        </svg>
        <span class="cta-text">{t('about.cta.connect.button')}</span>
      </a>
    </div>
  </div>

  <div class="max-w-[1200px] mx-auto px-xl lg:px-3xl pb-section">
    {projects.slice(2).map((p) => {
      const isLeft = p.side === 'left';
      return (
        <a href={p.href} data-transition-line1={t(p.transitionKey)} data-transition-line2="" class={`project-showcase group block ${p.num === '04' ? 'mb-[60px]' : 'mb-[100px]'}`}>
          <div class="grid grid-cols-1 lg:grid-cols-12 gap-xl items-center">
            {isLeft && (
              <div class="lg:col-span-7 overflow-hidden rounded-xl">
                <div class="relative" style="padding-bottom: 58%;">
                  {p.num === '03' ? (
                    <LapatzakGallery />
                  ) : (
                    <div class="absolute -top-[15%] left-0 w-full h-[130%] bg-surface project-image-wrap">
                      <div class="absolute inset-0 flex items-center justify-center" style="top:15%;height:60%;">
                        <span class="font-accent text-[clamp(64px,8vw,100px)] font-bold tracking-[-0.04em] text-ink/[0.04]">{p.num}</span>
                      </div>
                      <div class="absolute inset-0 bg-ink/0 group-hover:bg-ink/[0.03] transition-colors duration-500"></div>
                    </div>
                  )}
                </div>
              </div>
            )}
            <div class={isLeft ? "lg:col-span-4 lg:col-start-9" : "lg:col-span-4 lg:order-1 lg:text-right order-2"}>
              <div class="project-text-wrap">
                <span class="text-ghost text-[11px] font-medium tracking-[0.14px] uppercase mb-sm block">{t(p.tagKey)}</span>
                <h3 class="text-[clamp(28px,3.5vw,44px)] font-medium leading-[1.08] tracking-[-0.035em] text-ink mb-md group-hover:text-accent transition-colors duration-300">
                  {t(p.titleKey)}
                </h3>
                <p class="text-muted text-[16px] leading-[1.6] mb-lg">
                  <strong class="text-ink font-medium">{t(p.bodyKey)}</strong> {t(p.boldKey)}
                </p>
                <span class="project-cta inline-flex items-center gap-2 px-5 py-2.5 bg-ink text-canvas text-[12px] font-medium tracking-[-0.2px] rounded-lg transition-colors duration-300 hover:bg-ink/85 cursor-pointer">
                  <span class="cta-text">{t(p.ctaKey)}</span>
                  <svg class="cta-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="5" y1="12" x2="19" y2="12"/>
                    <polyline points="12 5 19 12 12 19"/>
                  </svg>
                </span>
              </div>
            </div>
            {!isLeft && (
              <div class="lg:col-span-7 lg:col-start-6 lg:order-2 order-1 overflow-hidden rounded-xl">
                <div class="relative" style="padding-bottom: 58%;">
                  <div class="absolute -top-[15%] left-0 w-full h-[130%] bg-surface project-image-wrap">
                    <div class="absolute inset-0 flex items-center justify-center" style="top:15%;height:60%;">
                      <span class="font-accent text-[clamp(64px,8vw,100px)] font-bold tracking-[-0.04em] text-ink/[0.04]">{p.num}</span>
                    </div>
                    <div class="absolute inset-0 bg-ink/0 group-hover:bg-ink/[0.03] transition-colors duration-500"></div>
                  </div>
                </div>
              </div>
            )}
          </div>
        </a>
      );
    })}
  </div>
</section>

<style>
  .project-showcase {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .project-showcase .project-image-wrap {
    transition: box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .project-showcase:hover .project-image-wrap {
    box-shadow: 0 20px 50px rgba(0,0,0,0.06);
  }
</style>
