---
import { useTranslations, defaultLang, type Language, type UIKey } from '@i18n/ui';
import FoodSlideshow from '@components/FoodSlideshow.astro';
import LapatzakGallery from '@components/LapatzakGallery.astro';

const lang = (Astro.currentLocale ?? defaultLang) as Language;
const t = useTranslations(lang);

const projects: Array<{
  href: string;
  tagKey: UIKey;
  titleKey: UIKey;
  bodyKey: UIKey;
  boldKey: UIKey;
  ctaKey: UIKey;
  transitionKey: UIKey;
  num: string;
  side: 'left' | 'right';
}> = [
  {
    href: lang === defaultLang ? '/koora' : '/es/koora',
    tagKey: 'work.koora.tag',
    titleKey: 'work.koora.title',
    bodyKey: 'work.koora.body',
    boldKey: 'work.koora.bodyBold',
    ctaKey: 'work.koora.cta',
    transitionKey: 'transition.koora.line1',
    num: '01',
    side: 'left',
  },
  {
    href: lang === defaultLang ? '/renders' : '/es/renders',
    tagKey: 'work.renders.tag',
    titleKey: 'work.renders.title',
    bodyKey: 'work.renders.body',
    boldKey: 'work.renders.bodyBold',
    ctaKey: 'work.renders.cta',
    transitionKey: 'transition.renders.line1',
    num: '02',
    side: 'right',
  },
  {
    href: lang === defaultLang ? '/lapatzak' : '/es/lapatzak',
    tagKey: 'work.lapatzak.tag',
    titleKey: 'work.lapatzak.title',
    bodyKey: 'work.lapatzak.body',
    boldKey: 'work.lapatzak.bodyBold',
    ctaKey: 'work.lapatzak.cta',
    transitionKey: 'transition.lapatzak.line1',
    num: '03',
    side: 'left',
  },
  {
    href: lang === defaultLang ? '/lab' : '/es/lab',
    tagKey: 'work.lab.tag',
    titleKey: 'work.lab.title',
    bodyKey: 'work.lab.body',
    boldKey: 'work.lab.bodyBold',
    ctaKey: 'work.lab.cta',
    transitionKey: 'transition.lab.line1',
    num: '04',
    side: 'right',
  },
];
---

<section class="relative bg-canvas" id="work">
  <div class="bg-ink w-full py-3xl mb-[100px]">
    <div class="max-w-[1200px] mx-auto px-xl lg:px-3xl">
      <h2 class="text-[clamp(36px,5vw,64px)] font-medium leading-[1.05] tracking-[-0.04em] text-canvas" set:html={t('work.heading')} />
    </div>
  </div>

  <div class="max-w-[1200px] mx-auto px-xl lg:px-3xl pb-section">

    {projects.map((p, i) => {
      const isLeft = p.side === 'left';
      return (
        <>
        <a href={p.href} data-transition-line1={t(p.transitionKey)} data-transition-line2="" class={`project-showcase group block ${i === projects.length - 1 ? 'mb-[60px]' : 'mb-[100px]'}`}>
          <div class="grid grid-cols-1 lg:grid-cols-12 gap-xl items-center">
            {isLeft && (
              <div class="lg:col-span-7 overflow-hidden rounded-xl">
                <div class="relative" style="padding-bottom: 58%;">
                  {p.num === '01' ? (
                    <div class="absolute inset-0 project-image-wrap" style="top:-15%; height:130%;">
                      <video
                        src="/kooraShowreel.webm"
                        loop
                        muted
                        playsinline
                        autoplay
                        preload="auto"
                        class="w-full h-full object-cover"
                        style="position:absolute; inset:0;"
                      />
                      <div class="absolute inset-0 bg-ink/0 group-hover:bg-ink/[0.03] transition-colors duration-500"></div>
                    </div>
                  ) : p.num === '03' ? (
                    <LapatzakGallery />
                  ) : (
                    <div class="absolute -top-[15%] left-0 w-full h-[130%] bg-surface project-image-wrap">
                      <div class="absolute inset-0 flex items-center justify-center" style="top:15%;height:60%;">
                        <span class="font-accent text-[clamp(64px,8vw,100px)] font-bold tracking-[-0.04em] text-ink/[0.04]">{p.num}</span>
                      </div>
                      <div class="absolute inset-0 bg-ink/0 group-hover:bg-ink/[0.03] transition-colors duration-500"></div>
                    </div>
                  )}
                </div>
              </div>
            )}
            <div class={isLeft ? "lg:col-span-4 lg:col-start-9" : "lg:col-span-4 lg:order-1 lg:text-right order-2"}>
              <div class="project-text-wrap">
                <span class="text-ghost text-[11px] font-medium tracking-[0.14px] uppercase mb-sm block">{t(p.tagKey)}</span>
                <h3 class="text-[clamp(28px,3.5vw,44px)] font-medium leading-[1.08] tracking-[-0.035em] text-ink mb-md group-hover:text-accent transition-colors duration-300">
                  {t(p.titleKey)}
                </h3>
                <p class="text-muted text-[16px] leading-[1.6] mb-lg">
                  <strong class="text-ink font-medium">{t(p.bodyKey)}</strong> {t(p.boldKey)}
                </p>
                <span class="inline-flex items-center justify-center px-5 py-2.5 bg-ink text-canvas text-[12px] font-medium tracking-[-0.2px] rounded-lg transition-colors duration-300 hover:bg-ink/85">
                  {t(p.ctaKey)}
                </span>
              </div>
            </div>
            {!isLeft && (
              <div class="lg:col-span-7 lg:col-start-6 lg:order-2 order-1 overflow-hidden rounded-xl">
                <div class="relative" style="padding-bottom: 58%;">
                  {p.num === '02' ? (
                    <FoodSlideshow />
                  ) : (
                    <div class="absolute -top-[15%] left-0 w-full h-[130%] bg-surface project-image-wrap">
                      <div class="absolute inset-0 flex items-center justify-center" style="top:15%;height:60%;">
                        <span class="font-accent text-[clamp(64px,8vw,100px)] font-bold tracking-[-0.04em] text-ink/[0.04]">{p.num}</span>
                      </div>
                      <div class="absolute inset-0 bg-ink/0 group-hover:bg-ink/[0.03] transition-colors duration-500"></div>
                    </div>
                  )}
                </div>
              </div>
            )}
          </div>
        </a>
        {i === 1 && (
          <div class="bg-ink w-full py-4xl mb-[140px] overflow-hidden">
            <div class="max-w-[1200px] mx-auto px-xl lg:px-3xl flex flex-col items-center text-center">
              <span class="text-canvas/50 text-[11px] font-medium tracking-[0.14px] uppercase block mb-sm">{t('home.hero.available')}</span>
              <h3 class="text-[clamp(22px,2.8vw,32px)] font-light leading-[1.1] tracking-[-0.03em] text-canvas mb-md max-w-[560px]">
                {t('about.cta.connect.title')}
              </h3>
              <a href={`mailto:${t('footer.email')}`} class="inline-flex items-center justify-center px-5 py-2.5 bg-canvas text-ink text-[12px] font-medium tracking-[-0.2px] rounded-lg transition-colors duration-300 hover:bg-canvas/90">
                {t('about.cta.connect.button')}
              </a>
            </div>
          </div>
        )}
      </>
      );
    })}

  </div>
</section>

<style>
  .project-showcase {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .project-showcase .project-image-wrap {
    transition: box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .project-showcase:hover .project-image-wrap {
    box-shadow: 0 20px 50px rgba(0,0,0,0.06);
  }
</style>
