---
import { useTranslations, defaultLang, type Language } from '@i18n/ui';

const lang = (Astro.currentLocale ?? defaultLang) as Language;
const t = useTranslations(lang);
---

<section class="relative min-h-screen flex flex-col justify-center bg-canvas overflow-hidden" id="hero">
  <div class="absolute inset-0 pointer-events-none hero-grid" id="hero-grid" style="background-image: linear-gradient(rgba(0,0,0,0.025) 1px, transparent 1px), linear-gradient(90deg, rgba(0,0,0,0.025) 1px, transparent 1px); background-size: 60px 60px;"></div>

  <div class="hero-blob" id="hero-blob" style="left: 50%; top: 40%; transform: translate(-50%, -50%);"></div>
  <div class="hero-fade pointer-events-none" aria-hidden="true"></div>

  <div class="relative z-10 max-w-[1200px] mx-auto pl-2xl pr-xl lg:pl-4xl lg:pr-2xl py-3xl">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-xl items-center">
      <div class="lg:col-span-5">

        <div class="mb-xl">
          <span class="inline-flex items-center gap-2.5 px-4 py-2 border border-border rounded-full">
            <span class="accent-dot"></span>
            <span class="text-ink text-[11px] font-medium tracking-[0.12px] uppercase">{t('home.hero.available')}</span>
          </span>
        </div>

        <div class="mb-2xl">
          <h1 class="text-[clamp(32px,5vw,56px)] font-light leading-[1.08] tracking-[-0.04em] text-ink text-balance">
            <span class="block">{t('home.hero.title.line1')}</span>
            <span class="block">{t('home.hero.title.line2')}</span>
          </h1>
        </div>

        <p class="text-[17px] leading-[1.6] text-muted max-w-[460px] mb-2xl">
          <strong class="text-ink font-medium">{t('home.hero.lede')}</strong> {t('home.hero.ledeBold')}
        </p>

        <div class="flex gap-md">
          <a href="#work" class="magnetic inline-flex items-center justify-center px-6 py-3 bg-ink text-canvas text-[13px] font-medium tracking-[-0.2px] rounded-lg transition-colors duration-300 hover:bg-ink/85">
            {t('home.hero.cta.work')}
          </a>
          <a href={lang === defaultLang ? '/about' : '/es/about'} class="magnetic inline-flex items-center justify-center px-6 py-3 bg-surface text-ink text-[13px] font-medium tracking-[-0.2px] rounded-lg border border-border transition-colors duration-300 hover:border-ink/20">
            {t('home.hero.cta.about')}
          </a>
        </div>

      </div>

      <div class="hidden lg:block lg:col-span-6 lg:col-start-7 relative hero-video-wrap" style="min-height: 500px;" data-theme-video>
        <video
          src="/keyCupAnimation.webm"
          loop
          muted
          playsinline
          autoplay
          preload="auto"
          class="hero-video absolute inset-0 w-full h-full object-contain"
          data-video="warm"
          style="opacity: 1"
        ></video>
        <video
          src="/keyCupAnimation_cold.webm"
          loop
          muted
          playsinline
          autoplay
          preload="auto"
          class="hero-video absolute inset-0 w-full h-full object-contain"
          data-video="cold"
          style="opacity: 0"
        ></video>
      </div>
    </div>
  </div>

  <div class="absolute bottom-0 left-0 right-0 z-10 px-xl lg:px-3xl py-5">
    <div class="max-w-[1200px] mx-auto flex justify-center">
      <span class="inline-flex items-center gap-md text-ghost text-[11px] tracking-[0.14px]">
        <span class="inline-flex items-center gap-xs">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          {t('home.hero.bornIn')}
        </span>
        <span class="w-[3px] h-[3px] rounded-full bg-ghost/40"></span>
        <span>{t('home.hero.basedIn')}</span>
        <span class="w-[3px] h-[3px] rounded-full bg-ghost/40"></span>
        <span>{t('home.hero.working')}</span>
      </span>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';

  const wrap = document.querySelector<HTMLElement>('[data-theme-video]');
  if (wrap) {
    const videos = Array.from(wrap.querySelectorAll<HTMLVideoElement>('video'));
    let position = 0;

    const applyTheme = () => {
      const theme = document.documentElement.getAttribute('data-theme') || 'warm';

      // Guardar posición del video visible actualmente
      videos.forEach((v) => {
        if (v.style.opacity === '1') position = v.currentTime;
        v.pause();
      });

      const incoming = videos.find((v) => v.dataset.video === theme) ?? videos[0];
      const outgoing = videos.find((v) => v.dataset.video !== theme);

      const activate = () => {
        incoming.play().catch(() => {});
        if (outgoing) outgoing.style.opacity = '0';
        incoming.style.opacity = '1';
      };

      // Si ya está en el tiempo correcto (o muy cerca), activar inmediatamente
      // para evitar que el evento seeked no dispare por race condition
      if (Math.abs(incoming.currentTime - position) < 0.05) {
        activate();
      } else {
        incoming.currentTime = position;
        const onSeeked = () => {
          incoming.removeEventListener('seeked', onSeeked);
          activate();
        };
        incoming.addEventListener('seeked', onSeeked);
      }
    };

    applyTheme();

    new MutationObserver(applyTheme).observe(document.documentElement, {
      attributes: true,
      attributeFilter: ['data-theme'],
    });

    // Re-activar videos al volver con back/forward (bfcache)
    window.addEventListener('pageshow', () => {
      applyTheme();
    });
  }

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!prefersReducedMotion) {
    const blob = document.getElementById('hero-blob');
    const hero = document.getElementById('hero');
    const grid = document.getElementById('hero-grid');

    if (blob && hero) {
      hero.addEventListener('mousemove', (e) => {
        const rect = hero.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;

        gsap.to(blob, {
          left: x,
          top: y,
          duration: 1.4,
          ease: 'power2.out',
        });

        if (grid) {
          const xPercent = (x / rect.width) * 100;
          const yPercent = (y / rect.height) * 100;
          grid.style.background = `
            radial-gradient(circle 300px at ${xPercent}% ${yPercent}%, rgba(var(--accent-rgb), 0.06), transparent),
            linear-gradient(rgba(0,0,0,0.025) 1px, transparent 1px),
            linear-gradient(90deg, rgba(0,0,0,0.025) 1px, transparent 1px)
          `;
          grid.style.backgroundSize = `100% 100%, 60px 60px, 60px 60px`;
        }
      });

      hero.addEventListener('mouseleave', () => {
        gsap.to(blob, { opacity: 0.04, duration: 0.6 });
        if (grid) {
          grid.style.background = `
            linear-gradient(rgba(0,0,0,0.025) 1px, transparent 1px),
            linear-gradient(90deg, rgba(0,0,0,0.025) 1px, transparent 1px)
          `;
          grid.style.backgroundSize = `60px 60px, 60px 60px`;
        }
      });

      hero.addEventListener('mouseenter', () => {
        gsap.to(blob, { opacity: 0.1, duration: 0.6 });
      });
    }
  }
</script>
