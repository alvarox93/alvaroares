---
import LanguageSwitcher from '@components/LanguageSwitcher.astro';
import { useTranslations, defaultLang, type Language } from '@i18n/ui';

const lang = (Astro.currentLocale ?? defaultLang) as Language;
const t = useTranslations(lang);
const homeHref = lang === defaultLang ? '/' : `/${lang}`;
const aboutHref = lang === defaultLang ? '/about' : '/es/about';

const nameChars = 'Álvaro Ares'.split('');
const aboutChars = t('nav.about').split('');
---

<nav class="fixed top-0 left-0 right-0 z-50" id="main-nav">
  <div class="max-w-[1200px] mx-auto px-xl lg:px-3xl flex items-center justify-between h-16">
    <a
      href={homeHref}
      data-transition-line1={t('transition.home.line1')}
      data-transition-line2={t('transition.home.line2')}
      class="nav-char-link nav-name text-ink text-[15px] font-medium tracking-[-0.3px]"
    >
      <span class="nav-text">
        {nameChars.map((char) => (
          <span class="nav-char">{char === ' ' ? '\u00A0' : char}</span>
        ))}
      </span>
    </a>
    <div class="flex items-center gap-lg">
      <a
        href={aboutHref}
        data-transition-line1={t('transition.about.line1')}
        data-transition-line2={t('transition.about.line2')}
        class="nav-char-link nav-about text-[13px] font-normal tracking-[-0.2px]"
      >
        <span class="nav-text">
          {aboutChars.map((char) => (
            <span class="nav-char">{char === ' ' ? '\u00A0' : char}</span>
          ))}
        </span>
      </a>
      <div class="theme-toggle" role="group" aria-label="Theme">
        <button class="theme-dot is-active" data-theme="warm" aria-label="Warm theme" aria-pressed="true"></button>
        <button class="theme-dot" data-theme="cold" aria-label="Cold theme" aria-pressed="false"></button>
      </div>
      <LanguageSwitcher />
      <a href="mailto:hey@alvaroar.es" class="inline-flex items-center justify-center px-4 py-2 bg-ink text-canvas text-[12px] font-medium tracking-[-0.2px] rounded-lg transition-colors duration-300 hover:bg-ink/85">
        {t('nav.contact')}
      </a>
    </div>
  </div>
</nav>

<style is:global>
  :root,
  [data-theme="warm"] {
    --accent: #e8a838;
    --accent-light: #fdf6e8;
    --accent-rgb: 232, 168, 56;
  }

  [data-theme="cold"] {
    --accent: #2596a8;
    --accent-light: #eaf4f6;
    --accent-rgb: 37, 150, 168;
  }
</style>

<style>
  #main-nav {
    background-color: transparent;
    transition: background-color 0.4s ease;
  }

  #main-nav.nav-scrolled {
    background-color: color-mix(in srgb, var(--color-canvas) 90%, transparent);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }

  /* Nav char links */
  .nav-char-link {
    display: inline-block;
    text-decoration: none;
    position: relative;
  }

  .nav-text {
    display: inline-block;
  }

  .nav-char {
    display: inline-block;
    will-change: transform;
  }

  .nav-about {
    color: var(--color-muted);
    transition: color 0.25s ease;
  }

  .nav-about:hover {
    color: var(--color-ink);
  }

  /* Theme dots */
  .theme-toggle {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .theme-dot {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    border: 2px solid transparent;
    cursor: pointer;
    padding: 0;
    transition: transform 0.2s ease, opacity 0.2s ease, border-color 0.2s ease;
    background: transparent;
  }

  .theme-dot:hover {
    transform: scale(1.2);
  }

  .theme-dot.is-active {
    border-color: var(--color-ink);
    transform: scale(1.1);
  }

  .theme-dot[data-theme="warm"] {
    background: #e8a838;
  }

  .theme-dot[data-theme="cold"] {
    background: #2596a8;
  }

  .theme-dot:not(.is-active) {
    opacity: 0.4;
  }

  .theme-dot:not(.is-active):hover {
    opacity: 0.85;
  }
</style>

<script>
  import { gsap } from 'gsap';

  /* ── Theme Toggle ── */
  const STORAGE_KEY = 'aa-theme';
  const root = document.documentElement;
  const stored = localStorage.getItem(STORAGE_KEY);
  const initial = stored === 'cold' || stored === 'warm' ? stored : 'warm';
  root.setAttribute('data-theme', initial);

  const dots = document.querySelectorAll<HTMLButtonElement>('.theme-dot');
  const syncTheme = (theme: string) => {
    dots.forEach((dot) => {
      const isActive = dot.dataset.theme === theme;
      dot.classList.toggle('is-active', isActive);
      dot.setAttribute('aria-pressed', String(isActive));
    });
  };
  syncTheme(initial);

  dots.forEach((dot) => {
    dot.addEventListener('click', () => {
      const theme = dot.dataset.theme;
      if (!theme) return;
      root.setAttribute('data-theme', theme);
      localStorage.setItem(STORAGE_KEY, theme);
      syncTheme(theme);
    });
  });

  /* ── Per-character hover ── */
  document.querySelectorAll<HTMLElement>('.nav-char-link').forEach((link) => {
    const chars = link.querySelectorAll<HTMLElement>('.nav-char');
    if (!chars.length) return;

    let hoverTween: gsap.core.Tween | null = null;

    link.addEventListener('mouseenter', () => {
      if (hoverTween) hoverTween.kill();
      hoverTween = gsap.to(chars, {
        y: -2,
        duration: 0.2,
        stagger: 0.02,
        ease: 'power2.out',
      });
    });

    link.addEventListener('mouseleave', () => {
      if (hoverTween) hoverTween.kill();
      hoverTween = gsap.to(chars, {
        y: 0,
        duration: 0.2,
        stagger: 0.02,
        ease: 'power2.in',
      });
    });
  });
</script>
