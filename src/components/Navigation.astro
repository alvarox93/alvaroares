---
import LanguageSwitcher from '@components/LanguageSwitcher.astro';
import { useTranslations, defaultLang, type Language } from '@i18n/ui';

const lang = (Astro.currentLocale ?? defaultLang) as Language;
const t = useTranslations(lang);
const homeHref = lang === defaultLang ? '/' : `/${lang}`;
const aboutHref = lang === defaultLang ? '/about' : '/es/about';

const nameChars = 'Álvaro Ares'.split('');
const aboutChars = t('nav.about').split('');
---

<nav class="fixed top-0 left-0 right-0 z-50" id="main-nav">
  <div class="max-w-[1200px] mx-auto px-xl lg:px-3xl flex items-center justify-between h-16">
    <a
      href={homeHref}
      data-transition-line1={t('transition.home.line1')}
      data-transition-line2={t('transition.home.line2')}
      class="nav-char-link nav-name text-ink text-[15px] font-medium tracking-[-0.3px]"
    >
      <span class="nav-text">
        {nameChars.map((char) => (
          <span class="nav-char">{char === ' ' ? '\u00A0' : char}</span>
        ))}
      </span>
      <button
        class="brand-theme-dot"
        aria-label="Toggle theme"
        data-theme-dot
      ></button>
    </a>
    <div class="flex items-center gap-lg">
      <a
        href={aboutHref}
        data-transition-line1={t('transition.about.line1')}
        data-transition-line2={t('transition.about.line2')}
        class="nav-char-link nav-about text-[13px] font-normal tracking-[-0.2px]"
      >
        <span class="nav-text">
          {aboutChars.map((char) => (
            <span class="nav-char">{char === ' ' ? '\u00A0' : char}</span>
          ))}
        </span>
      </a>
      <LanguageSwitcher />
      <a href="mailto:hey@alvaroar.es" class="inline-flex items-center justify-center px-4 py-2 bg-ink text-canvas text-[12px] font-medium tracking-[-0.2px] rounded-lg transition-colors duration-300 hover:bg-ink/85">
        {t('nav.contact')}
      </a>
    </div>
  </div>
</nav>

<style is:global>
  :root,
  [data-theme="warm"] {
    --accent: #e8a838;
    --accent-light: #fdf6e8;
    --accent-rgb: 232, 168, 56;
  }

  [data-theme="cold"] {
    --accent: #2596a8;
    --accent-light: #eaf4f6;
    --accent-rgb: 37, 150, 168;
  }
</style>

<style>
  #main-nav {
    background-color: transparent;
    transition: background-color 0.4s ease;
  }

  #main-nav.nav-scrolled {
    background-color: color-mix(in srgb, var(--color-canvas) 90%, transparent);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }

  /* Nav char links */
  .nav-char-link {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    position: relative;
  }

  .nav-text {
    display: inline-block;
  }

  .nav-char {
    display: inline-block;
    will-change: transform;
  }

  .nav-about {
    color: var(--color-muted);
    transition: color 0.25s ease;
  }

  .nav-about:hover {
    color: var(--color-ink);
  }

  /* Brand theme dot */
  .brand-theme-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    margin-left: 5px;
    margin-top: 1px;
    border: none;
    padding: 0;
    cursor: pointer;
    flex-shrink: 0;
    transition: transform 0.25s ease, background-color 0.3s ease;
  }

  .brand-theme-dot:hover {
    transform: scale(1.4);
  }

  .nav-char-link:hover .brand-theme-dot {
    transform: scale(1.3);
  }
</style>

<script>
  import { gsap } from 'gsap';

  /* ── Theme Toggle ── */
  const STORAGE_KEY = 'aa-theme';
  const root = document.documentElement;
  const stored = localStorage.getItem(STORAGE_KEY);
  const initial = stored === 'cold' || stored === 'warm' ? stored : 'warm';
  root.setAttribute('data-theme', initial);

  const dot = document.querySelector<HTMLButtonElement>('.brand-theme-dot');
  const themes = ['warm', 'cold'] as const;

  function syncDot(theme: string) {
    if (!dot) return;
    dot.style.backgroundColor = theme === 'warm' ? '#e8a838' : '#2596a8';
    dot.setAttribute('aria-pressed', String(theme === 'warm'));
  }
  syncDot(initial);

  dot?.addEventListener('click', (e) => {
    e.preventDefault();
    e.stopPropagation();
    const current = root.getAttribute('data-theme') || 'warm';
    const next = current === 'warm' ? 'cold' : 'warm';
    root.setAttribute('data-theme', next);
    localStorage.setItem(STORAGE_KEY, next);
    syncDot(next);
  });

  /* ── Per-character hover ── */
  document.querySelectorAll<HTMLElement>('.nav-char-link').forEach((link) => {
    const chars = link.querySelectorAll<HTMLElement>('.nav-char');
    if (!chars.length) return;

    let hoverTween: gsap.core.Tween | null = null;

    link.addEventListener('mouseenter', () => {
      if (hoverTween) hoverTween.kill();
      hoverTween = gsap.to(chars, {
        y: -2,
        duration: 0.2,
        stagger: 0.02,
        ease: 'power2.out',
      });
    });

    link.addEventListener('mouseleave', () => {
      if (hoverTween) hoverTween.kill();
      hoverTween = gsap.to(chars, {
        y: 0,
        duration: 0.2,
        stagger: 0.02,
        ease: 'power2.in',
      });
    });
  });
</script>
