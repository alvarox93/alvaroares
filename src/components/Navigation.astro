<nav class="fixed top-0 left-0 right-0 z-50" id="main-nav" style="background-color: transparent;">
  <div class="max-w-[1200px] mx-auto px-xl lg:px-3xl flex items-center justify-between h-16">
    <a href="/" class="nav-logo text-ink text-[15px] font-medium tracking-[-0.3px] relative group">
      <span>Álvaro Ares</span>
      <span class="absolute -bottom-0.5 left-0 w-0 h-[1px] bg-accent transition-all duration-300 group-hover:w-full"></span>
    </a>
    <div class="flex items-center gap-xl">
      <a href="/#work" class="nav-link text-muted text-[13px] font-normal tracking-[-0.2px] hover:text-ink transition-colors duration-200 relative group">
        <span>Work</span>
        <span class="absolute -bottom-0.5 left-0 w-0 h-[1px] bg-accent transition-all duration-300 group-hover:w-full"></span>
      </a>
      <a href="/about" class="nav-link text-muted text-[13px] font-normal tracking-[-0.2px] hover:text-ink transition-colors duration-200 relative group">
        <span>About</span>
        <span class="absolute -bottom-0.5 left-0 w-0 h-[1px] bg-accent transition-all duration-300 group-hover:w-full"></span>
      </a>
      <a href="mailto:hey@alvaroar.es" class="nav-link magnetic inline-flex items-center justify-center px-4 py-2 bg-ink text-canvas text-[12px] font-medium tracking-[-0.2px] rounded-lg transition-all duration-300 hover:bg-ink/85">
        Contact
      </a>
    </div>
  </div>
</nav>

<script>
  import { gsap } from 'gsap';

  const nav = document.getElementById('main-nav');
  let lastScroll = 0;

  if (nav) {
    window.addEventListener('scroll', () => {
      const currentScroll = window.scrollY;

      if (currentScroll > 50) {
        nav.style.backgroundColor = 'rgba(255, 255, 255, 0.85)';
        nav.style.backdropFilter = 'blur(20px)';
        nav.style.borderBottom = '1px solid #f0f0f0';
      } else {
        nav.style.backgroundColor = 'transparent';
        nav.style.backdropFilter = 'none';
        nav.style.borderBottom = 'none';
      }

      // Hide/show on scroll direction
      if (currentScroll > lastScroll && currentScroll > 200) {
        gsap.to(nav, { y: -64, duration: 0.3, ease: 'power2.in' });
      } else {
        gsap.to(nav, { y: 0, duration: 0.3, ease: 'power2.out' });
      }

      lastScroll = currentScroll;
    }, { passive: true });
  }
</script>
