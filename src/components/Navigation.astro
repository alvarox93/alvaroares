<nav class="fixed top-0 left-0 right-0 z-50" id="main-nav" style="background-color: transparent;">
  <div class="max-w-[1200px] mx-auto px-xl lg:px-3xl flex items-center justify-between h-16">
    <a href="/" class="text-ink text-[15px] font-normal tracking-[-0.3px]">
      Álvaro Ares
    </a>
    <div class="flex items-center gap-xl">
      <a href="#work" class="text-muted text-[13px] font-normal tracking-[-0.2px] hover:text-ink transition-colors duration-200">Work</a>
      <a href="#about" class="text-muted text-[13px] font-normal tracking-[-0.2px] hover:text-ink transition-colors duration-200">About</a>
      <a href="#contact" class="text-muted text-[13px] font-normal tracking-[-0.2px] hover:text-ink transition-colors duration-200">Contact</a>
    </div>
  </div>
</nav>

<script>
  const nav = document.getElementById('main-nav');
  if (nav) {
    window.addEventListener('scroll', () => {
      if (window.scrollY > 50) {
        nav.style.backgroundColor = 'rgba(255, 255, 255, 0.85)';
        nav.style.backdropFilter = 'blur(20px)';
        nav.style.borderBottom = '1px solid #f0f0f0';
      } else {
        nav.style.backgroundColor = 'transparent';
        nav.style.backdropFilter = 'none';
        nav.style.borderBottom = 'none';
      }
    }, { passive: true });
  }
</script>
