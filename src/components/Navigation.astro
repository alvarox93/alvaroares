---
import LanguageSwitcher from '@components/LanguageSwitcher.astro';
import { useTranslations, defaultLang, type Language } from '@i18n/ui';
import IconChat from '@components/icons/IconChat.astro';

const lang = (Astro.currentLocale ?? defaultLang) as Language;
const t = useTranslations(lang);
const homeHref = lang === defaultLang ? '/' : `/${lang}`;
const aboutHref = lang === defaultLang ? '/about' : '/es/about';

const nameChars = 'Álvaro Ares'.split('');
const aboutChars = t('nav.about').split('');
---

<nav class="fixed top-0 left-0 right-0 z-50" id="main-nav">
  <div class="max-w-[1200px] mx-auto px-xl lg:px-3xl flex items-center justify-between h-16">
    <a
      href={homeHref}
      data-transition-line1={t('transition.home.line1')}
      data-transition-line2={t('transition.home.line2')}
      class="nav-char-link nav-name text-ink text-[15px] font-medium tracking-[-0.3px]"
    >
      <span class="nav-text">
        {nameChars.map((char) => (
          <span class="nav-char">{char === ' ' ? '\u00A0' : char}</span>
        ))}
      </span>
    </a>

    {/* Desktop nav */}
    <div class="hidden md:flex items-center gap-lg">
      <a
        href={aboutHref}
        data-transition-line1={t('transition.about.line1')}
        data-transition-line2={t('transition.about.line2')}
        class="nav-char-link nav-about text-[13px] font-normal tracking-[-0.2px]"
      >
        <span class="nav-text">
          {aboutChars.map((char) => (
            <span class="nav-char">{char === ' ' ? '\u00A0' : char}</span>
          ))}
        </span>
      </a>
      <a href="mailto:hey@alvaroar.es" class="inline-flex items-center gap-1.5 justify-center px-4 py-2 bg-ink text-canvas text-[12px] font-medium tracking-[-0.2px] rounded-lg transition-colors duration-300 hover:bg-ink/85">
        <IconChat />
        {t('nav.contact.talk')}
      </a>
      <button class="theme-knob" aria-label="Toggle color theme" data-theme-knob>
        <svg class="theme-icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4"/>
          <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
        </svg>
        <svg class="theme-icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>
      <LanguageSwitcher />
    </div>

    {/* Mobile burger */}
    <button
      class="md:hidden burger-btn relative w-10 h-10 flex items-center justify-center"
      aria-label="Open menu"
      aria-expanded="false"
      data-burger
    >
      <span class="burger-line burger-line-1"></span>
      <span class="burger-line burger-line-2"></span>
    </button>
  </div>
</nav>

{/* Mobile full-screen menu */}
<div class="mobile-menu fixed inset-0 z-40 pointer-events-none" data-mobile-menu>
  <div class="mobile-menu-backdrop absolute inset-0 bg-canvas" data-menu-backdrop></div>
  <div class="mobile-menu-content relative h-full flex flex-col justify-between px-xl py-2xl opacity-0" data-menu-content>
    {/* Top: about link */}
    <div></div>

    {/* Center: main links */}
    <div class="flex flex-col items-center gap-xl">
      <a
        href={aboutHref}
        data-transition-line1={t('transition.about.line1')}
        data-transition-line2={t('transition.about.line2')}
        class="mobile-menu-link text-ink text-[32px] font-semibold tracking-[-0.6px]"
      >{t('nav.about')}</a>
      <a
        href="mailto:hey@alvaroar.es"
        class="mobile-menu-link text-ink text-[32px] font-semibold tracking-[-0.6px]"
      >{t('nav.contact.talk')}</a>
    </div>

    {/* Bottom: email, socials, controls */}
    <div class="flex flex-col gap-xl">
      {/* Controls row */}
      <div class="flex items-center justify-center gap-lg">
        <button class="theme-knob theme-knob-mobile" aria-label="Toggle color theme" data-theme-knob-mobile>
          <svg class="theme-icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="4"/>
            <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
          </svg>
          <svg class="theme-icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
        </button>
        <LanguageSwitcher />
      </div>

      {/* Divider */}
      <div class="h-px bg-border mx-auto w-full"></div>

      {/* Email */}
      <a href="mailto:hey@alvaroar.es" class="block text-center text-muted text-[14px] tracking-[-0.2px] hover:text-ink transition-colors duration-200">
        hey@alvaroar.es
      </a>

      {/* Socials */}
      <div class="flex items-center justify-center gap-lg">
        <a href="https://linkedin.com/in/alvaroares" target="_blank" rel="noopener" class="text-muted text-[13px] tracking-[-0.2px] hover:text-ink transition-colors duration-200">LinkedIn</a>
        <a href="https://instagram.com/alvaroares" target="_blank" rel="noopener" class="text-muted text-[13px] tracking-[-0.2px] hover:text-ink transition-colors duration-200">Instagram</a>
        <a href="https://vimeo.com/alvaroares" target="_blank" rel="noopener" class="text-muted text-[13px] tracking-[-0.2px] hover:text-ink transition-colors duration-200">Vimeo</a>
      </div>
    </div>
  </div>
</div>

<style is:global>
  :root,
  [data-theme="warm"] {
    --accent: #e8a838;
    --accent-light: #fdf6e8;
    --accent-rgb: 232, 168, 56;
  }

  [data-theme="cold"] {
    --accent: #2596a8;
    --accent-light: #eaf4f6;
    --accent-rgb: 37, 150, 168;
  }
</style>

<style>
  #main-nav {
    background-color: transparent;
    transition: background-color 0.4s ease;
  }

  #main-nav.nav-scrolled {
    background-color: color-mix(in srgb, var(--color-canvas) 90%, transparent);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }

  .nav-char-link {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    position: relative;
  }

  .nav-text {
    display: inline-block;
  }

  .nav-char {
    display: inline-block;
    will-change: transform;
  }

  .nav-about {
    color: var(--color-muted);
    transition: color 0.25s ease;
  }

  .nav-about:hover {
    color: var(--color-ink);
  }

  /* Theme knob */
  .theme-knob {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 1.5px solid var(--color-border);
    padding: 0;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    color: var(--color-muted);
    transition: transform 0.2s ease, border-color 0.2s ease, color 0.2s ease;
    position: relative;
  }

  .theme-knob:hover {
    transform: scale(1.1);
    border-color: var(--theme-knob-hover-color, var(--color-ink));
  }

  .theme-knob:active {
    transform: scale(0.92);
  }

  .theme-icon-sun,
  .theme-icon-moon {
    width: 14px;
    height: 14px;
    position: absolute;
    transition: opacity 0.25s ease, transform 0.25s ease;
  }

  .theme-icon-sun {
    color: #e8a838;
    opacity: 0;
    transform: scale(0.6);
  }

  .theme-icon-moon {
    color: #2596a8;
    opacity: 1;
    transform: scale(1);
  }

  .theme-knob.is-cold {
    --theme-knob-hover-color: #e8a838;
  }

  .theme-knob:not(.is-cold) {
    --theme-knob-hover-color: #2596a8;
  }

  .theme-knob.is-cold .theme-icon-sun {
    opacity: 1;
    transform: scale(1);
  }

  .theme-knob.is-cold .theme-icon-moon {
    opacity: 0;
    transform: scale(0.6);
  }

  /* ── Burger ── */
  .burger-btn {
    background: none;
    border: none;
    padding: 0;
  }

  .burger-line {
    display: block;
    width: 20px;
    height: 1.5px;
    background: var(--color-ink);
    border-radius: 1px;
    position: absolute;
    transition: transform 0.35s cubic-bezier(0.77, 0, 0.18, 1),
                opacity 0.2s ease;
  }

  .burger-line-1 {
    transform: translateY(-4px);
  }

  .burger-line-2 {
    transform: translateY(4px);
  }

  .burger-btn.is-open .burger-line-1 {
    transform: rotate(45deg);
  }

  .burger-btn.is-open .burger-line-2 {
    transform: rotate(-45deg);
  }

  /* ── Mobile menu ── */
  .mobile-menu {
    visibility: hidden;
  }

  .mobile-menu.is-visible {
    visibility: visible;
    pointer-events: auto;
  }

  .mobile-menu-backdrop {
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .mobile-menu.is-visible .mobile-menu-backdrop {
    opacity: 1;
  }

  .mobile-menu-content {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding-top: 80px;
    padding-bottom: 40px;
  }

  .mobile-menu-link {
    opacity: 0;
    transform: translateY(20px);
  }
</style>

<script>
  import { gsap } from 'gsap';

  /* ── Theme Toggle ── */
  const STORAGE_KEY = 'aa-theme';
  const root = document.documentElement;
  const stored = localStorage.getItem(STORAGE_KEY);
  const initial = stored === 'cold' || stored === 'warm' ? stored : 'warm';
  root.setAttribute('data-theme', initial);

  function syncKnob(el: HTMLButtonElement | null, theme: string) {
    if (!el) return;
    el.classList.toggle('is-cold', theme === 'cold');
    el.setAttribute('aria-pressed', String(theme === 'warm'));
  }

  const desktopKnob = document.querySelector<HTMLButtonElement>('[data-theme-knob]');
  const mobileKnob = document.querySelector<HTMLButtonElement>('[data-theme-knob-mobile]');

  syncKnob(desktopKnob, initial);
  syncKnob(mobileKnob, initial);

  function toggleTheme() {
    const current = root.getAttribute('data-theme') || 'warm';
    const next = current === 'warm' ? 'cold' : 'warm';
    root.setAttribute('data-theme', next);
    localStorage.setItem(STORAGE_KEY, next);
    syncKnob(desktopKnob, next);
    syncKnob(mobileKnob, next);
  }

  desktopKnob?.addEventListener('click', toggleTheme);
  mobileKnob?.addEventListener('click', toggleTheme);

  /* ── Mobile menu ── */
  const burger = document.querySelector<HTMLButtonElement>('[data-burger]');
  const menu = document.querySelector<HTMLElement>('[data-mobile-menu]');
  const menuContent = menu?.querySelector<HTMLElement>('[data-menu-content]');
  const menuLinks = menuContent?.querySelectorAll<HTMLElement>('.mobile-menu-link') ?? [];
  let isOpen = false;
  let menuTl: gsap.core.Timeline | null = null;

  function openMenu() {
    if (!menu || !menuContent || isOpen) return;
    isOpen = true;
    burger?.classList.add('is-open');
    burger?.setAttribute('aria-expanded', 'true');
    burger?.setAttribute('aria-label', 'Close menu');
    menu.classList.add('is-visible');
    document.body.style.overflow = 'hidden';

    if (menuTl) menuTl.kill();
    menuTl = gsap.timeline();
    menuTl
      .fromTo(menuContent, { opacity: 0 }, { opacity: 1, duration: 0.3, ease: 'power2.out' })
      .fromTo(menuLinks, { y: 24, opacity: 0 }, { y: 0, opacity: 1, duration: 0.35, stagger: 0.08, ease: 'power3.out' }, '-=0.1');
  }

  function closeMenu() {
    if (!menu || !menuContent || !isOpen) return;
    isOpen = false;
    burger?.classList.remove('is-open');
    burger?.setAttribute('aria-expanded', 'false');
    burger?.setAttribute('aria-label', 'Open menu');
    document.body.style.overflow = '';

    if (menuTl) menuTl.kill();
    menuTl = gsap.timeline({
      onComplete: () => {
        if (!isOpen) menu.classList.remove('is-visible');
      },
    });
    menuTl
      .to(menuLinks, { y: 16, opacity: 0, duration: 0.2, stagger: 0.04, ease: 'power2.in' })
      .to(menuContent, { opacity: 0, duration: 0.25, ease: 'power2.in' }, '-=0.1');
  }

  burger?.addEventListener('click', () => {
    isOpen ? closeMenu() : openMenu();
  });

  // Close on link click
  menuLinks.forEach((link) => {
    link.addEventListener('click', () => {
      closeMenu();
    });
  });

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && isOpen) closeMenu();
  });

  // Close if resized to desktop
  window.addEventListener('resize', () => {
    if (window.innerWidth >= 768 && isOpen) closeMenu();
  });

  /* ── Per-character hover ── */
  document.querySelectorAll<HTMLElement>('.nav-char-link').forEach((link) => {
    const chars = link.querySelectorAll<HTMLElement>('.nav-char');
    if (!chars.length) return;

    let hoverTween: gsap.core.Tween | null = null;

    link.addEventListener('mouseenter', () => {
      if (hoverTween) hoverTween.kill();
      hoverTween = gsap.to(chars, {
        y: -2,
        duration: 0.2,
        stagger: 0.02,
        ease: 'power2.out',
      });
    });

    link.addEventListener('mouseleave', () => {
      if (hoverTween) hoverTween.kill();
      hoverTween = gsap.to(chars, {
        y: 0,
        duration: 0.2,
        stagger: 0.02,
        ease: 'power2.in',
      });
    });
  });
</script>
