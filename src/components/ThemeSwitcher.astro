---
const colors = [
  { name: 'gold', label: 'Gold', hex: '#e8a838' },
  { name: 'coral', label: 'Coral', hex: '#e87461' },
  { name: 'turquoise', label: 'Turquoise', hex: '#4abfb0' },
  { name: 'rose', label: 'Rose', hex: '#d4697a' },
  { name: 'violet', label: 'Violet', hex: '#9b87d4' },
];
---

<div class="fixed bottom-6 right-6 z-[10000]" id="theme-switcher">
  <button
    id="theme-toggle"
    class="theme-btn flex items-center gap-2.5 px-4 py-2.5 bg-canvas/90 backdrop-blur-lg border border-border rounded-full cursor-pointer select-none"
    aria-label="Change accent color"
  >
    <span class="accent-dot"></span>
    <span class="text-[11px] font-medium tracking-[0.12px] uppercase text-muted">I adapt to you</span>
  </button>

  <div
    id="theme-panel"
    class="absolute bottom-full right-0 mb-3 bg-canvas/95 backdrop-blur-xl border border-border rounded-2xl p-5 opacity-0 pointer-events-none transform translate-y-3 transition-all duration-300"
    style="min-width: 200px;"
  >
    <p class="text-[10px] font-medium tracking-[0.14px] uppercase text-ghost mb-3">Pick your vibe</p>
    <div class="flex items-center gap-3">
      {colors.map((c, i) => (
        <button
          class={`color-swatch magnetic-swatch ${i === 0 ? 'active' : ''}`}
          data-theme-name={c.name}
          style={`background: ${c.hex};`}
          aria-label={`Set accent to ${c.label}`}
          title={c.label}
        />
      ))}
    </div>
  </div>
</div>

<script>
  import { gsap } from 'gsap';

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const toggle = document.getElementById('theme-toggle');
  const panel = document.getElementById('theme-panel');
  let panelOpen = false;

  if (toggle && !prefersReducedMotion) {
    toggle.addEventListener('mousemove', (e) => {
      const rect = toggle.getBoundingClientRect();
      const x = e.clientX - rect.left - rect.width / 2;
      const y = e.clientY - rect.top - rect.height / 2;
      gsap.to(toggle, {
        x: x * 0.3,
        y: y * 0.3,
        duration: 0.3,
        ease: 'power2.out',
      });
    });

    toggle.addEventListener('mouseleave', () => {
      gsap.to(toggle, {
        x: 0,
        y: 0,
        duration: 0.7,
        ease: 'elastic.out(1.2, 0.4)',
      });
    });
  }

  if (toggle) {
    toggle.addEventListener('click', (e) => {
      e.stopPropagation();
      panelOpen = !panelOpen;
      if (panel) {
        panel.style.opacity = panelOpen ? '1' : '0';
        panel.style.pointerEvents = panelOpen ? 'auto' : 'none';
        panel.style.transform = panelOpen ? 'translateY(0)' : 'translateY(12px)';
      }
    });
  }

  document.addEventListener('click', (e) => {
    if (toggle && panel && !toggle.contains(e.target as Node) && !panel.contains(e.target as Node)) {
      panelOpen = false;
      panel.style.opacity = '0';
      panel.style.pointerEvents = 'none';
      panel.style.transform = 'translateY(12px)';
    }
  });

  if (!prefersReducedMotion) {
    document.querySelectorAll('.magnetic-swatch').forEach((el) => {
      el.addEventListener('mousemove', (e) => {
        const rect = (el as HTMLElement).getBoundingClientRect();
        const x = (e as MouseEvent).clientX - rect.left - rect.width / 2;
        const y = (e as MouseEvent).clientY - rect.top - rect.height / 2;
        gsap.to(el, {
          x: x * 0.4,
          y: y * 0.4,
          scale: 1.2,
          duration: 0.25,
          ease: 'power2.out',
        });
      });

      el.addEventListener('mouseleave', () => {
        gsap.to(el, {
          x: 0,
          y: 0,
          scale: 1,
          duration: 0.6,
          ease: 'elastic.out(1.2, 0.35)',
        });
      });
    });
  }

  const swatches = document.querySelectorAll('.color-swatch');
  swatches.forEach((swatch) => {
    swatch.addEventListener('click', () => {
      const theme = (swatch as HTMLElement).dataset.themeName;
      if (theme) {
        document.documentElement.setAttribute('data-theme', theme);
      }
      swatches.forEach(s => s.classList.remove('active'));
      swatch.classList.add('active');
    });
  });
</script>
