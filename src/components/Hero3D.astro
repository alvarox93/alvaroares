---
---

<div class="hero-3d-container" id="hero-3d">
  <canvas id="hero-3d-canvas"></canvas>
</div>

<script>
  import * as THREE from 'three';

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const container = document.getElementById('hero-3d');
  const canvas = document.getElementById('hero-3d-canvas') as HTMLCanvasElement;

  if (container && canvas && !prefersReducedMotion) {
    const scene = new THREE.Scene();

    const camera = new THREE.PerspectiveCamera(40, 1, 0.1, 100);
    camera.position.set(0, 2.5, 5);
    camera.lookAt(0, 0, 0);

    const renderer = new THREE.WebGLRenderer({
      canvas,
      antialias: true,
      alpha: true,
    });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.setClearColor(0x000000, 0);

    // Lights
    const ambientLight = new THREE.AmbientLight(0xffffff, 0.7);
    scene.add(ambientLight);

    const directionalLight = new THREE.DirectionalLight(0xffffff, 1);
    directionalLight.position.set(4, 6, 4);
    scene.add(directionalLight);

    const fillLight = new THREE.DirectionalLight(0xffffff, 0.3);
    fillLight.position.set(-3, 2, -3);
    scene.add(fillLight);

    // Keycap shape — wider than tall, top face slightly smaller
    const baseW = 1.4;
    const baseD = 1.2;
    const baseH = 0.5;
    const topW = 1.2;
    const topD = 1.0;
    const topH = 0.08;
    const topY = baseH;

    // Build custom geometry
    const geometry = new THREE.BufferGeometry();

    // Vertices: bottom face (4) + top base (4) + top surface (4) = 12 vertices
    const hw = baseW / 2;
    const hd = baseD / 2;
    const thw = topW / 2;
    const thd = topD / 2;

    const vertices = new Float32Array([
      // Bottom face (y=0)
      -hw, 0, -hd,
       hw, 0, -hd,
       hw, 0,  hd,
      -hw, 0,  hd,

      // Top base edge (y=baseH)
      -hw, baseH, -hd,
       hw, baseH, -hd,
       hw, baseH,  hd,
      -hw, baseH,  hd,

      // Top surface (y=baseH+topH, slightly inset)
      -thw, topY + topH, -thd,
       thw, topY + topH, -thd,
       thw, topY + topH,  thd,
      -thw, topY + topH,  thd,
    ]);

    const indices = [
      // Bottom
      0, 2, 1,  0, 3, 2,
      // Front
      0, 1, 5,  0, 5, 4,
      // Back
      3, 6, 2,  3, 7, 6,
      // Left
      0, 4, 7,  0, 7, 3,
      // Right
      1, 2, 6,  1, 6, 5,
      // Top base (connecting base to top surface)
      4, 5, 9,   4, 9, 8,
      5, 6, 10,  5, 10, 9,
      6, 7, 11,  6, 11, 10,
      7, 4, 8,   7, 8, 11,
      // Top surface
      8, 9, 10,  8, 10, 11,
    ];

    geometry.setIndex(indices);
    geometry.setAttribute('position', new THREE.BufferAttribute(vertices, 3));
    geometry.computeVertexNormals();

    const material = new THREE.MeshPhysicalMaterial({
      color: 0xffffff,
      roughness: 0.25,
      metalness: 0,
      clearcoat: 0.3,
      clearcoatRoughness: 0.4,
    });

    const keycap = new THREE.Mesh(geometry, material);
    // Initial rotation to show top face
    keycap.rotation.x = -0.4;
    scene.add(keycap);

    // Click interaction — press down and spring back
    let isPressed = false;
    let pressTime = 0;
    const pressDuration = 0.4;
    const pressDepth = -0.2;

    container.addEventListener('mousedown', () => {
      isPressed = true;
      pressTime = 0;
    });

    container.addEventListener('mouseup', () => {
      isPressed = false;
    });

    container.addEventListener('mouseleave', () => {
      isPressed = false;
    });

    // Mouse tracking
    const mouse = { x: 0, y: 0 };
    const targetRotation = { x: 0, y: 0 };

    document.addEventListener('mousemove', (e) => {
      mouse.x = (e.clientX / window.innerWidth) * 2 - 1;
      mouse.y = -(e.clientY / window.innerHeight) * 2 + 1;
    });

    // Resize
    function updateSize() {
      const rect = container.getBoundingClientRect();
      camera.aspect = rect.width / rect.height;
      camera.updateProjectionMatrix();
      renderer.setSize(rect.width, rect.height);
    }
    updateSize();
    window.addEventListener('resize', updateSize);

    // Animation
    const clock = new THREE.Clock();
    let baseY = 0;

    function animate() {
      requestAnimationFrame(animate);

      const elapsed = clock.getElapsedTime();
      const delta = clock.getDelta();

      // Float
      const floatY = Math.sin(elapsed * 0.7) * 0.12;
      keycap.position.x = Math.sin(elapsed * 0.4) * 0.04;

      // Click press animation
      if (isPressed) {
        pressTime += delta;
        const t = Math.min(pressTime / pressDuration, 1);
        // Ease out cubic
        const eased = 1 - Math.pow(1 - t, 3);
        baseY = pressDepth * eased;
      } else {
        // Spring back
        baseY += (0 - baseY) * 0.08;
      }

      keycap.position.y = floatY + baseY;

      // Mouse-reactive rotation
      targetRotation.x = mouse.y * 0.3 + (-0.4);
      targetRotation.y = mouse.x * 0.3;

      keycap.rotation.x += (targetRotation.x - keycap.rotation.x) * 0.04;
      keycap.rotation.y += (targetRotation.y - keycap.rotation.y) * 0.04;
      keycap.rotation.z = Math.sin(elapsed * 0.25) * 0.03;

      renderer.render(scene, camera);
    }

    animate();
  }
</script>

<style>
  .hero-3d-container {
    width: 100%;
    height: 100%;
    min-height: 350px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #hero-3d-canvas {
    width: 100%;
    height: 100%;
    display: block;
  }
</style>
