---
interface Props {
  line1?: string;
  line2?: string;
}

const { line1 = '', line2 = '' } = Astro.props;
const words = line1.trim().split(/\s+/).filter(Boolean);
---

<div id="page-transition" class="page-transition" aria-hidden="true">
  <div class="transition-bg"></div>
  <div class="transition-content" id="trans-content">
    {words.map((w) => (
      <span class="word">{w}</span>
    ))}
  </div>
</div>

<style is:global>
  .page-transition {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 1;
    pointer-events: all;
  }

  .page-transition.is-done {
    opacity: 0;
    pointer-events: none;
  }

  .transition-bg {
    position: absolute;
    inset: 0;
    background: var(--color-canvas, #ffffff);
  }

  .transition-content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 0.35em;
    text-align: center;
    padding: 0 32px;
    max-width: 90vw;
  }

  .page-transition .word {
    display: inline-block;
    font-family: 'Bricolage Grotesque', var(--font-display, system-ui, -apple-system, sans-serif);
    font-size: clamp(18px, 3vw, 32px);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.01em;
    color: var(--color-ink, #1a1a1a);
    opacity: 0;
    will-change: transform, opacity;
  }

  /* Fallback: si JS nunca carga, ocultar a los 4s */
  @media (prefers-reduced-motion: no-preference) {
    .page-transition {
      animation: pt-safety 0.5s ease-out 4s forwards;
    }
  }

  @keyframes pt-safety {
    from { opacity: 1; pointer-events: all; }
    to   { opacity: 0; pointer-events: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .page-transition {
      animation: none !important;
      display: none !important;
    }
  }
</style>

<script>
  import { gsap } from 'gsap';

  (function() {
    const overlay = document.getElementById('page-transition');
    if (!overlay) return;

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReducedMotion) {
      overlay.classList.add('is-done');
      return;
    }

    // Cancelar CSS fallback
    overlay.style.animation = 'none';

    function forceVisible() {
      overlay.classList.remove('is-done');
      gsap.set(overlay, { opacity: 1, pointerEvents: 'all' });
    }

    function forceHidden() {
      overlay.classList.add('is-done');
      gsap.set(overlay, { opacity: 0, pointerEvents: 'none' });
    }

    const words = overlay.querySelectorAll<HTMLElement>('.word');

    if (!words.length) {
      forceHidden();
      return;
    }

    const tl = gsap.timeline({
      onComplete: forceHidden,
    });

    // Empiezan arriba y ocultas
    tl.set(words, { y: -30, opacity: 0 });

    // Caen
    tl.to(words, {
      y: 0,
      opacity: 1,
      duration: 0.5,
      stagger: 0.08,
      ease: 'power3.out',
    });

    // Flash read
    tl.to({}, { duration: 0.4 });

    // Se desvanecen hacia abajo
    tl.to(words, {
      y: 15,
      opacity: 0,
      duration: 0.3,
      stagger: 0.04,
      ease: 'power2.in',
    });

    // Overlay fade out
    tl.to(overlay, {
      opacity: 0,
      duration: 0.5,
      ease: 'power2.inOut',
    });
  })();
</script>
