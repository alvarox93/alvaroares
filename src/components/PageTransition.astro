---
interface Props {
  line1?: string;
  line2?: string;
}

const { line1 = '', line2 = '' } = Astro.props;
const words = line1.trim().split(/\s+/).filter(Boolean);
---

<div id="page-transition" class="page-transition" aria-hidden="true" data-line1={line1} data-line2={line2}>
  <div class="transition-bg"></div>
  <div class="transition-content" id="trans-content">
    {words.map((w) => (
      <span class="word">{w}</span>
    ))}
  </div>
</div>

<style>
  .page-transition {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 1;
    pointer-events: all;
  }

  .page-transition.is-done {
    pointer-events: none;
  }

  .transition-bg {
    position: absolute;
    inset: 0;
    background: var(--color-canvas, #ffffff);
  }

  .transition-content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 0.35em;
    text-align: center;
    padding: 0 32px;
    max-width: 90vw;
  }

  .word {
    display: inline-block;
    font-family: 'Bricolage Grotesque', var(--font-display, system-ui, -apple-system, sans-serif);
    font-size: clamp(18px, 3vw, 32px);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.01em;
    color: var(--color-ink, #1a1a1a);
    opacity: 0;
    transform: translateY(-40px);
    will-change: transform, opacity;
  }

  /* Fallback: si JS nunca carga o falla, el overlay se oculta solo después de 3s */
  @media (prefers-reduced-motion: no-preference) {
    .page-transition {
      animation: pt-safety-fade 0.5s ease-out 3s forwards;
    }
  }

  @keyframes pt-safety-fade {
    from { opacity: 1; pointer-events: all; }
    to   { opacity: 0; pointer-events: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .page-transition {
      animation: none !important;
      display: none !important;
    }
  }
</style>

<script>
  import { gsap } from 'gsap';

  (function() {
    const transition = document.getElementById('page-transition');
    const content = document.getElementById('trans-content') as HTMLElement | null;

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReducedMotion || !transition || !content) {
      if (transition) {
        transition.style.opacity = '0';
        transition.style.pointerEvents = 'none';
      }
      return;
    }

    // Cancelar la animación CSS de fallback para que no interfiera
    transition.style.animation = 'none';

    const STORAGE_KEY = 'aa-page-transition';
    let safetyTimer: ReturnType<typeof setTimeout> | null = null;

    function setWords(text: string) {
      const words = text.trim().split(/\s+/).filter(Boolean);
      content.innerHTML = words.map((w) => `<span class="word">${w}</span>`).join('');
    }

    function getWordEls(): HTMLElement[] {
      return Array.from(content.querySelectorAll('.word'));
    }

    function forceVisible() {
      transition.classList.remove('is-done');
      gsap.set(transition, { opacity: 1, pointerEvents: 'all' });
    }

    function forceHidden() {
      transition.classList.add('is-done');
      gsap.set(transition, { opacity: 0, pointerEvents: 'none' });
    }

    function safetyHide() {
      if (safetyTimer) clearTimeout(safetyTimer);
      safetyTimer = setTimeout(() => {
        forceHidden();
      }, 3500);
    }

    function clearSafety() {
      if (safetyTimer) {
        clearTimeout(safetyTimer);
        safetyTimer = null;
      }
    }

    // --- ENTRADA: ejecutada SIEMPRE en cada carga / restauración ---
    function playEnter() {
      clearSafety();
      forceVisible();

      const words = getWordEls();
      if (!words.length) {
        gsap.to(transition, { opacity: 0, duration: 0.4, ease: 'power2.inOut', onComplete: forceHidden });
        return;
      }

      const tl = gsap.timeline({
        onComplete: () => {
          clearSafety();
          forceHidden();
        },
      });

      // Palabras empiezan arriba y ocultas
      tl.set(words, { y: -40, opacity: 0 });

      // Caen de arriba abajo con stagger
      tl.to(words, {
        y: 0,
        opacity: 1,
        duration: 0.7,
        stagger: 0.1,
        ease: 'power3.out',
      });

      // Flash read
      tl.to({}, { duration: 0.55 });

      // Se desvanecen hacia abajo
      tl.to(words, {
        y: 20,
        opacity: 0,
        duration: 0.4,
        stagger: 0.05,
        ease: 'power2.in',
      });

      // Overlay blanco se desvanece revelando la página
      tl.to(transition, {
        opacity: 0,
        duration: 0.65,
        ease: 'power2.inOut',
      });

      safetyHide();
    }

    // --- SALIDA ---
    function playExit(onComplete: () => void) {
      clearSafety();
      forceVisible();

      const words = getWordEls();
      if (!words.length) {
        onComplete();
        return;
      }

      const tl = gsap.timeline({ onComplete });

      tl.set(words, { y: -40, opacity: 0 });

      tl.to(words, {
        y: 0,
        opacity: 1,
        duration: 0.7,
        stagger: 0.1,
        ease: 'power3.out',
      });

      tl.to({}, { duration: 0.55 });

      safetyHide();
    }

    (window as any).__pageTransition = {
      playEnter,
      playExit,
      setWords,
      storeLines: (l1: string, l2: string) => {
        sessionStorage.setItem(STORAGE_KEY, JSON.stringify({ line1: l1, line2: l2 }));
      },
    };

    // --- SIEMPRE ejecutar entrada ---
    // "pageshow" se dispara en carga normal Y en restauración desde bfcache (botón atrás)
    const runEnter = () => {
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          playEnter();
        });
      });
    };

    // Intentar ejecutar ahora si el DOM ya está listo
    if (document.readyState !== 'loading') {
      runEnter();
    } else {
      document.addEventListener('DOMContentLoaded', runEnter);
    }

    // También en pageshow (captura bfcache del navegador)
    window.addEventListener('pageshow', () => {
      runEnter();
    });
  })();
</script>
