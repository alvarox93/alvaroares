---
interface Props {
  line1?: string;
  line2?: string;
}

const { line1 = '', line2 = '' } = Astro.props;
const words = line1.trim().split(/\s+/).filter(Boolean);
---

<div id="page-transition" class="page-transition" aria-hidden="true">
  <div class="transition-bg"></div>
  <div class="transition-content">
    {words.map((w) => (
      <span class="word">{w}</span>
    ))}
  </div>
</div>

<style is:global>
  .page-transition {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 1;
    pointer-events: all;
  }

  .transition-bg {
    position: absolute;
    inset: 0;
    background: var(--color-canvas, #ffffff);
  }

  .transition-content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 0.35em;
    text-align: center;
    padding: 0 32px;
    max-width: 90vw;
  }

  .page-transition .word {
    display: inline-block;
    font-family: 'Bricolage Grotesque', var(--font-display, system-ui, -apple-system, sans-serif);
    font-size: clamp(18px, 3vw, 32px);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.01em;
    color: var(--color-ink, #1a1a1a);
    opacity: 0;
    transform: translateY(-30px);
    will-change: transform, opacity;
  }

  /* --- Animación activa cuando .is-animating está presente --- */

  .page-transition.is-animating .word {
    animation: word-cycle 1.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .page-transition.is-animating .word:nth-child(1) { animation-delay: 0s; }
  .page-transition.is-animating .word:nth-child(2) { animation-delay: 0.08s; }
  .page-transition.is-animating .word:nth-child(3) { animation-delay: 0.16s; }
  .page-transition.is-animating .word:nth-child(4) { animation-delay: 0.24s; }
  .page-transition.is-animating .word:nth-child(5) { animation-delay: 0.32s; }
  .page-transition.is-animating .word:nth-child(6) { animation-delay: 0.40s; }

  @keyframes word-cycle {
    0%   { transform: translateY(-30px); opacity: 0; }
    36.7%{ transform: translateY(0);     opacity: 1; }
    66.7%{ transform: translateY(0);     opacity: 1; }
    90%  { transform: translateY(15px);  opacity: 0; }
    100% { transform: translateY(15px);  opacity: 0; }
  }

  .page-transition.is-animating {
    animation: overlay-fade 0.55s ease-in-out 1.9s forwards;
  }

  @keyframes overlay-fade {
    from { opacity: 1; pointer-events: all; }
    to   { opacity: 0; pointer-events: none; }
  }

  /* Fallback si el script nunca corre: ocultar a los 5s */
  .page-transition:not(.is-animating) {
    animation: pt-safety 0.6s ease-out 5s forwards;
  }

  @keyframes pt-safety {
    from { opacity: 1; pointer-events: all; }
    to   { opacity: 0; pointer-events: none; }
  }

  /* --- Estado de salida: visible inmediatamente, sin animación --- */
  .page-transition.is-exiting {
    opacity: 1 !important;
    pointer-events: all !important;
    animation: none !important;
    transition: none !important;
  }

  .page-transition.is-exiting .word {
    opacity: 0 !important;
    transform: translateY(-30px) !important;
    animation: none !important;
  }

  @media (prefers-reduced-motion: reduce) {
    .page-transition,
    .page-transition.is-animating,
    .page-transition:not(.is-animating) {
      animation: none !important;
      display: none !important;
    }
  }
</style>

<script is:inline>
  (function() {
    function run() {
      var overlay = document.getElementById('page-transition');
      if (!overlay) return;

      // Respectar prefers-reduced-motion
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        overlay.style.display = 'none';
        return;
      }

      // Limpiar estilos inline de animaciones anteriores o bfcache
      overlay.style.opacity = '';
      overlay.style.pointerEvents = '';
      overlay.style.transition = '';
      overlay.style.animation = '';

      var words = overlay.querySelectorAll('.word');
      for (var i = 0; i < words.length; i++) {
        words[i].style.transform = '';
        words[i].style.opacity = '';
        words[i].style.animation = '';
      }

      // Reiniciar: limpiar clases de salida/entrada anteriores, forzar reflow, activar
      overlay.classList.remove('is-exiting');
      overlay.classList.remove('is-animating');
      void overlay.offsetHeight;
      overlay.classList.add('is-animating');
    }

    if (document.readyState !== 'loading') {
      run();
    } else {
      document.addEventListener('DOMContentLoaded', run);
    }

    // back/forward/bfcache
    window.addEventListener('pageshow', run);
  })();
</script>
