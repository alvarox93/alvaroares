---
const images = [
  'bar',
  'bonbon',
  'bravas-1',
  'bravas-2',
  'cafe',
  'chocolate-bar',
  'chocolate-hover',
  'churro',
  'churros',
  'coulant',
  'gyoza',
  'honey-cake',
  'huesito',
  'kortxo',
  'macaron',
  'matcha-cookies',
  'panellet-1',
  'panellet-2',
  'panellet-3',
  'pansuflado',
  'pasta',
  'pineapple',
  'pringle',
  'snack',
  'spoonful',
  'tea-matcha',
  'topoki',
  'waffle-honey',
];

function shuffle(arr: string[]): string[] {
  const a = [...arr];
  for (let i = a.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}

const shuffled = shuffle(images);

const slot0 = shuffled.slice(0, Math.ceil(shuffled.length / 3));
const slot1 = shuffled.slice(Math.ceil(shuffled.length / 3), Math.ceil(2 * shuffled.length / 3));
const slot2 = shuffled.slice(Math.ceil(2 * shuffled.length / 3));

const initial = [slot0[0], slot1[0], slot2[0]];

const slotsData = JSON.stringify({ slot0, slot1, slot2 });
const initialData = JSON.stringify(initial);
---

<div class="food-slideshow absolute -top-[15%] left-0 w-full h-[130%] flex gap-1.5 project-image-wrap bg-surface" data-slideshow data-slots={slotsData} data-initial={initialData}>
  {initial.map((img, i) => (
    <div class="food-slide-slot" data-slot={i} style="flex: 1; position: relative; overflow: hidden; border-radius: 6px;">
      <img
        src={`/food-renders/${img}.webp`}
        alt=""
        loading="lazy"
        decoding="async"
        class="food-slide-img absolute inset-0 w-full h-full object-cover"
        style="opacity: 1; z-index: 1;"
        data-active="true"
      />
      <img
        src={`/food-renders/${img}.webp`}
        alt=""
        loading="lazy"
        decoding="async"
        class="food-slide-img absolute inset-0 w-full h-full object-cover"
        style="opacity: 0; z-index: 0;"
        data-active="false"
      />
    </div>
  ))}
  <div class="absolute inset-0 bg-ink/0 group-hover:bg-ink/[0.03] transition-colors duration-500"></div>
</div>

<script>
  const container = document.querySelector<HTMLElement>('[data-slideshow]');
  if (!container) throw new Error('FoodSlideshow container not found');

  const slotsData: Record<string, string[]> = JSON.parse(container.dataset.slots || '{}');

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!prefersReducedMotion) {
    const slots = Array.from(container.querySelectorAll<HTMLElement>('[data-slot]'));
    const queues = slots.map((_, i) => slotsData[`slot${i}`] as string[]);
    const indices = [0, 0, 0];

    const FADE_DURATION = 0.9;
    const INTERVAL = 700;

    const swapSlot = (i: number) => {
      indices[i] = (indices[i] + 1) % queues[i].length;
      const nextSrc = `/food-renders/${queues[i][indices[i]]}.webp`;

      const slot = slots[i];
      const imgs = Array.from(slot.querySelectorAll<HTMLImageElement>('.food-slide-img'));
      const active = imgs.find((img) => img.dataset.active === 'true')!;
      const inactive = imgs.find((img) => img.dataset.active === 'false')!;

      let done = false;
      const doSwap = () => {
        if (done) return;
        done = true;

        inactive.style.transition = 'none';
        inactive.src = nextSrc;
        inactive.offsetHeight;

        const ease = 'cubic-bezier(0.4, 0, 0.2, 1)';
        inactive.style.transition = `opacity ${FADE_DURATION}s ${ease}`;
        active.style.transition = `opacity ${FADE_DURATION}s ${ease}`;

        inactive.style.opacity = '1';
        active.style.opacity = '0';

        inactive.dataset.active = 'true';
        active.dataset.active = 'false';

        inactive.style.zIndex = '1';
        active.style.zIndex = '0';
      };

      const preload = new Image();
      preload.onload = doSwap;
      preload.src = nextSrc;
      if (preload.complete) doSwap();
    };

    let currentSlot = 0;
    let timer: ReturnType<typeof setInterval> | null = null;

    const startInterval = () => {
      return setInterval(() => {
        swapSlot(currentSlot);
        currentSlot = (currentSlot + 1) % 3;
      }, INTERVAL);
    };

    timer = startInterval();

    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          if (!timer) {
            timer = startInterval();
          }
        } else {
          if (timer) {
            clearInterval(timer);
            timer = null;
          }
        }
      },
      { threshold: 0.1 }
    );

    observer.observe(container);
  }
</script>

<style>
  .food-slide-img {
    will-change: opacity;
  }

  @media (prefers-reduced-motion: reduce) {
    .food-slide-img {
      transition: none !important;
    }
  }
</style>
