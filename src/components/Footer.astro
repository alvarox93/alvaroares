---
import { useTranslations, defaultLang, type Language } from '@i18n/ui';

const lang = (Astro.currentLocale ?? defaultLang) as Language;
const t = useTranslations(lang);
const year = new Date().getFullYear();
---

<footer class="bg-canvas py-16 px-lg border-t border-border">
  <div class="max-w-[1400px] mx-auto">
    <div class="flex flex-col md:flex-row justify-between items-start gap-lg mb-xl">
      <div>
        <p class="text-ink text-[17px] font-semibold tracking-[-0.374px] mb-xs">Álvaro Ares</p>
        <p class="text-muted text-[14px] tracking-[-0.224px]">{t('footer.location')}</p>
      </div>
      <div class="flex flex-col gap-xs">
        <a href="https://linkedin.com/in/alvaroares" target="_blank" rel="noopener" class="text-muted text-[14px] tracking-[-0.224px] hover:text-ink transition-colors duration-200">LinkedIn</a>
        <a href="https://vimeo.com/alvaroares" target="_blank" rel="noopener" class="text-muted text-[14px] tracking-[-0.224px] hover:text-ink transition-colors duration-200">Vimeo</a>
        <a href="https://instagram.com/alvaroares" target="_blank" rel="noopener" class="text-muted text-[14px] tracking-[-0.224px] hover:text-ink transition-colors duration-200">Instagram</a>
      </div>
    </div>
    <div class="pt-lg flex flex-col md:flex-row justify-between gap-sm">
      <p class="text-ghost text-[12px] tracking-[-0.12px]">© {year} Álvaro Ares. {lang === 'es' ? 'Todos los derechos reservados.' : 'All rights reserved.'}</p>
      <p class="text-ghost text-[12px] tracking-[-0.12px]">{lang === 'es' ? 'El trabajo es el argumento.' : 'The work is the argument.'}</p>
    </div>
  </div>
</footer>
