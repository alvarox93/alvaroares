---
import { getCollection } from 'astro:content';
import PostLayout from '@layouts/PostLayout.astro';
import { type Language } from '@i18n/ui';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  const enPosts = posts.filter((p) => p.data.lang === 'en');
  return enPosts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const lang = 'en' as Language;

const transitions: Record<string, string> = {
  'motion-design-systems': 'Motion that moves people',
  'cgi-vs-photography': 'Every pixel earned',
  'ai-pipeline': 'Half the time, all the judgment',
  'designing-in-code': 'Code as craft',
  'building-lapatzak': 'Built from scratch',
};

const transitionLine1 = transitions[post.slug] ?? post.data.title;
const transitionLine2 = '';
---

<PostLayout
  title={post.data.title}
  category={post.data.category}
  readTime={post.data.readTime}
  date={post.data.date}
  description={post.data.description}
  lang={lang}
  transitionLine1={transitionLine1}
  transitionLine2={transitionLine2}
>
  <Content />
</PostLayout>
