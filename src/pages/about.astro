---
import BaseLayout from '@layouts/BaseLayout.astro';
import Navigation from '@components/Navigation.astro';
import { useTranslations, defaultLang, type Language } from '@i18n/ui';

const lang = (Astro.currentLocale ?? defaultLang) as Language;
const t = useTranslations(lang);

const timeline = [
  {
    year: '2026',
    period: lang === 'es' ? 'Ahora' : 'Now',
    role: t('about.timeline.item.now.role'),
    company: t('about.timeline.item.now.company'),
    location: 'Barcelona',
    description: t('about.timeline.item.now.description'),
    tags: [t('about.timeline.item.now.tag1'), t('about.timeline.item.now.tag2')],
    accent: true,
  },
  {
    year: '2024',
    period: '2024 — ' + (lang === 'es' ? 'Presente' : 'Present'),
    role: t('about.timeline.item.lapatzak.role'),
    company: 'Lapatzak',
    location: 'Barcelona',
    description: t('about.timeline.item.lapatzak.description'),
    tags: [t('about.timeline.item.lapatzak.tag1'), t('about.timeline.item.lapatzak.tag2'), t('about.timeline.item.lapatzak.tag3')],
  },
  {
    year: '2023',
    period: '2023 — ' + (lang === 'es' ? 'Presente' : 'Present'),
    role: t('about.timeline.item.renders.role'),
    company: lang === 'es' ? 'Renders + Lab' : 'Renders + Lab',
    location: 'Barcelona',
    description: t('about.timeline.item.renders.description'),
    tags: [t('about.timeline.item.renders.tag1'), t('about.timeline.item.renders.tag2'), t('about.timeline.item.renders.tag3'), t('about.timeline.item.renders.tag4')],
  },
  {
    year: '2022',
    period: lang === 'es' ? 'Mudanza' : 'Move',
    role: t('about.timeline.item.move.role'),
    company: lang === 'es' ? 'Nueva ciudad, nuevas apuestas' : 'New city, new bets',
    location: 'Barcelona',
    description: t('about.timeline.item.move.description'),
    tags: [t('about.timeline.item.move.tag1')],
  },
  {
    year: '2021',
    period: lang === 'es' ? 'Salto' : 'Breakthrough',
    role: t('about.timeline.item.intl.role'),
    company: 'Koora.studio',
    location: 'Bilbao',
    description: t('about.timeline.item.intl.description'),
    tags: [t('about.timeline.item.intl.tag1'), t('about.timeline.item.intl.tag2'), t('about.timeline.item.intl.tag3')],
  },
  {
    year: '2018',
    period: '2018 — 2022',
    role: t('about.timeline.item.koora.role'),
    company: 'Koora.studio',
    location: 'Bilbao',
    description: t('about.timeline.item.koora.description'),
    tags: [t('about.timeline.item.koora.tag1'), t('about.timeline.item.koora.tag2'), t('about.timeline.item.koora.tag3'), t('about.timeline.item.koora.tag4')],
  },
  {
    year: '2018',
    period: lang === 'es' ? 'Inicio de año' : 'Early year',
    role: t('about.timeline.item.ludei.role'),
    company: t('about.timeline.item.ludei.company'),
    location: lang === 'es' ? 'Remoto, Bilbao' : 'Remote, Bilbao',
    description: t('about.timeline.item.ludei.description'),
    tags: [t('about.timeline.item.ludei.tag1'), t('about.timeline.item.ludei.tag2'), t('about.timeline.item.ludei.tag3')],
  },
  {
    year: '2015',
    period: '2015',
    role: t('about.timeline.item.mmd.role'),
    company: 'MMD Distribution',
    location: 'Cork, Ireland',
    description: t('about.timeline.item.mmd.description'),
    tags: [t('about.timeline.item.mmd.tag1'), t('about.timeline.item.mmd.tag2'), t('about.timeline.item.mmd.tag3')],
  },
  {
    year: '2006',
    period: lang === 'es' ? 'Origen' : 'Origin',
    role: t('about.timeline.item.origin.role'),
    company: lang === 'es' ? 'Autodidacta' : 'Self-taught',
    location: 'Bilbao',
    description: t('about.timeline.item.origin.description'),
    tags: [t('about.timeline.item.origin.tag1')],
  },
];
---

<BaseLayout
  title={lang === 'es' ? 'Sobre mí — Álvaro Ares' : 'About — Álvaro Ares'}
  transitionLine1={t('transition.about.line1')}
  transitionLine2={t('transition.about.line2')}
>
  <Navigation />

  <main class="bg-canvas">

    <!-- INTRO -->
    <section class="relative overflow-hidden bg-canvas">
      <div class="hero-blob" id="about-blob" style="left: 70%; top: 30%; transform: translate(-50%, -50%);"></div>

      <div class="relative max-w-[1200px] mx-auto px-xl lg:px-3xl pt-32 pb-section">
        <span class="text-ghost text-[11px] font-medium tracking-[0.14px] uppercase mb-xl block">{t('about.label')}</span>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-2xl items-start">

          <div class="lg:col-span-5 order-2 lg:order-1">
            <div class="relative w-full max-w-[380px] aspect-[4/5] rounded-2xl overflow-hidden">
              <img
                src="/alvaroProfile.png"
                alt="Álvaro Ares"
                class="w-full h-full object-cover"
                loading="eager"
                fetchpriority="high"
              />
              <div class="absolute inset-0 ring-1 ring-inset ring-black/[0.08] rounded-2xl pointer-events-none"></div>
            </div>
          </div>

          <div class="lg:col-span-7 lg:col-start-6 order-1 lg:order-2 flex flex-col justify-between min-h-[420px]">
            <div>
              <h1 class="text-[clamp(36px,5.5vw,64px)] font-light leading-[1.05] tracking-[-0.04em] text-ink text-balance mb-xl">
                {t('about.heading')}
              </h1>
              <p class="text-[17px] leading-[1.65] text-muted max-w-[480px]">
                <strong class="text-ink font-medium">{t('about.lede.bold')}</strong> {t('about.lede.regular')}
              </p>
            </div>

            <div class="flex items-center gap-xl mt-2xl pt-xl border-t border-border-light">
              <div class="flex items-center gap-xs">
                <span class="accent-dot" style="width:6px;height:6px;"></span>
                <span class="text-ink text-[11px] font-medium tracking-[0.12px] uppercase">{t('about.meta.available')}</span>
              </div>
              <span class="w-[1px] h-[16px] bg-border"></span>
              <span class="text-muted text-[12px] tracking-[0.06px]">{t('footer.location')}</span>
              <span class="w-[1px] h-[16px] bg-border hidden sm:block"></span>
              <span class="text-muted text-[12px] tracking-[0.06px] hidden sm:block">{t('about.meta.worldwide')}</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- DARK CTA -->
    <section class="bg-ink">
      <div class="max-w-[1200px] mx-auto px-xl lg:px-3xl py-section">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-2xl items-center">
          <div class="lg:col-span-7">
            <span class="text-canvas/40 text-[11px] font-medium tracking-[0.14px] uppercase mb-lg block">{t('about.cta.dark.label')}</span>
            <h2 class="text-[clamp(28px,4vw,48px)] font-light leading-[1.08] tracking-[-0.04em] text-canvas text-balance mb-lg">
              {t('about.cta.dark.title')}
            </h2>
            <p class="text-canvas/60 text-[16px] leading-[1.65] max-w-[420px] mb-xl">
              {t('about.cta.dark.body')}
            </p>
            <div class="flex flex-wrap gap-sm">
              <a
                href={`mailto:${t('footer.email')}`}
                class="inline-flex items-center gap-xs px-4 py-2 bg-canvas text-ink text-[12px] font-medium tracking-[-0.2px] rounded-lg transition-colors duration-300 hover:bg-canvas/85"
              >
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                {t('about.cta.dark.contact')}
              </a>
              <a
                href="/alvaroAres_CV_2026.pdf"
                download
                class="inline-flex items-center gap-xs px-4 py-2 bg-canvas/10 text-canvas text-[12px] font-medium tracking-[-0.2px] rounded-lg border border-canvas/20 transition-colors duration-300 hover:border-canvas/40"
              >
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
                {t('about.cta.dark.cv')}
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- TIMELINE -->
    <section class="relative bg-canvas overflow-hidden" id="timeline-section">
      <div class="max-w-[1200px] mx-auto px-xl lg:px-3xl pt-section pb-2xl">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-2xl items-end mb-3xl">
          <div class="lg:col-span-7">
            <span class="text-ghost text-[11px] font-medium tracking-[0.14px] uppercase mb-lg block">{t('about.timeline.label')}</span>
            <h2 class="text-[clamp(28px,3.5vw,40px)] font-light leading-[1.08] tracking-[-0.04em] text-ink text-balance">
              {t('about.timeline.heading')}
            </h2>
          </div>
          <div class="lg:col-span-4 lg:col-start-9">
            <p class="text-muted text-[15px] leading-[1.6]">
              {t('about.timeline.caption')}
            </p>
          </div>
        </div>
      </div>

      <div class="relative max-w-[1200px] mx-auto px-xl lg:px-3xl pb-section">
        <div class="timeline-rail relative">

          <div class="timeline-line" aria-hidden="true">
            <div class="timeline-line-fill" id="timeline-fill"></div>
          </div>

          <div class="timeline-cap timeline-cap-top" aria-hidden="true">
            <span class="cap-dot"></span>
            <span class="cap-label">{t('about.timeline.now')}</span>
          </div>

          <ol class="relative space-y-2xl pt-2xl pb-2xl list-none">
            {timeline.map((item, i) => (
              <li class={`timeline-item ${item.accent ? 'is-accent' : ''} ${i % 2 === 0 ? 'is-left' : 'is-right'}`}>
                <div class="timeline-node" aria-hidden="true">
                  <span class="node-ring"></span>
                  <span class="node-dot"></span>
                </div>

                <div class="timeline-year">
                  <span class="year-text">{item.year}</span>
                </div>

                <article class="timeline-card group">
                  <div class="card-inner">
                    <div class="flex items-center gap-xs mb-sm flex-wrap">
                      <span class="text-ghost text-[10px] font-medium tracking-[0.14px] uppercase">{item.period}</span>
                      <span class="w-[3px] h-[3px] rounded-full bg-ghost/40"></span>
                      <span class="inline-flex items-center gap-1 text-ghost text-[10px] tracking-[0.06px]">
                        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                        {item.location}
                      </span>
                    </div>

                    <h3 class="text-[18px] font-medium leading-[1.2] tracking-[-0.02em] text-ink mb-xs">
                      {item.role}
                    </h3>
                    <p class="text-muted text-[13px] tracking-[-0.1px] mb-md font-medium">
                      {item.company}
                    </p>

                    <p class="text-muted text-[15px] leading-[1.6] mb-md">
                      {item.description}
                    </p>

                    {item.tags && item.tags.length > 0 && (
                      <div class="card-tags flex flex-wrap gap-xs">
                        {item.tags.map((tag) => (
                          <span class="text-ghost text-[10px] tracking-[0.08px] uppercase px-[10px] py-[5px] border border-border rounded-sm">
                            {tag}
                          </span>
                        ))}
                      </div>
                    )}
                  </div>
                </article>
              </li>
            ))}
          </ol>

          <div class="timeline-cap timeline-cap-bottom" aria-hidden="true">
            <span class="cap-dot"></span>
            <span class="cap-label">{t('about.timeline.start')}</span>
          </div>

        </div>
      </div>
    </section>

    <!-- WHAT I DO NOW -->
    <section class="bg-ink">
      <div class="max-w-[1200px] mx-auto px-xl lg:px-3xl py-section">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-2xl mb-3xl">
          <div class="lg:col-span-7">
            <span class="text-canvas/40 text-[11px] font-medium tracking-[0.14px] uppercase mb-lg block">{t('about.now.label')}</span>
            <h2 class="text-[clamp(28px,3.5vw,40px)] font-light leading-[1.08] tracking-[-0.04em] text-canvas text-balance">
              {t('about.now.heading')}
            </h2>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-lg">
          <div class="bg-canvas/[0.06] rounded-xl p-xl border border-canvas/10">
            <span class="text-canvas/40 text-[10px] font-medium tracking-[0.14px] uppercase mb-md block">{t('about.now.1.tag')}</span>
            <h3 class="text-[18px] font-medium leading-[1.2] tracking-[-0.02em] text-canvas mb-sm">{t('about.now.1.title')}</h3>
            <p class="text-canvas/60 text-[14px] leading-[1.6] mb-md">
              {t('about.now.1.body')}
            </p>
          </div>

          <div class="bg-canvas/[0.06] rounded-xl p-xl border border-canvas/10">
            <span class="text-canvas/40 text-[10px] font-medium tracking-[0.14px] uppercase mb-md block">{t('about.now.2.tag')}</span>
            <h3 class="text-[18px] font-medium leading-[1.2] tracking-[-0.02em] text-canvas mb-sm">{t('about.now.2.title')}</h3>
            <p class="text-canvas/60 text-[14px] leading-[1.6] mb-md">
              {t('about.now.2.body')}
            </p>
          </div>

          <div class="bg-canvas/[0.06] rounded-xl p-xl border border-canvas/10">
            <span class="text-canvas/40 text-[10px] font-medium tracking-[0.14px] uppercase mb-md block">{t('about.now.3.tag')}</span>
            <h3 class="text-[18px] font-medium leading-[1.2] tracking-[-0.02em] text-canvas mb-sm">{t('about.now.3.title')}</h3>
            <p class="text-canvas/60 text-[14px] leading-[1.6] mb-md">
              {t('about.now.3.body')}
            </p>
          </div>
        </div>
      </div>
    </section>

  </main>

  <div class="noise-overlay"></div>
</BaseLayout>

<style>
  .timeline-rail {
    padding-block: 24px;
  }

  .timeline-line {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 1px;
    background: linear-gradient(
      to bottom,
      transparent 0%,
      var(--color-border) 6%,
      var(--color-border) 94%,
      transparent 100%
    );
    z-index: 0;
  }

  .timeline-line-fill {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 0%;
    background: linear-gradient(
      to bottom,
      var(--accent) 0%,
      color-mix(in srgb, var(--accent) 30%, transparent) 100%
    );
    transition: height 0.1s linear;
  }

  .timeline-cap {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    z-index: 2;
  }

  .timeline-cap-top { top: 0; }
  .timeline-cap-bottom { bottom: 0; }

  .cap-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-canvas);
    border: 1.5px solid var(--color-ink);
  }

  .timeline-cap-top .cap-dot {
    background: var(--accent);
    border-color: var(--accent);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--accent) 18%, transparent);
  }

  .cap-label {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.14px;
    text-transform: uppercase;
    color: var(--color-ghost);
    background: var(--color-canvas);
    padding: 2px 8px;
  }

  .timeline-item {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 80px 1fr;
    align-items: center;
    gap: 0;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .timeline-item.is-revealed {
    opacity: 1;
    transform: translateY(0);
  }

  .timeline-node {
    grid-column: 2;
    justify-self: center;
    position: relative;
    width: 16px;
    height: 16px;
    z-index: 2;
  }

  .node-ring {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: var(--color-canvas);
    border: 1.5px solid var(--color-border);
    transition: border-color 0.3s ease, transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .node-dot {
    position: absolute;
    inset: 4px;
    border-radius: 50%;
    background: var(--color-ink);
    transform: scale(0);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                background-color 0.3s ease;
  }

  .timeline-item.is-revealed .node-dot { transform: scale(1); }

  .timeline-item.is-accent .node-ring {
    border-color: var(--accent);
    box-shadow: 0 0 0 5px color-mix(in srgb, var(--accent) 12%, transparent);
  }

  .timeline-item.is-accent .node-dot { background: var(--accent); }

  .timeline-year {
    display: flex;
    align-items: center;
  }

  .year-text {
    display: inline-block;
    font-family: var(--font-display);
    font-size: clamp(28px, 3.5vw, 44px);
    font-weight: 200;
    letter-spacing: -0.04em;
    line-height: 1;
    color: var(--color-ink);
    opacity: 0.75;
  }

  .timeline-item.is-accent .year-text {
    color: var(--accent);
    opacity: 1;
  }

  .timeline-card { position: relative; }

  .card-inner {
    background: var(--color-canvas);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-xl);
    padding: 24px;
    transition: border-color 0.3s ease,
                box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .timeline-item:hover .card-inner {
    border-color: var(--color-border);
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.05);
    transform: translateY(-2px);
  }

  .timeline-item:hover .node-ring {
    border-color: var(--accent);
    transform: scale(1.15);
  }

  .timeline-item.is-accent .card-inner {
    border-color: color-mix(in srgb, var(--accent) 35%, var(--color-border-light));
    background: linear-gradient(
      135deg,
      var(--color-canvas) 0%,
      color-mix(in srgb, var(--accent) 4%, var(--color-canvas)) 100%
    );
  }

  .timeline-item.is-left .timeline-card {
    grid-column: 1;
    padding-right: 32px;
  }

  .timeline-item.is-left .timeline-year {
    grid-column: 3;
    padding-left: 32px;
    justify-content: flex-start;
  }

  .timeline-item.is-right .timeline-year {
    grid-column: 1;
    padding-right: 32px;
    justify-content: flex-end;
  }

  .timeline-item.is-right .timeline-card {
    grid-column: 3;
    padding-left: 32px;
  }

  @media (max-width: 768px) {
    .timeline-line {
      left: 18px;
      transform: none;
    }

    .timeline-cap {
      left: 18px;
      transform: translateX(-50%);
    }

    .timeline-item {
      display: block;
      position: relative;
      padding-left: 48px;
    }

    .timeline-node {
      position: absolute;
      left: 10px;
      top: 14px;
      grid-column: auto !important;
    }

    .timeline-year,
    .timeline-card {
      grid-column: auto !important;
      padding-left: 0 !important;
      padding-right: 0 !important;
      justify-content: flex-start !important;
    }

    .timeline-year { margin-bottom: 8px; }

    .year-text { font-size: 28px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .timeline-item {
      opacity: 1;
      transform: none;
      transition: none;
    }
    .node-dot { transform: scale(1); }
    .timeline-line-fill { transition: none; }
  }
</style>

<script>
  import Lenis from 'lenis';
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const lenis = new Lenis({
    duration: 1.2,
    easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
    touchMultiplier: 2,
  });

  lenis.on('scroll', ScrollTrigger.update);

  gsap.ticker.add((time) => {
    lenis.raf(time * 1000);
  });

  gsap.ticker.lagSmoothing(0);

  const nav = document.getElementById('main-nav');
  let lastNavScroll = 0;
  let navHidden = false;

  if (nav) {
    lenis.on('scroll', ({ scroll }: { scroll: number }) => {
      if (scroll > 50) {
        nav.classList.add('nav-scrolled');
      } else {
        nav.classList.remove('nav-scrolled');
      }

      if (scroll > lastNavScroll && scroll > 200 && !navHidden) {
        gsap.to(nav, { y: -80, duration: 0.4, ease: 'power3.in' });
        navHidden = true;
      } else if (scroll < lastNavScroll && navHidden) {
        gsap.to(nav, { y: 0, duration: 0.35, ease: 'power2.out' });
        navHidden = false;
      }

      lastNavScroll = scroll;
    });
  }

  if (!prefersReducedMotion) {
    const blob = document.getElementById('about-blob');
    if (blob) {
      gsap.to(blob, {
        x: '+=80',
        y: '+=40',
        duration: 6,
        repeat: -1,
        yoyo: true,
        ease: 'sine.inOut',
      });
    }
  }

  const timelineItems = document.querySelectorAll<HTMLElement>('.timeline-item');

  if (!prefersReducedMotion) {
    timelineItems.forEach((item) => {
      ScrollTrigger.create({
        trigger: item,
        start: 'top 85%',
        once: true,
        onEnter: () => item.classList.add('is-revealed'),
      });
    });
  } else {
    timelineItems.forEach((item) => item.classList.add('is-revealed'));
  }

  const timelineFill = document.getElementById('timeline-fill');
  const rail = document.querySelector('.timeline-rail');

  if (timelineFill && rail && !prefersReducedMotion) {
    ScrollTrigger.create({
      trigger: rail,
      start: 'top 70%',
      end: 'bottom 60%',
      scrub: 0.6,
      onUpdate: (self) => {
        timelineFill.style.height = `${self.progress * 100}%`;
      },
    });
  } else if (timelineFill) {
    timelineFill.style.height = '100%';
  }

  document.querySelectorAll('.magnetic').forEach((el) => {
    el.addEventListener('mousemove', (e) => {
      const rect = (el as HTMLElement).getBoundingClientRect();
      const x = (e as MouseEvent).clientX - rect.left - rect.width / 2;
      const y = (e as MouseEvent).clientY - rect.top - rect.height / 2;
      gsap.to(el, {
        x: x * 0.15,
        y: y * 0.15,
        duration: 0.3,
        ease: 'power2.out',
      });
    });

    el.addEventListener('mouseleave', () => {
      gsap.to(el, {
        x: 0,
        y: 0,
        duration: 0.5,
        ease: 'elastic.out(1, 0.5)',
      });
    });
  });
</script>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!prefersReducedMotion) {
    const sections = document.querySelectorAll('main > section');

    if (sections[3]) {
      const cards = sections[3].querySelectorAll('.grid > div');
      if (cards.length) {
        gsap.from(cards, {
          y: 20, autoAlpha: 0, duration: 0.6, ease: 'power2.out', stagger: 0.1,
          scrollTrigger: { trigger: sections[3], start: 'top 80%', once: true },
        });
      }
    }
  }
</script>
