---
import BaseLayout from '@layouts/BaseLayout.astro';
import Navigation from '@components/Navigation.astro';
---

<BaseLayout title="Koora.studio — Álvaro Ares">
  <Navigation />

  <main class="bg-warm min-h-screen">
    <!-- Top bar -->
    <div class="sticky top-16 z-20 bg-warm/85 backdrop-blur-lg py-4 px-xl lg:px-3xl border-b border-border-light">
      <div class="max-w-[1200px] mx-auto flex justify-between items-center">
        <span class="inline-flex items-center gap-sm text-ghost text-[11px] font-medium tracking-[0.14px] uppercase">
          <span class="accent-dot"></span>
          Koora.studio · Case Study
        </span>
        <a href="/" class="text-ghost text-[11px] font-medium tracking-[0.14px] uppercase hover:text-ink transition-colors duration-200">&larr; Back</a>
      </div>
    </div>

    <div class="max-w-[1200px] mx-auto px-xl lg:px-3xl pt-section pb-section">

      <!-- Hero header -->
      <div class="mb-3xl">
        <span class="text-ghost text-[11px] font-medium tracking-[0.14px] uppercase mb-sm block">Creative Direction · CGI · Motion · 2016—2024</span>
        <h1 class="text-[clamp(44px,6vw,72px)] font-light leading-[1.02] tracking-[-0.045em] text-ink text-balance mb-xl">
          The studio chapter.
        </h1>
        <p class="text-[17px] leading-[1.65] text-muted max-w-[560px]">
          <strong class="text-ink font-medium">8 years. One studio. 150+ projects shipped.</strong> I founded Koora.studio in Bilbao, built a team of 8, and delivered CGI, motion and creative direction for brands across 12 countries. This is where I learned that ambition scales — geography doesn't matter.
        </p>
      </div>

      <!-- Dashboard Grid -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-xl mb-3xl">
        <div class="lg:col-span-3">
          <div class="bg-canvas rounded-xl border border-border-light p-xl">
            <span class="text-ghost text-[11px] font-medium tracking-[0.14px] uppercase block mb-sm">Years Leading</span>
            <span class="font-accent text-[clamp(36px,4vw,56px)] font-bold leading-none tracking-[-0.04em] text-ink">8+</span>
          </div>
        </div>
        <div class="lg:col-span-3">
          <div class="bg-canvas rounded-xl border border-border-light p-xl">
            <span class="text-ghost text-[11px] font-medium tracking-[0.14px] uppercase block mb-sm">Projects Delivered</span>
            <span class="font-accent text-[clamp(36px,4vw,56px)] font-bold leading-none tracking-[-0.04em] text-ink">150+</span>
          </div>
        </div>
        <div class="lg:col-span-3">
          <div class="bg-canvas rounded-xl border border-border-light p-xl">
            <span class="text-ghost text-[11px] font-medium tracking-[0.14px] uppercase block mb-sm">Team Members</span>
            <span class="font-accent text-[clamp(36px,4vw,56px)] font-bold leading-none tracking-[-0.04em] text-ink">8</span>
          </div>
        </div>
        <div class="lg:col-span-3">
          <div class="bg-canvas rounded-xl border border-border-light p-xl">
            <span class="text-ghost text-[11px] font-medium tracking-[0.14px] uppercase block mb-sm">Countries Served</span>
            <span class="font-accent text-[clamp(36px,4vw,56px)] font-bold leading-none tracking-[-0.04em] text-ink">12+</span>
          </div>
        </div>
      </div>

      <!-- Skills & Tools row -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-xl mb-3xl">
        <div class="lg:col-span-4">
          <div class="bg-canvas rounded-xl border border-border-light p-xl h-full">
            <span class="text-ghost text-[11px] font-medium tracking-[0.14px] uppercase block mb-lg">Core Skills</span>
            <div class="space-y-md">
              <div class="flex items-center justify-between">
                <span class="text-ink text-[14px] font-medium">Creative Direction</span>
                <div class="w-24 h-1.5 bg-surface rounded-full overflow-hidden"><div class="w-full h-full bg-accent rounded-full"></div></div>
              </div>
              <div class="flex items-center justify-between">
                <span class="text-ink text-[14px] font-medium">CGI & 3D Rendering</span>
                <div class="w-24 h-1.5 bg-surface rounded-full overflow-hidden"><div class="w-[95%] h-full bg-accent rounded-full"></div></div>
              </div>
              <div class="flex items-center justify-between">
                <span class="text-ink text-[14px] font-medium">Motion Design</span>
                <div class="w-24 h-1.5 bg-surface rounded-full overflow-hidden"><div class="w-[90%] h-full bg-accent rounded-full"></div></div>
              </div>
              <div class="flex items-center justify-between">
                <span class="text-ink text-[14px] font-medium">Art Direction</span>
                <div class="w-24 h-1.5 bg-surface rounded-full overflow-hidden"><div class="w-[92%] h-full bg-accent rounded-full"></div></div>
              </div>
              <div class="flex items-center justify-between">
                <span class="text-ink text-[14px] font-medium">Team Leadership</span>
                <div class="w-24 h-1.5 bg-surface rounded-full overflow-hidden"><div class="w-[88%] h-full bg-accent rounded-full"></div></div>
              </div>
            </div>
          </div>
        </div>

        <div class="lg:col-span-4">
          <div class="bg-canvas rounded-xl border border-border-light p-xl h-full">
            <span class="text-ghost text-[11px] font-medium tracking-[0.14px] uppercase block mb-lg">Tools & Software</span>
            <div class="flex flex-wrap gap-xs">
              <span class="text-ink text-[12px] font-medium px-3 py-1.5 bg-surface rounded-lg">Maya</span>
              <span class="text-ink text-[12px] font-medium px-3 py-1.5 bg-surface rounded-lg">V-Ray</span>
              <span class="text-ink text-[12px] font-medium px-3 py-1.5 bg-surface rounded-lg">After Effects</span>
              <span class="text-ink text-[12px] font-medium px-3 py-1.5 bg-surface rounded-lg">Cinema 4D</span>
              <span class="text-ink text-[12px] font-medium px-3 py-1.5 bg-surface rounded-lg">Premiere Pro</span>
              <span class="text-ink text-[12px] font-medium px-3 py-1.5 bg-surface rounded-lg">Photoshop</span>
              <span class="text-ink text-[12px] font-medium px-3 py-1.5 bg-surface rounded-lg">Illustrator</span>
              <span class="text-ink text-[12px] font-medium px-3 py-1.5 bg-surface rounded-lg">Figma</span>
            </div>
          </div>
        </div>

        <div class="lg:col-span-4">
          <div class="bg-canvas rounded-xl border border-border-light p-xl h-full">
            <span class="text-ghost text-[11px] font-medium tracking-[0.14px] uppercase block mb-lg">Services</span>
            <div class="space-y-sm">
              <div class="flex items-center gap-sm">
                <span class="w-1.5 h-1.5 rounded-full bg-accent"></span>
                <span class="text-ink text-[14px]">Product CGI & Rendering</span>
              </div>
              <div class="flex items-center gap-sm">
                <span class="w-1.5 h-1.5 rounded-full bg-accent"></span>
                <span class="text-ink text-[14px]">Motion Design Systems</span>
              </div>
              <div class="flex items-center gap-sm">
                <span class="w-1.5 h-1.5 rounded-full bg-accent"></span>
                <span class="text-ink text-[14px]">Campaign Direction</span>
              </div>
              <div class="flex items-center gap-sm">
                <span class="w-1.5 h-1.5 rounded-full bg-accent"></span>
                <span class="text-ink text-[14px]">Brand Visual Language</span>
              </div>
              <div class="flex items-center gap-sm">
                <span class="w-1.5 h-1.5 rounded-full bg-accent"></span>
                <span class="text-ink text-[14px]">Food & Packaging CGI</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Project showcases -->
      <div class="mb-3xl">
        <span class="text-ghost text-[11px] font-medium tracking-[0.14px] uppercase block mb-lg">Selected Projects</span>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-xl items-center mb-3xl">
        <div class="lg:col-span-7">
          <div class="relative aspect-[16/10] bg-canvas rounded-xl border border-border-light overflow-hidden group">
            <div class="absolute inset-0 flex items-center justify-center text-ghost text-[13px]">[CGI Product Rendering]</div>
            <div class="absolute inset-0 bg-ink/0 group-hover:bg-ink/5 transition-colors duration-500"></div>
          </div>
        </div>
        <div class="lg:col-span-4 lg:col-start-9">
          <span class="text-ghost text-[11px] font-medium tracking-[0.14px] uppercase mb-xs block">CGI · Product</span>
          <h3 class="text-[20px] font-light leading-[1.2] tracking-[-0.02em] text-ink mb-sm">Photoreal Rendering</h3>
          <p class="text-muted text-[14px] leading-[1.55]">
            <strong class="text-ink font-medium">Food. Packaging. Hero shots.</strong> Maya + V-Ray from scratch. Every texture designed so the product speaks before it exists.
          </p>
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-xl items-center mb-3xl">
        <div class="lg:col-span-4 lg:order-1">
          <span class="text-ghost text-[11px] font-medium tracking-[0.14px] uppercase mb-xs block">Motion Systems</span>
          <h3 class="text-[20px] font-light leading-[1.2] tracking-[-0.02em] text-ink mb-sm">Brand Motion Languages</h3>
          <p class="text-muted text-[14px] leading-[1.55]">
            <strong class="text-ink font-medium">Not animated logos.</strong> Complete motion systems. Pulse, rhythm, personality. Every easing — strategic.
          </p>
        </div>
        <div class="lg:col-span-7 lg:col-start-6 lg:order-2">
          <div class="relative aspect-[16/10] bg-canvas rounded-xl border border-border-light overflow-hidden group">
            <div class="absolute inset-0 flex items-center justify-center text-ghost text-[13px]">[Motion Systems]</div>
            <div class="absolute inset-0 bg-ink/0 group-hover:bg-ink/5 transition-colors duration-500"></div>
          </div>
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-xl items-center">
        <div class="lg:col-span-7">
          <div class="relative aspect-[16/10] bg-canvas rounded-xl border border-border-light overflow-hidden group">
            <div class="absolute inset-0 flex items-center justify-center text-ghost text-[13px]">[Campaign Direction]</div>
            <div class="absolute inset-0 bg-ink/0 group-hover:bg-ink/5 transition-colors duration-500"></div>
          </div>
        </div>
        <div class="lg:col-span-4 lg:col-start-9">
          <span class="text-ghost text-[11px] font-medium tracking-[0.14px] uppercase mb-xs block">Campaigns</span>
          <h3 class="text-[20px] font-light leading-[1.2] tracking-[-0.02em] text-ink mb-sm">Global Visual Narratives</h3>
          <p class="text-muted text-[14px] leading-[1.55]">
            <strong class="text-ink font-medium">End-to-end direction.</strong> CGI, motion, art direction. Concept to final frame. Every pixel intentional.
          </p>
        </div>
      </div>

      <!-- Client marquee -->
      <div class="mt-section">
        <div class="border-t border-border-light pt-xl">
          <p class="text-center text-ghost text-[11px] font-medium tracking-[0.14px] uppercase mb-xl">
            Trusted by teams that demand visual excellence
          </p>
          <div class="overflow-hidden">
            <div class="marquee-track">
              <div class="flex items-center gap-4xl shrink-0 px-2xl">
                <span class="text-[14px] font-medium tracking-[0.02px] text-muted/30 whitespace-nowrap">Client 01</span>
                <span class="text-[14px] font-medium tracking-[0.02px] text-muted/30 whitespace-nowrap">Client 02</span>
                <span class="text-[14px] font-medium tracking-[0.02px] text-muted/30 whitespace-nowrap">Client 03</span>
                <span class="text-[14px] font-medium tracking-[0.02px] text-muted/30 whitespace-nowrap">Client 04</span>
                <span class="text-[14px] font-medium tracking-[0.02px] text-muted/30 whitespace-nowrap">Client 05</span>
                <span class="text-[14px] font-medium tracking-[0.02px] text-muted/30 whitespace-nowrap">Client 06</span>
              </div>
              <div class="flex items-center gap-4xl shrink-0 px-2xl">
                <span class="text-[14px] font-medium tracking-[0.02px] text-muted/30 whitespace-nowrap">Client 01</span>
                <span class="text-[14px] font-medium tracking-[0.02px] text-muted/30 whitespace-nowrap">Client 02</span>
                <span class="text-[14px] font-medium tracking-[0.02px] text-muted/30 whitespace-nowrap">Client 03</span>
                <span class="text-[14px] font-medium tracking-[0.02px] text-muted/30 whitespace-nowrap">Client 04</span>
                <span class="text-[14px] font-medium tracking-[0.02px] text-muted/30 whitespace-nowrap">Client 05</span>
                <span class="text-[14px] font-medium tracking-[0.02px] text-muted/30 whitespace-nowrap">Client 06</span>
              </div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </main>

  <div class="noise-overlay"></div>
</BaseLayout>

<script>
  import Lenis from 'lenis';
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const lenis = new Lenis({
    duration: 1.2,
    easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
    touchMultiplier: 2,
  });

  lenis.on('scroll', ScrollTrigger.update);
  gsap.ticker.add((time) => { lenis.raf(time * 1000); });
  gsap.ticker.lagSmoothing(0);

  const nav = document.getElementById('main-nav');
  let lastNavScroll = 0;
  let navHidden = false;

  if (nav) {
    lenis.on('scroll', ({ scroll }: { scroll: number }) => {
      if (scroll > 50) nav.classList.add('nav-scrolled');
      else nav.classList.remove('nav-scrolled');

      if (scroll > lastNavScroll && scroll > 200 && !navHidden) {
        gsap.to(nav, { y: -80, duration: 0.4, ease: 'power3.in' });
        navHidden = true;
      } else if (scroll < lastNavScroll && navHidden) {
        gsap.to(nav, { y: 0, duration: 0.35, ease: 'power2.out' });
        navHidden = false;
      }
      lastNavScroll = scroll;
    });
  }

  if (!prefersReducedMotion) {
    const heroTitle = document.querySelector('main h1');
    if (heroTitle) {
      gsap.from(heroTitle, { y: 20, autoAlpha: 0, duration: 0.8, ease: 'power2.out', delay: 0.15 });
    }

    document.querySelectorAll('main .grid').forEach((grid) => {
      const isShowcase = grid.classList.contains('items-center') && grid.querySelector('h3');

      if (isShowcase) {
        const imageWrap = grid.querySelector('.aspect-\\[16\\/10\\]');
        const textCol = grid.querySelector('h3')?.closest('div');

        if (imageWrap) {
          gsap.from(imageWrap, {
            scale: 0.96, autoAlpha: 0, duration: 0.7, ease: 'power2.out',
            scrollTrigger: { trigger: grid, start: 'top 80%', once: true },
          });
          gsap.fromTo(imageWrap, { yPercent: 5 }, {
            yPercent: -5, ease: 'none',
            scrollTrigger: { trigger: grid, start: 'top bottom', end: 'bottom top', scrub: true },
          });
        }

        if (textCol) {
          const textEls = textCol.querySelectorAll(':scope > span, :scope > h3, :scope > p');
          if (textEls.length) {
            gsap.from(textEls, {
              y: 18, autoAlpha: 0, duration: 0.5, ease: 'power2.out', stagger: 0.1,
              scrollTrigger: { trigger: grid, start: 'top 78%', once: true },
            });
          }
          gsap.fromTo(textCol, { y: 20 }, {
            y: -20, ease: 'none',
            scrollTrigger: { trigger: grid, start: 'top bottom', end: 'bottom top', scrub: true },
          });
        }
      } else {
        const children = grid.querySelectorAll(':scope > div');
        if (children.length > 1) {
          gsap.from(children, {
            y: 16, autoAlpha: 0, duration: 0.5, ease: 'power2.out', stagger: 0.08,
            scrollTrigger: { trigger: grid, start: 'top 85%', once: true },
          });
        }
      }
    });

    document.querySelectorAll('main .border-t').forEach((el) => {
      gsap.from(el, {
        y: 16, autoAlpha: 0, duration: 0.6, ease: 'power2.out',
        scrollTrigger: { trigger: el, start: 'top 90%', once: true },
      });
    });

    document.querySelectorAll('.magnetic').forEach((el) => {
      el.addEventListener('mousemove', (e) => {
        const rect = (el as HTMLElement).getBoundingClientRect();
        const x = (e as MouseEvent).clientX - rect.left - rect.width / 2;
        const y = (e as MouseEvent).clientY - rect.top - rect.height / 2;
        gsap.to(el, { x: x * 0.15, y: y * 0.15, duration: 0.3, ease: 'power2.out' });
      });
      el.addEventListener('mouseleave', () => {
        gsap.to(el, { x: 0, y: 0, duration: 0.5, ease: 'elastic.out(1, 0.5)' });
      });
    });
  }
</script>
