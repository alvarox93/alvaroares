---
import BaseLayout from '@layouts/BaseLayout.astro';
import Navigation from '@components/Navigation.astro';
import Hero from '@components/Hero.astro';
import WorkSection from '@components/WorkSection.astro';
import ThemeSwitcher from '@components/ThemeSwitcher.astro';
---

<BaseLayout title="Álvaro Ares — Creative Director & Motion Strategist">
  <Navigation />
  <main>
    <Hero />
    <WorkSection />

    <!-- Mini About -->
    <section class="relative bg-canvas overflow-hidden" id="about-preview">
      <div class="max-w-[1200px] mx-auto px-xl lg:px-3xl py-section">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-3xl items-center">
          <div class="lg:col-span-5 about-reveal">
            <span class="text-ghost text-[11px] font-medium tracking-[0.14px] uppercase mb-sm block">About</span>
            <h2 class="text-[clamp(28px,3.5vw,40px)] font-light leading-[1.08] tracking-[-0.04em] text-ink text-balance">
              The person behind<br />the work.
            </h2>
          </div>
          <div class="lg:col-span-6 lg:col-start-7 about-reveal" style="transition-delay: 0.1s;">
            <p class="text-[16px] leading-[1.65] text-muted mb-lg">
              <strong class="text-ink font-medium">8 years of CGI, motion and brand systems.</strong> I ran a studio in Bilbao, led a team of 8, shipped campaigns for brands across 12 countries. Now based in Barcelona, I also work with AI and code — tools that make the creative work sharper.
            </p>
            <div class="flex flex-wrap gap-xs mb-xl">
              <span class="text-ghost text-[10px] tracking-[0.08px] uppercase px-[10px] py-[5px] border border-border rounded-sm">Maya</span>
              <span class="text-ghost text-[10px] tracking-[0.08px] uppercase px-[10px] py-[5px] border border-border rounded-sm">V-Ray</span>
              <span class="text-ghost text-[10px] tracking-[0.08px] uppercase px-[10px] py-[5px] border border-border rounded-sm">After Effects</span>
              <span class="text-ghost text-[10px] tracking-[0.08px] uppercase px-[10px] py-[5px] border border-border rounded-sm">Figma</span>
              <span class="text-ghost text-[10px] tracking-[0.08px] uppercase px-[10px] py-[5px] border border-border rounded-sm">HTML/CSS</span>
              <span class="text-ghost text-[10px] tracking-[0.08px] uppercase px-[10px] py-[5px] border border-border rounded-sm">AI Workflows</span>
            </div>
            <a href="/about" class="magnetic inline-flex items-center justify-center px-5 py-2.5 bg-ink text-canvas text-[12px] font-medium tracking-[-0.2px] rounded-lg transition-all duration-300 hover:bg-ink/85">
              More about me
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Posts — horizontal scroll -->
    <section class="relative bg-warm overflow-hidden" id="posts">
      <div class="max-w-[1200px] mx-auto px-xl lg:px-3xl pt-section pb-xl">
        <div class="flex items-end justify-between mb-xl posts-header">
          <div>
            <span class="text-ghost text-[11px] font-medium tracking-[0.14px] uppercase block mb-sm">Thinking</span>
            <h2 class="text-[clamp(28px,3.5vw,42px)] font-light leading-[1.08] tracking-[-0.04em] text-ink">
              Posts & concepts.
            </h2>
          </div>
        </div>
      </div>

      <div class="posts-scroll-container" id="posts-scroll">
        <div class="posts-track flex gap-xl px-xl lg:px-3xl pb-section" id="posts-track">

          <a href="#" class="post-card group shrink-0" style="width: 320px;">
            <div class="relative aspect-[3/4] bg-surface rounded-xl overflow-hidden mb-lg">
              <div class="absolute inset-0 flex items-center justify-center text-ghost text-[13px]">Motion</div>
              <div class="absolute inset-0 bg-ink/0 group-hover:bg-ink/[0.03] transition-colors duration-500"></div>
            </div>
            <div class="flex items-start justify-between mb-xs">
              <span class="text-ghost text-[11px] font-medium tracking-[0.14px] uppercase">Motion · Systems</span>
              <span class="text-ghost text-[11px] tracking-[0.14px]">5 min</span>
            </div>
            <h3 class="text-[16px] font-medium leading-[1.3] tracking-[-0.01em] text-ink group-hover:text-accent transition-colors duration-300">
              Why motion design systems matter more than animated logos
            </h3>
          </a>

          <a href="#" class="post-card group shrink-0" style="width: 320px;">
            <div class="relative aspect-[3/4] bg-surface rounded-xl overflow-hidden mb-lg">
              <div class="absolute inset-0 flex items-center justify-center text-ghost text-[13px]">CGI</div>
              <div class="absolute inset-0 bg-ink/0 group-hover:bg-ink/[0.03] transition-colors duration-500"></div>
            </div>
            <div class="flex items-start justify-between mb-xs">
              <span class="text-ghost text-[11px] font-medium tracking-[0.14px] uppercase">CGI · Product</span>
              <span class="text-ghost text-[11px] tracking-[0.14px]">4 min</span>
            </div>
            <h3 class="text-[16px] font-medium leading-[1.3] tracking-[-0.01em] text-ink group-hover:text-accent transition-colors duration-300">
              The case for CGI product rendering over traditional photography
            </h3>
          </a>

          <a href="#" class="post-card group shrink-0" style="width: 320px;">
            <div class="relative aspect-[3/4] bg-surface rounded-xl overflow-hidden mb-lg">
              <div class="absolute inset-0 flex items-center justify-center text-ghost text-[13px]">AI</div>
              <div class="absolute inset-0 bg-ink/0 group-hover:bg-ink/[0.03] transition-colors duration-500"></div>
            </div>
            <div class="flex items-start justify-between mb-xs">
              <span class="text-ghost text-[11px] font-medium tracking-[0.14px] uppercase">AI · Workflow</span>
              <span class="text-ghost text-[11px] tracking-[0.14px]">6 min</span>
            </div>
            <h3 class="text-[16px] font-medium leading-[1.3] tracking-[-0.01em] text-ink group-hover:text-accent transition-colors duration-300">
              AI-native production: how I automated 60% of my visual pipeline
            </h3>
          </a>

          <a href="#" class="post-card group shrink-0" style="width: 320px;">
            <div class="relative aspect-[3/4] bg-surface rounded-xl overflow-hidden mb-lg">
              <div class="absolute inset-0 flex items-center justify-center text-ghost text-[13px]">Code</div>
              <div class="absolute inset-0 bg-ink/0 group-hover:bg-ink/[0.03] transition-colors duration-500"></div>
            </div>
            <div class="flex items-start justify-between mb-xs">
              <span class="text-ghost text-[11px] font-medium tracking-[0.14px] uppercase">Design · Code</span>
              <span class="text-ghost text-[11px] tracking-[0.14px]">3 min</span>
            </div>
            <h3 class="text-[16px] font-medium leading-[1.3] tracking-[-0.01em] text-ink group-hover:text-accent transition-colors duration-300">
              Designing interfaces that think in code (and why it matters)
            </h3>
          </a>

        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="relative bg-ink text-canvas overflow-hidden" id="footer">
      <div class="max-w-[1200px] mx-auto px-xl lg:px-3xl pt-section pb-xl">

        <!-- Email -->
        <div class="mb-section">
          <a href="mailto:hey@alvaroar.es" class="block group" id="footer-email-link">
            <div class="footer-email text-[clamp(28px,4.5vw,56px)] font-light leading-[1.1] tracking-[-0.03em] text-canvas overflow-hidden" id="footer-email">
              hey@alvaroar.es
            </div>
          </a>
        </div>

        <!-- Bottom row -->
        <div class="border-t border-canvas/10 pt-xl flex flex-col sm:flex-row justify-between items-center gap-lg">
          <span class="text-canvas/30 text-[12px] tracking-[0.14px] order-2 sm:order-1">&copy; 2024 Álvaro Ares · Designed & built with intention</span>
          <div class="flex items-center gap-lg order-1 sm:order-2">
            <a href="https://linkedin.com" target="_blank" rel="noopener" class="text-canvas/30 hover:text-accent transition-colors duration-300" aria-label="LinkedIn">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            </a>
            <a href="https://instagram.com" target="_blank" rel="noopener" class="text-canvas/30 hover:text-accent transition-colors duration-300" aria-label="Instagram">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
            </a>
          </div>
        </div>
      </div>
    </footer>
  </main>
  <ThemeSwitcher />
  <div class="noise-overlay"></div>
</BaseLayout>

<script>
  import Lenis from 'lenis';
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!prefersReducedMotion) {
    const lenis = new Lenis({
      duration: 1.2,
      easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
      touchMultiplier: 2,
    });

    lenis.on('scroll', ScrollTrigger.update);

    gsap.ticker.add((time) => {
      lenis.raf(time * 1000);
    });

    gsap.ticker.lagSmoothing(0);

    document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
      anchor.addEventListener('click', (e) => {
        const href = anchor.getAttribute('href');
        if (href) {
          e.preventDefault();
          lenis.scrollTo(href);
        }
      });
    });

    // Horizontal scroll for posts
    const postsTrack = document.getElementById('posts-track');
    const postsSection = document.getElementById('posts');

    if (postsTrack && postsSection) {
      const totalWidth = postsTrack.scrollWidth - window.innerWidth + 100;

      gsap.to(postsTrack, {
        x: -totalWidth,
        ease: 'none',
        scrollTrigger: {
          trigger: postsSection,
          start: 'top+=200 top',
          end: `+=${totalWidth}`,
          pin: true,
          scrub: 1.5,
          anticipatePin: 1,
        },
      });
    }

    // About reveal
    document.querySelectorAll('.about-reveal').forEach((el) => {
      gsap.fromTo(el,
        { opacity: 0, y: 28 },
        {
          opacity: 1,
          y: 0,
          duration: 0.8,
          ease: 'power3.out',
          scrollTrigger: {
            trigger: el,
            start: 'top 90%',
            toggleActions: 'play none none none',
          },
        }
      );
    });

    // Posts header reveal
    document.querySelectorAll('.posts-header').forEach((el) => {
      gsap.fromTo(el,
        { opacity: 0, y: 25 },
        {
          opacity: 1,
          y: 0,
          duration: 0.8,
          ease: 'power3.out',
          scrollTrigger: {
            trigger: el,
            start: 'top 90%',
            toggleActions: 'play none none none',
          },
        }
      );
    });

    // Footer email — scroll reveal (per character)
    const emailEl = document.getElementById('footer-email');
    if (emailEl) {
      const text = emailEl.textContent || '';
      emailEl.innerHTML = '';

      text.split('').forEach((char) => {
        const span = document.createElement('span');
        span.textContent = char;
        span.style.display = 'inline-block';
        span.style.opacity = '0';
        span.style.transform = 'translateY(40px)';
        span.style.cursor = 'default';
        if (char === '@' || char === '.') {
          span.style.color = 'var(--accent)';
        }
        emailEl.appendChild(span);
      });

      const chars = emailEl.querySelectorAll('span');

      // Scroll reveal
      ScrollTrigger.create({
        trigger: emailEl,
        start: 'top 85%',
        onEnter: () => {
          gsap.to(chars, {
            opacity: 1,
            y: 0,
            duration: 0.6,
            ease: 'power3.out',
            stagger: 0.04,
          });
        },
        once: true,
      });

      // Per-character hover animation
      chars.forEach((charEl) => {
        charEl.addEventListener('mouseenter', () => {
          gsap.to(charEl, {
            y: -8,
            color: 'var(--accent)',
            duration: 0.3,
            ease: 'power2.out',
          });
        });

        charEl.addEventListener('mouseleave', () => {
          const isSpecial = charEl.textContent === '@' || charEl.textContent === '.';
          gsap.to(charEl, {
            y: 0,
            color: isSpecial ? 'var(--accent)' : 'var(--color-canvas)',
            duration: 0.5,
            ease: 'elastic.out(1, 0.4)',
          });
        });
      });
    }
  }
</script>

<style>
  .post-card {
    text-decoration: none;
    color: inherit;
  }

  .post-card .aspect-\[3\/4\] {
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1),
                box-shadow 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .post-card:hover .aspect-\[3\/4\] {
    transform: translateY(-4px);
    box-shadow: 0 20px 60px rgba(0,0,0,0.06);
  }
</style>
