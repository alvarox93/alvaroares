---
import BaseLayout from '@layouts/BaseLayout.astro';
import Navigation from '@components/Navigation.astro';
import Hero from '@components/Hero.astro';
import WorkSection from '@components/WorkSection.astro';
import ThemeSwitcher from '@components/ThemeSwitcher.astro';
---

<BaseLayout title="Álvaro Ares — Creative Director & CGI Artist">
  <Navigation />
  <main style="position: relative; z-index: 1; background: var(--color-canvas);">
    <Hero />
    <WorkSection />

    <!-- About — gradient fill -->
    <section class="relative bg-canvas overflow-hidden" id="about-preview">
      <div class="max-w-[1200px] mx-auto px-xl lg:px-3xl py-section">
        <span class="text-ghost text-[11px] font-medium tracking-[0.14px] uppercase mb-xl block about-reveal">About</span>
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-3xl items-start">
          <div class="lg:col-span-5 about-reveal" style="transition-delay: 0.05s;">
            <h2 class="text-[clamp(28px,3.5vw,40px)] font-light leading-[1.08] tracking-[-0.04em] text-ink text-balance">
              The person behind<br />the work.
            </h2>
          </div>
          <div class="lg:col-span-6 lg:col-start-7 about-reveal" style="transition-delay: 0.1s;">
            <p class="text-[19px] leading-[1.65] mb-lg" id="about-fill-paragraph">
              <strong class="text-ink font-medium">8 years of visual craft.</strong> <span class="about-word" style="color: #a0a0a0;">I</span> <span class="about-word" style="color: #a0a0a0;">ran</span> <span class="about-word" style="color: #a0a0a0;">a</span> <span class="about-word" style="color: #a0a0a0;">studio</span> <span class="about-word" style="color: #a0a0a0;">in</span> <span class="about-word" style="color: #a0a0a0;">Bilbao,</span> <span class="about-word" style="color: #a0a0a0;">led</span> <span class="about-word" style="color: #a0a0a0;">a</span> <span class="about-word" style="color: #a0a0a0;">team</span> <span class="about-word" style="color: #a0a0a0;">of</span> <span class="about-word" style="color: #a0a0a0;">8,</span> <span class="about-word" style="color: #a0a0a0;">shipped</span> <span class="about-word" style="color: #a0a0a0;">campaigns</span> <span class="about-word" style="color: #a0a0a0;">across</span> <span class="about-word" style="color: #a0a0a0;">12</span> <span class="about-word" style="color: #a0a0a0;">countries.</span> <span class="about-word" style="color: #a0a0a0;">Now</span> <span class="about-word" style="color: #a0a0a0;">based</span> <span class="about-word" style="color: #a0a0a0;">in</span> <span class="about-word" style="color: #a0a0a0;">Barcelona,</span> <span class="about-word" style="color: #a0a0a0;">I</span> <span class="about-word" style="color: #a0a0a0;">work</span> <span class="about-word" style="color: #a0a0a0;">with</span> <span class="about-word" style="color: #a0a0a0;">CGI,</span> <span class="about-word" style="color: #a0a0a0;">motion</span> <span class="about-word" style="color: #a0a0a0;">and</span> <span class="about-word" style="color: #a0a0a0;">brand</span> <span class="about-word" style="color: #a0a0a0;">systems</span> <span class="about-word" style="color: #a0a0a0;">—</span> <span class="about-word" style="color: #a0a0a0;">and</span> <span class="about-word" style="color: #a0a0a0;">explore</span> <span class="about-word" style="color: #a0a0a0;">AI</span> <span class="about-word" style="color: #a0a0a0;">and</span> <span class="about-word" style="color: #a0a0a0;">code</span> <span class="about-word" style="color: #a0a0a0;">to</span> <span class="about-word" style="color: #a0a0a0;">push</span> <span class="about-word" style="color: #a0a0a0;">the</span> <span class="about-word" style="color: #a0a0a0;">work</span> <span class="about-word" style="color: #a0a0a0;">further.</span>
            </p>
            <div class="flex flex-wrap gap-xs mb-xl">
              <span class="text-ghost text-[10px] tracking-[0.08px] uppercase px-[10px] py-[5px] border border-border rounded-sm">Maya</span>
              <span class="text-ghost text-[10px] tracking-[0.08px] uppercase px-[10px] py-[5px] border border-border rounded-sm">V-Ray</span>
              <span class="text-ghost text-[10px] tracking-[0.08px] uppercase px-[10px] py-[5px] border border-border rounded-sm">After Effects</span>
              <span class="text-ghost text-[10px] tracking-[0.08px] uppercase px-[10px] py-[5px] border border-border rounded-sm">Figma</span>
              <span class="text-ghost text-[10px] tracking-[0.08px] uppercase px-[10px] py-[5px] border border-border rounded-sm">HTML/CSS</span>
              <span class="text-ghost text-[10px] tracking-[0.08px] uppercase px-[10px] py-[5px] border border-border rounded-sm">AI Workflows</span>
            </div>
            <a href="/about" class="magnetic inline-flex items-center justify-center px-5 py-2.5 bg-ink text-canvas text-[12px] font-medium tracking-[-0.2px] rounded-lg transition-all duration-200 hover:scale-[0.97] hover:bg-ink/90 active:scale-[0.95]">
              More about me
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Mini CTA -->
    <section class="relative bg-warm overflow-hidden" id="mini-cta">
      <div class="max-w-[1200px] mx-auto px-xl lg:px-3xl py-3xl">
        <div class="flex flex-col sm:flex-row items-center justify-between gap-lg border-t border-b border-border-light py-xl cta-reveal">
          <p class="text-ink text-[18px] font-light tracking-[-0.02em]">
            Got something in mind? <strong class="font-medium">Let's talk.</strong>
          </p>
          <a href="mailto:hey@alvaroar.es" class="magnetic inline-flex items-center justify-center px-5 py-2.5 bg-ink text-canvas text-[12px] font-medium tracking-[-0.2px] rounded-lg transition-all duration-200 hover:scale-[0.97] hover:bg-ink/90 active:scale-[0.95]">
            Get in touch
          </a>
        </div>
      </div>
    </section>

    <!-- Posts — horizontal scroll -->
    <section class="relative bg-warm overflow-hidden pb-3xl" id="posts">
      <div class="posts-pin-wrapper" id="posts-pin">
        <div class="px-xl lg:px-3xl pt-xl pb-lg" style="text-align: left;">
          <span class="text-ghost text-[11px] font-medium tracking-[0.14px] uppercase block mb-sm">Thinking</span>
          <h2 class="text-[clamp(28px,3.5vw,42px)] font-light leading-[1.08] tracking-[-0.04em] text-ink">
            Posts & concepts.
          </h2>
        </div>

        <div class="posts-track flex gap-lg px-xl lg:px-3xl" id="posts-track">

          <a href="#" class="post-card group shrink-0" style="width: 280px;">
            <div class="relative aspect-[3/4] bg-surface rounded-xl overflow-hidden">
              <div class="absolute inset-0 flex items-center justify-center text-ghost text-[13px]">Motion</div>
              <div class="absolute bottom-0 left-0 right-0 p-lg bg-gradient-to-t from-black/60 to-transparent">
                <h3 class="text-[15px] font-medium leading-[1.3] tracking-[-0.01em] text-canvas">
                  Why motion design systems matter more than animated logos
                </h3>
              </div>
            </div>
            <div class="flex items-center gap-sm mt-sm">
              <span class="text-ghost text-[10px] tracking-[0.08px] uppercase px-2 py-1 border border-border rounded-sm">Motion</span>
              <span class="text-ghost text-[10px] tracking-[0.08px]">5 min</span>
            </div>
          </a>

          <a href="#" class="post-card group shrink-0" style="width: 280px;">
            <div class="relative aspect-[3/4] bg-surface rounded-xl overflow-hidden">
              <div class="absolute inset-0 flex items-center justify-center text-ghost text-[13px]">CGI</div>
              <div class="absolute bottom-0 left-0 right-0 p-lg bg-gradient-to-t from-black/60 to-transparent">
                <h3 class="text-[15px] font-medium leading-[1.3] tracking-[-0.01em] text-canvas">
                  The case for CGI product rendering over traditional photography
                </h3>
              </div>
            </div>
            <div class="flex items-center gap-sm mt-sm">
              <span class="text-ghost text-[10px] tracking-[0.08px] uppercase px-2 py-1 border border-border rounded-sm">CGI</span>
              <span class="text-ghost text-[10px] tracking-[0.08px]">4 min</span>
            </div>
          </a>

          <a href="#" class="post-card group shrink-0" style="width: 280px;">
            <div class="relative aspect-[3/4] bg-surface rounded-xl overflow-hidden">
              <div class="absolute inset-0 flex items-center justify-center text-ghost text-[13px]">AI</div>
              <div class="absolute bottom-0 left-0 right-0 p-lg bg-gradient-to-t from-black/60 to-transparent">
                <h3 class="text-[15px] font-medium leading-[1.3] tracking-[-0.01em] text-canvas">
                  AI-native production: how I automated 60% of my visual pipeline
                </h3>
              </div>
            </div>
            <div class="flex items-center gap-sm mt-sm">
              <span class="text-ghost text-[10px] tracking-[0.08px] uppercase px-2 py-1 border border-border rounded-sm">AI</span>
              <span class="text-ghost text-[10px] tracking-[0.08px]">6 min</span>
            </div>
          </a>

          <a href="#" class="post-card group shrink-0" style="width: 280px;">
            <div class="relative aspect-[3/4] bg-surface rounded-xl overflow-hidden">
              <div class="absolute inset-0 flex items-center justify-center text-ghost text-[13px]">Code</div>
              <div class="absolute bottom-0 left-0 right-0 p-lg bg-gradient-to-t from-black/60 to-transparent">
                <h3 class="text-[15px] font-medium leading-[1.3] tracking-[-0.01em] text-canvas">
                  Designing interfaces that think in code (and why it matters)
                </h3>
              </div>
            </div>
            <div class="flex items-center gap-sm mt-sm">
              <span class="text-ghost text-[10px] tracking-[0.08px] uppercase px-2 py-1 border border-border rounded-sm">Design</span>
              <span class="text-ghost text-[10px] tracking-[0.08px]">3 min</span>
            </div>
          </a>

          <a href="#" class="post-card group shrink-0" style="width: 280px;">
            <div class="relative aspect-[3/4] bg-surface rounded-xl overflow-hidden">
              <div class="absolute inset-0 flex items-center justify-center text-ghost text-[13px]">Brand</div>
              <div class="absolute bottom-0 left-0 right-0 p-lg bg-gradient-to-t from-black/60 to-transparent">
                <h3 class="text-[15px] font-medium leading-[1.3] tracking-[-0.01em] text-canvas">
                  Building a brand from zero: what I learned running Lapatzak
                </h3>
              </div>
            </div>
            <div class="flex items-center gap-sm mt-sm">
              <span class="text-ghost text-[10px] tracking-[0.08px] uppercase px-2 py-1 border border-border rounded-sm">Brand</span>
              <span class="text-ghost text-[10px] tracking-[0.08px]">4 min</span>
            </div>
          </a>

        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="fixed bottom-0 left-0 right-0 bg-ink text-canvas" id="footer" style="z-index: 0;">
      <div class="max-w-[1200px] mx-auto px-xl lg:px-3xl py-section">

        <!-- Email -->
        <div class="mb-lg">
          <a href="mailto:hey@alvaroar.es" class="block group" id="footer-email-link">
            <div class="footer-email text-[clamp(28px,4.5vw,56px)] font-medium leading-[1.1] tracking-[-0.03em] text-canvas overflow-hidden" id="footer-email">
              hey@alvaroar.es
            </div>
          </a>
        </div>

        <!-- Info line -->
        <div class="flex flex-wrap items-center gap-x-lg gap-y-sm mb-lg">
          <a href="tel:+34649635382" class="inline-flex items-center gap-xs text-canvas/50 text-[13px] hover:text-canvas transition-colors duration-300">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
            +34 649 635 382
          </a>
          <span class="text-canvas/20 text-[13px]">/</span>
          <span class="inline-flex items-center gap-xs text-canvas/50 text-[13px]">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            Barcelona, Spain
          </span>
          <span class="text-canvas/20 text-[13px]">/</span>
          <span class="text-canvas/50 text-[13px]">Working worldwide</span>
        </div>

        <!-- Bottom row -->
        <div class="flex items-center justify-between">
          <span class="text-canvas/20 text-[11px] tracking-[0.14px]">Designed & built by Álvaro Ares &middot; 2026</span>
          <div class="flex items-center gap-lg">
            <a href="https://linkedin.com" target="_blank" rel="noopener" class="text-canvas/30 hover:text-accent transition-colors duration-300" aria-label="LinkedIn">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            </a>
            <a href="https://instagram.com" target="_blank" rel="noopener" class="text-canvas/30 hover:text-accent transition-colors duration-300" aria-label="Instagram">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
            </a>
          </div>
        </div>
      </div>
    </footer>
  </main>

  <ThemeSwitcher />
  <div class="noise-overlay"></div>
</BaseLayout>

<script>
  import Lenis from 'lenis';
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!prefersReducedMotion) {
    const lenis = new Lenis({
      duration: 1.2,
      easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
      touchMultiplier: 2,
    });

    lenis.on('scroll', ScrollTrigger.update);

    gsap.ticker.add((time) => {
      lenis.raf(time * 1000);
    });

    gsap.ticker.lagSmoothing(0);

    document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
      anchor.addEventListener('click', (e) => {
        const href = anchor.getAttribute('href');
        if (href) {
          e.preventDefault();
          lenis.scrollTo(href);
        }
      });
    });

    // Horizontal scroll for posts
    const postsTrack = document.getElementById('posts-track');
    const postsPin = document.getElementById('posts-pin');

    if (postsTrack && postsPin) {
      const totalWidth = postsTrack.scrollWidth - window.innerWidth + 100;

      gsap.to(postsTrack, {
        x: -totalWidth,
        ease: 'none',
        scrollTrigger: {
          trigger: postsPin,
          start: 'top top',
          end: `+=${totalWidth}`,
          pin: true,
          scrub: 2,
          anticipatePin: 1,
        },
      });
    }

    // About reveal
    document.querySelectorAll('.about-reveal').forEach((el) => {
      gsap.fromTo(el,
        { opacity: 0, y: 20 },
        {
          opacity: 1,
          y: 0,
          duration: 0.8,
          ease: 'power2.out',
          scrollTrigger: {
            trigger: el,
            start: 'top 92%',
            toggleActions: 'play none none none',
          },
        }
      );
    });

    // About text — per-word gradient fill (pre-rendered spans)
    const wordSpans = document.querySelectorAll('.about-word');
    if (wordSpans.length > 0) {
      const totalWords = wordSpans.length;

      wordSpans.forEach((wordEl, i) => {
        const start = i / totalWords;
        const end = (i + 1) / totalWords;

        gsap.to(wordEl, {
          color: '#1a1a1a',
          ease: 'none',
          scrollTrigger: {
            trigger: wordEl.closest('p'),
            start: 'top 75%',
            end: 'top 20%',
            scrub: 1,
            onUpdate: (self) => {
              const progress = self.progress;
              if (progress >= start && progress <= end) {
                const localProgress = (progress - start) / (end - start);
                const v = Math.round(160 + (26 - 160) * localProgress);
                (wordEl as HTMLElement).style.color = `rgb(${v},${v},${v})`;
              } else if (progress > end) {
                (wordEl as HTMLElement).style.color = '#1a1a1a';
              }
            }
          }
        });
      });
    }

    // CTA reveal
    document.querySelectorAll('.cta-reveal').forEach((el) => {
      gsap.fromTo(el,
        { opacity: 0, y: 20 },
        {
          opacity: 1,
          y: 0,
          duration: 0.8,
          ease: 'power2.out',
          scrollTrigger: {
            trigger: el,
            start: 'top 90%',
            toggleActions: 'play none none none',
          },
        }
      );
    });

    // Footer email — scroll reveal + hover (only y, no color change)
    const emailEl = document.getElementById('footer-email');
    const emailLink = document.getElementById('footer-email-link');

    if (emailEl) {
      const text = emailEl.textContent || '';
      emailEl.innerHTML = '';

      text.split('').forEach((char) => {
        const span = document.createElement('span');
        span.textContent = char;
        span.style.display = 'inline-block';
        span.style.opacity = '0';
        span.style.transform = 'translateY(40px)';
        if (char === '@' || char === '.') {
          span.style.color = 'var(--accent)';
        }
        emailEl.appendChild(span);
      });

      const chars = emailEl.querySelectorAll('span');

      ScrollTrigger.create({
        trigger: emailEl,
        start: 'top 90%',
        onEnter: () => {
          gsap.to(chars, {
            opacity: 1,
            y: 0,
            duration: 0.6,
            ease: 'power2.out',
            stagger: 0.04,
          });
        },
        once: true,
      });

      if (emailLink) {
        emailLink.addEventListener('mouseenter', () => {
          gsap.to(chars, {
            y: -6,
            duration: 0.35,
            ease: 'power2.out',
            stagger: 0.02,
          });
        });

        emailLink.addEventListener('mouseleave', () => {
          gsap.to(chars, {
            y: 0,
            duration: 0.5,
            ease: 'power2.out',
            stagger: 0.02,
          });
        });
      }
    }

    // Magnetic effect on CTA buttons
    document.querySelectorAll('.magnetic').forEach((el) => {
      el.addEventListener('mousemove', (e) => {
        const rect = (el as HTMLElement).getBoundingClientRect();
        const x = (e as MouseEvent).clientX - rect.left - rect.width / 2;
        const y = (e as MouseEvent).clientY - rect.top - rect.height / 2;
        gsap.to(el, {
          x: x * 0.15,
          y: y * 0.15,
          duration: 0.3,
          ease: 'power2.out',
        });
      });

      el.addEventListener('mouseleave', () => {
        gsap.to(el, {
          x: 0,
          y: 0,
          duration: 0.5,
          ease: 'elastic.out(1, 0.5)',
        });
      });
    });
  }
</script>

<style>
  .post-card {
    text-decoration: none;
    color: inherit;
  }

  .post-card .aspect-\[3\/4\] {
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1),
                box-shadow 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .post-card:hover .aspect-\[3\/4\] {
    transform: translateY(-4px);
    box-shadow: 0 20px 60px rgba(0,0,0,0.06);
  }

  .posts-pin-wrapper .posts-track {
    flex: 1;
    display: flex;
    align-items: center;
  }

  .posts-pin-wrapper {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  #footer-email-link {
    text-decoration: none;
    color: inherit;
  }
</style>
