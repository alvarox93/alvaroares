---
import BaseLayout from '@layouts/BaseLayout.astro';
import Navigation from '@components/Navigation.astro';
import Hero from '@components/Hero.astro';
import WorkSection from '@components/WorkSection.astro';
import { useTranslations, defaultLang, type Language, type UIKey } from '@i18n/ui';
import { homePosts } from '@data/home';
import IconUser from '@components/icons/IconUser.astro';
import IconPhone from '@components/icons/IconPhone.astro';
import IconLocation from '@components/icons/IconLocation.astro';
import IconLinkedIn from '@components/icons/IconLinkedIn.astro';
import IconInstagram from '@components/icons/IconInstagram.astro';

const lang = (Astro.currentLocale ?? defaultLang) as Language;
const t = useTranslations(lang);
const posts = homePosts[lang];
const aboutHref = lang === defaultLang ? '/about' : '/es/about';
---

<BaseLayout
  title={lang === 'es'
    ? 'Álvaro Ares — Director Creativo & Artista CGI'
    : 'Álvaro Ares — Creative Director & CGI Artist'}
  transitionLine1={t('transition.home.line1')}
  transitionLine2={t('transition.home.line2')}
>
  <Navigation />
  <main style="position: relative; z-index: 1; background: var(--color-canvas); padding-bottom: 50vh;">
    <Hero />
    <WorkSection />

    <!-- About — gradient fill -->
    <section class="relative bg-ink overflow-hidden" id="about-preview">
      <div class="max-w-[1200px] mx-auto px-xl lg:px-3xl pt-[48px] pb-section">
        <span class="text-canvas/40 text-[11px] font-medium tracking-[0.14px] uppercase mb-xl block">{t('home.about.label')}</span>
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-3xl items-start">
          <div class="lg:col-span-5">
            <h2 class="text-[clamp(28px,3.5vw,40px)] font-light leading-[1.08] tracking-[-0.04em] text-canvas text-balance" set:html={t('home.about.title')} />
          </div>
          <div class="lg:col-span-6 lg:col-start-7">
            <p class="text-[clamp(20px,2.2vw,24px)] leading-[1.7] mb-lg text-canvas" id="about-fill-paragraph" set:html={
              t('home.about.body').split(' ').map(word =>
                `<span class="about-word">${word}</span>`
              ).join(' ')
            } />
            <div class="flex flex-wrap gap-xs mb-xl">
              <span class="text-canvas/40 text-[10px] tracking-[0.08px] uppercase px-[10px] py-[5px] border border-canvas/15 rounded-sm">Maya</span>
              <span class="text-canvas/40 text-[10px] tracking-[0.08px] uppercase px-[10px] py-[5px] border border-canvas/15 rounded-sm">V-Ray</span>
              <span class="text-canvas/40 text-[10px] tracking-[0.08px] uppercase px-[10px] py-[5px] border border-canvas/15 rounded-sm">After Effects</span>
              <span class="text-canvas/40 text-[10px] tracking-[0.08px] uppercase px-[10px] py-[5px] border border-canvas/15 rounded-sm">Photoshop</span>
              <span class="text-canvas/40 text-[10px] tracking-[0.08px] uppercase px-[10px] py-[5px] border border-canvas/15 rounded-sm">Illustrator</span>
              <span class="text-canvas/40 text-[10px] tracking-[0.08px] uppercase px-[10px] py-[5px] border border-canvas/15 rounded-sm">Unity</span>
              <span class="text-canvas/40 text-[10px] tracking-[0.08px] uppercase px-[10px] py-[5px] border border-canvas/15 rounded-sm">ZBrush</span>
              <span class="text-canvas/40 text-[10px] tracking-[0.08px] uppercase px-[10px] py-[5px] border border-canvas/15 rounded-sm">HTML/CSS</span>
              <span class="text-canvas/40 text-[10px] tracking-[0.08px] uppercase px-[10px] py-[5px] border border-canvas/15 rounded-sm">AI Workflows</span>
            </div>
            <a href={aboutHref} data-transition-line1={t('transition.about.line1')} class="inline-flex items-center gap-2 justify-center px-5 py-2.5 bg-canvas text-ink text-[12px] font-medium tracking-[-0.2px] rounded-lg transition-colors duration-300 hover:bg-canvas/90">
              <IconUser />
              {t('home.about.cta')}
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Posts — horizontal scroll -->
    <section class="relative bg-warm overflow-hidden pb-section" id="posts">
      <div class="max-w-[1200px] mx-auto px-xl lg:px-3xl pt-[60px] pb-0">
        <span class="text-ghost text-[11px] font-medium tracking-[0.14px] uppercase block mb-sm">{t('home.posts.label')}</span>
        <h2 class="text-[clamp(28px,3.5vw,42px)] font-light leading-[1.08] tracking-[-0.04em] text-ink" set:html={t('home.posts.title')}>
        </h2>
      </div>

      <div class="posts-pin-wrapper" id="posts-pin">
        <div class="posts-track flex gap-xl" id="posts-track">

          {posts.map((post, i) => {
            const href = lang === defaultLang
              ? `/posts/${post.slug}`
              : `/es/posts/${post.slug}`;
            const transitionKey = `transition.${post.slug}.line1` as UIKey;
            return (
              <a href={href} class="post-card group shrink-0" style="width: 340px;" data-post-index={i} data-transition-line1={t(transitionKey)}>
                <div class="relative aspect-[3/4] bg-surface rounded-xl overflow-hidden">
                  <div class="absolute inset-0 flex items-center justify-center text-ghost/40 text-[48px] font-display font-bold tracking-[-0.04em] select-none">{post.placeholder}</div>
                  <div class="absolute bottom-0 left-0 right-0 p-xl bg-gradient-to-t from-black/70 via-black/30 to-transparent">
                    <span class="text-canvas/50 text-[10px] tracking-[0.1px] uppercase block mb-xs">{post.date}</span>
                    <h3 class="text-[clamp(20px,2.2vw,26px)] font-medium leading-[1.2] tracking-[-0.02em] text-canvas text-balance">
                      {post.title}
                    </h3>
                  </div>
                </div>
                <div class="flex items-center gap-sm mt-sm">
                  <span class="text-ghost text-[10px] tracking-[0.08px] uppercase px-2 py-1 border border-border rounded-sm">{post.category}</span>
                  <span class="text-ghost text-[10px] tracking-[0.08px]">{post.readTime}</span>
                </div>
              </a>
            );
          })}

        </div>
      </div>
    </section>

    <!-- Footer background -->
    <div class="fixed bottom-0 left-0 right-0 h-screen bg-ink" style="z-index: -2;"></div>

    <!-- Footer -->
    <footer class="fixed bottom-0 left-0 right-0 bg-ink text-canvas" id="footer" style="z-index: -1;">
      <div class="max-w-[1200px] mx-auto px-xl lg:px-3xl py-section">

        <!-- Email -->
        <div class="mb-lg">
          <a href={`mailto:${t('footer.email')}`} class="block group" id="footer-email-link">
            <div class="text-[clamp(28px,4.5vw,56px)] font-medium leading-[1.1] tracking-[-0.03em]" id="footer-email">
              {t('footer.email').split('').map(char => (
                <span class="footer-char">{char === ' ' ? '\u00A0' : char}</span>
              ))}
            </div>
          </a>
        </div>

        <!-- Info line -->
        <div class="flex flex-wrap items-center gap-x-lg gap-y-sm mb-lg">
          <a href="tel:+34649635382" class="inline-flex items-center gap-xs text-canvas/50 text-[13px] hover:text-canvas transition-colors duration-300">
            <IconPhone />
            {t('footer.phone')}
          </a>
          <span class="text-canvas/20 text-[13px]">/</span>
          <span class="inline-flex items-center gap-xs text-canvas/50 text-[13px]">
            <IconLocation />
            {t('footer.location')}
          </span>
          <span class="text-canvas/20 text-[13px]">/</span>
          <span class="text-canvas/50 text-[13px]">{t('footer.workingWorldwide')}</span>
        </div>

        <!-- Bottom row -->
        <div class="flex items-center justify-between">
          <span class="text-canvas/20 text-[11px] tracking-[0.14px]">{t('footer.copyright')}</span>
          <div class="flex items-center gap-lg">
            <a href="https://www.linkedin.com/in/alvaroares" target="_blank" rel="noopener noreferrer" class="text-canvas/30 hover:text-accent transition-colors duration-300" aria-label="LinkedIn">
              <IconLinkedIn />
            </a>
            <a href="https://instagram.com/alvaroar.es" target="_blank" rel="noopener" class="text-canvas/30 hover:text-accent transition-colors duration-300" aria-label="Instagram">
              <IconInstagram />
            </a>
          </div>
        </div>
      </div>
    </footer>
  </main>

  <div class="noise-overlay"></div>
</BaseLayout>

<script>
  import Lenis from 'lenis';
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const lenis = new Lenis({
    duration: 1.2,
    easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
    touchMultiplier: 2,
    smoothWheel: !prefersReducedMotion,
  });

  lenis.on('scroll', ScrollTrigger.update);

  gsap.ticker.add((time) => {
    lenis.raf(time * 1000);
  });

  gsap.ticker.lagSmoothing(0);

  document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
    anchor.addEventListener('click', (e) => {
      const href = anchor.getAttribute('href');
      if (href) {
        e.preventDefault();
        lenis.scrollTo(href);
      }
    });
  });

  const nav = document.getElementById('main-nav');
  let lastNavScroll = 0;
  let navHidden = false;

  if (nav) {
    lenis.on('scroll', ({ scroll }: { scroll: number }) => {
      if (scroll > 50) {
        nav.classList.add('nav-scrolled');
      } else {
        nav.classList.remove('nav-scrolled');
      }

      if (scroll > lastNavScroll && scroll > 200 && !navHidden) {
        gsap.to(nav, { y: -80, duration: 0.4, ease: 'power3.in' });
        navHidden = true;
      } else if (scroll < lastNavScroll && navHidden) {
        gsap.to(nav, { y: 0, duration: 0.35, ease: 'power2.out' });
        navHidden = false;
      }

      lastNavScroll = scroll;
    });
  }

  const postsTrack = document.getElementById('posts-track');
  const postsPin = document.getElementById('posts-pin');

  if (postsTrack && postsPin) {
    const firstCard = postsTrack.querySelector('.post-card');
    const rightPadding = firstCard ? firstCard.getBoundingClientRect().left : 0;
    const totalWidth = postsTrack.scrollWidth - (window.innerWidth - rightPadding);

    gsap.to(postsTrack, {
      x: -totalWidth,
      ease: 'none',
      scrollTrigger: {
        trigger: postsPin,
        start: 'center center',
        end: `+=${totalWidth}`,
        pin: true,
        scrub: true,
        anticipatePin: 1,
      },
    });
  }

  document.querySelectorAll('.project-showcase').forEach((card) => {
    const img = card.querySelector('.project-image-wrap');
    const text = card.querySelector('.project-text-wrap');

    if (img) {
      gsap.fromTo(img,
        { yPercent: 8 },
        {
          yPercent: -8,
          ease: 'none',
          scrollTrigger: {
            trigger: card,
            start: 'top bottom',
            end: 'bottom top',
            scrub: true,
          },
        }
      );
    }

    if (text) {
      gsap.fromTo(text,
        { y: -30 },
        {
          y: 30,
          ease: 'none',
          scrollTrigger: {
            trigger: card,
            start: 'top bottom',
            end: 'bottom top',
            scrub: true,
          },
        }
      );
    }
  });

  const aboutParagraph = document.getElementById('about-fill-paragraph');
  if (aboutParagraph) {
    const words = aboutParagraph.querySelectorAll('.about-word');
    const totalWords = words.length;

    ScrollTrigger.create({
      trigger: aboutParagraph,
      start: 'top 80%',
      end: 'top 20%',
      scrub: 1,
      onUpdate: (self) => {
        const progress = self.progress;
        words.forEach((word, i) => {
          const wordProgress = i / totalWords;
          const opacity = Math.min(1, Math.max(0.12, (progress - wordProgress) * totalWords * 1.2 + 0.12));
          (word as HTMLElement).style.opacity = String(opacity);
        });
      },
    });
  }

  const emailLink = document.getElementById('footer-email-link');
  if (emailLink) {
    const chars = emailLink.querySelectorAll('.footer-char');

    emailLink.addEventListener('mouseenter', () => {
      const accent = getComputedStyle(document.documentElement).getPropertyValue('--accent').trim();
      gsap.killTweensOf(chars);
      gsap.to(chars, {
        color: accent,
        y: -4,
        duration: 0.3,
        ease: 'power2.out',
        stagger: 0.04,
      });
    });

    emailLink.addEventListener('mouseleave', () => {
      gsap.killTweensOf(chars);
      gsap.to(chars, {
        color: '#ffffff',
        y: 0,
        duration: 0.25,
        ease: 'power2.out',
        stagger: 0.03,
      });
    });
  }

  document.querySelectorAll('.magnetic').forEach((el) => {
    el.addEventListener('mousemove', (e) => {
      const rect = (el as HTMLElement).getBoundingClientRect();
      const x = (e as MouseEvent).clientX - rect.left - rect.width / 2;
      const y = (e as MouseEvent).clientY - rect.top - rect.height / 2;
      gsap.to(el, {
        x: x * 0.15,
        y: y * 0.15,
        duration: 0.3,
        ease: 'power2.out',
      });
    });

    el.addEventListener('mouseleave', () => {
      gsap.to(el, {
        x: 0,
        y: 0,
        duration: 0.5,
        ease: 'elastic.out(1, 0.5)',
      });
    });
  });

  document.querySelectorAll('.project-cta').forEach((cta) => {
    const arrow = cta.querySelector('.cta-arrow');
    if (!arrow) return;

    cta.addEventListener('mouseenter', () => {
      gsap.to(arrow, {
        x: 4,
        opacity: 1,
        duration: 0.3,
        ease: 'power2.out',
      });
    });

    cta.addEventListener('mouseleave', () => {
      gsap.to(arrow, {
        x: 0,
        opacity: 0.7,
        duration: 0.3,
        ease: 'power2.out',
      });
    });
  });

  const eyesWrap = document.querySelector<HTMLElement>('.eyes-parallax-wrap');
  if (eyesWrap) {
    const eyeImgs = eyesWrap.querySelectorAll<HTMLElement>('.eyes-parallax-img');
    eyeImgs.forEach((el) => {
      const speed = 2 + Math.random() * 2;
      const dir = Math.random() > 0.5 ? 1 : -1;
      const startY = (Math.random() - 0.5) * 16;
      const range = speed * 8 * dir;
      gsap.fromTo(el,
        { yPercent: startY - range },
        {
          yPercent: startY + range,
          ease: 'none',
          scrollTrigger: {
            trigger: eyesWrap.parentElement,
            start: 'top bottom',
            end: 'bottom top',
            scrub: true,
          },
        }
      );
    });
  }
</script>

<style>
  .post-card:first-child {
    margin-left: max(var(--spacing-xl), calc((100vw - 1200px) / 2 + var(--spacing-xl)));
  }

  @media (min-width: 1024px) {
    .post-card:first-child {
      margin-left: max(var(--spacing-3xl), calc((100vw - 1200px) / 2 + var(--spacing-3xl)));
    }
  }

  .post-card {
    text-decoration: none;
    color: inherit;
  }

  .post-card .aspect-\[3\/4\] {
    transition: box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1), transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .post-card:hover .aspect-\[3\/4\] {
    box-shadow: 0 20px 50px rgba(0,0,0,0.1);
    transform: translateY(-4px);
  }

  .post-card h3 {
    transition: color 0.3s ease;
  }

  .post-card:hover h3 {
    color: var(--accent);
  }

  .posts-pin-wrapper .posts-track {
    flex: 1;
    display: flex;
    align-items: center;
  }

  .posts-pin-wrapper {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    background: var(--color-warm);
  }

  #footer-email-link {
    text-decoration: none;
    color: inherit;
  }

  #footer-email {
    display: flex;
    flex-wrap: wrap;
  }

  .footer-char-wrap {
    display: inline-block;
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!prefersReducedMotion) {
    const aboutHeading = document.querySelector('#about-preview h2');
    if (aboutHeading) {
      gsap.from(aboutHeading, {
        y: 16, autoAlpha: 0, duration: 0.7, ease: 'power2.out',
        scrollTrigger: { trigger: aboutHeading, start: 'top 85%', once: true },
      });
    }

    const skillTags = document.querySelectorAll('#about-preview .flex.flex-wrap > span');
    if (skillTags.length) {
      gsap.from(skillTags, {
        y: 8, autoAlpha: 0, duration: 0.4, ease: 'power2.out', stagger: 0.05,
        scrollTrigger: { trigger: skillTags[0], start: 'top 88%', once: true },
      });
    }

    const postsHeading = document.querySelector('#posts h2');
    if (postsHeading) {
      gsap.from(postsHeading, {
        y: 16, autoAlpha: 0, duration: 0.7, ease: 'power2.out',
        scrollTrigger: { trigger: postsHeading, start: 'top 85%', once: true },
      });
    }

    const postCards = document.querySelectorAll('.post-card');
    if (postCards.length) {
      gsap.from(postCards, {
        y: 40,
        autoAlpha: 0,
        duration: 0.6,
        ease: 'power3.out',
        stagger: 0.1,
        scrollTrigger: { trigger: '#posts-pin', start: 'top 80%', once: true },
      });
    }

    const workHeading = document.querySelector('#work h2');
    if (workHeading) {
      gsap.from(workHeading, {
        y: 16, autoAlpha: 0, duration: 0.7, ease: 'power2.out',
        scrollTrigger: { trigger: workHeading, start: 'top 85%', once: true },
      });
    }
  }
</script>
