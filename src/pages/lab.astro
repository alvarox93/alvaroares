---
import BaseLayout from '@layouts/BaseLayout.astro';
import Navigation from '@components/Navigation.astro';
import { useTranslations, defaultLang, type Language } from '@i18n/ui';

const lang = (Astro.currentLocale ?? defaultLang) as Language;
const t = useTranslations(lang);
const backHref = lang === defaultLang ? '/' : '/es';
---

<BaseLayout
  title={lang === 'es' ? 'Lab — Álvaro Ares' : 'Lab — Álvaro Ares'}
  transitionLine1={t('transition.lab.line1')}
  transitionLine2={t('transition.lab.line2')}
>
  <Navigation />

  <main class="bg-warm min-h-screen">
    <div class="max-w-[1200px] mx-auto px-xl lg:px-3xl pt-2xl lg:pt-3xl pb-section">

      <a href={backHref} class="inline-block text-ghost text-[11px] font-medium tracking-[0.14px] uppercase hover:text-ink transition-colors duration-200 mb-2xl">
        {t('nav.backToHome')}
      </a>

      <!-- HERO -->
      <section class="relative pb-2xl">
        <div class="hero-blob" style="top: -60px; right: -80px;"></div>

        <span class="relative text-ghost text-[11px] font-medium tracking-[0.14px] uppercase mb-sm block lab-anim">{t('lab.eyebrow')}</span>
        <h1 class="relative text-[clamp(42px,6vw,76px)] font-light leading-[0.98] tracking-[-0.05em] text-ink text-balance mb-lg max-w-[800px] lab-anim">
          {t('lab.heading.line1')}<br /><span class="font-extralight opacity-60">{t('lab.heading.line2')}</span>
        </h1>
        <p class="relative text-[clamp(17px,2vw,22px)] leading-[1.65] text-muted max-w-[640px] mb-xl lab-anim">
          <strong class="text-ink font-medium">{t('lab.description')}</strong> {t('lab.descriptionBold')}
        </p>

        <div class="relative flex flex-wrap gap-sm mb-3xl lab-anim">
          <span class="lab-tag">{t('lab.tag1')}</span>
          <span class="lab-tag">{t('lab.tag2')}</span>
          <span class="lab-tag">{t('lab.tag3')}</span>
          <span class="lab-tag">{t('lab.tag4')}</span>
          <span class="lab-tag">{t('lab.tag5')}</span>
          <span class="lab-tag">{t('lab.tag6')}</span>
        </div>

        <!-- Video placeholder -->
        <div class="relative aspect-[16/9] bg-canvas rounded-2xl border border-border-light overflow-hidden shadow-sm lab-anim">
          <video autoplay muted loop playsinline class="absolute inset-0 w-full h-full object-cover opacity-0">
            <source src="/lab/interactive-reel.mp4" type="video/mp4" />
          </video>
          <div class="absolute inset-0 flex items-center justify-center">
            <span class="text-ghost text-[13px]">[Interactive Reel]</span>
          </div>
        </div>
      </section>

      <!-- SELECTED WORK -->
      <section class="mb-section-mobile lg:mb-section">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-xl items-start">
          <div class="lg:col-span-7">
            <div class="lab-pulse-card">
              <span class="text-ghost text-[13px]">[VR Environment — WIP]</span>
            </div>
          </div>
          <div class="lg:col-span-4 lg:col-start-9 lg:pt-3xl">
            <span class="lab-counter">{t('lab.selected.counter')}</span>
            <h2 class="text-[clamp(22px,2.5vw,30px)] font-light leading-[1.18] tracking-[-0.03em] text-ink text-balance mb-sm">
              {t('lab.selected.title')}
            </h2>
            <p class="text-muted text-[15px] leading-[1.75] mb-sm">
              {t('lab.selected.description')}
            </p>
            <p class="lab-disciplines mb-lg">{t('lab.selected.disciplines')}</p>
            <a href={lang === defaultLang ? '/#contact' : '/es/#contact'} class="lab-cta-link">
              <span class="lab-cta-text">{t('lab.selected.cta')}</span>
            </a>
          </div>
        </div>
      </section>

      <!-- DASHBOARD -->
      <section class="mb-section-mobile lg:mb-section">
        <div class="border-t border-border-light pt-2xl">
          <p class="text-center text-ghost text-[11px] font-medium tracking-[0.14px] uppercase mb-xl">
            {t('lab.dashboard.label')}
          </p>

          <div class="dash">
            <!-- Top bar -->
            <div class="dash-topbar">
              <span class="dash-project">{t('dashboard.project')}</span>
              <span class="dash-status"><span class="dash-status-dot"></span>{t('dashboard.status')}</span>
              <span class="dash-clock" id="dash-clock">00:00:00</span>
            </div>

            <!-- Render progress -->
            <div class="dash-card">
              <div class="dash-card-header">
                <span class="dash-card-title">{t('dashboard.renderLabel')}</span>
                <span class="dash-pct" id="dash-pct">0%</span>
              </div>
              <div class="dash-progress-track">
                <div class="dash-progress-fill" id="dash-progress"></div>
              </div>
              <span class="dash-card-sub">{t('dashboard.renderDetail')}</span>
            </div>

            <!-- Stats -->
            <div class="dash-stats">
              <div class="dash-stat">
                <span class="dash-stat-num" data-count-to="12">0</span>
                <span class="dash-stat-label">{t('dashboard.stats.countries')}</span>
              </div>
              <div class="dash-stat">
                <span class="dash-stat-num" data-count-to="150">0</span>
                <span class="dash-stat-label">{t('dashboard.stats.projects')}</span>
              </div>
              <div class="dash-stat">
                <span class="dash-stat-num" data-count-to="8">0</span>
                <span class="dash-stat-label">{t('dashboard.stats.team')}</span>
              </div>
            </div>

            <!-- Pipeline -->
            <div class="dash-card">
              <span class="dash-card-title">{t('dashboard.pipeline')}</span>
              <div class="dash-pipeline">
                <div class="dash-pipe-row">
                  <span class="dash-pipe-name"><span class="dash-dot dash-dot--green"></span>{t('dashboard.pipe.modeling')}</span>
                  <div class="dash-pipe-track"><div class="dash-pipe-fill" data-fill="100"></div></div>
                </div>
                <div class="dash-pipe-row">
                  <span class="dash-pipe-name"><span class="dash-dot dash-dot--green"></span>{t('dashboard.pipe.texturing')}</span>
                  <div class="dash-pipe-track"><div class="dash-pipe-fill" data-fill="100"></div></div>
                </div>
                <div class="dash-pipe-row">
                  <span class="dash-pipe-name"><span class="dash-dot dash-dot--amber"></span>{t('dashboard.pipe.lighting')}</span>
                  <div class="dash-pipe-track"><div class="dash-pipe-fill" data-fill="65"></div></div>
                </div>
                <div class="dash-pipe-row">
                  <span class="dash-pipe-name"><span class="dash-dot dash-dot--amber"></span>{t('dashboard.pipe.rendering')}</span>
                  <div class="dash-pipe-track"><div class="dash-pipe-fill" data-fill="35"></div></div>
                </div>
                <div class="dash-pipe-row">
                  <span class="dash-pipe-name"><span class="dash-dot dash-dot--grey"></span>{t('dashboard.pipe.compositing')}</span>
                  <div class="dash-pipe-track"><div class="dash-pipe-fill" data-fill="0"></div></div>
                </div>
              </div>
            </div>

            <!-- Bottom row -->
            <div class="dash-bottom">
              <div class="dash-card">
                <span class="dash-card-title">{t('dashboard.tools')}</span>
                <div class="dash-tools">
                  <span class="dash-tool-pill">Maya</span>
                  <span class="dash-tool-pill">V-Ray</span>
                  <span class="dash-tool-pill">After Effects</span>
                  <span class="dash-tool-pill">ComfyUI</span>
                </div>
              </div>
              <div class="dash-card">
                <span class="dash-card-title">{t('dashboard.delivery')}</span>
                <span class="dash-countdown" id="dash-countdown">00:00:00</span>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- CTA -->
      <section class="border-t border-border-light pt-xl text-center">
        <a href={lang === defaultLang ? '/#contact' : '/es/#contact'} class="magnetic inline-flex items-center justify-center px-6 py-3 bg-ink text-canvas text-[13px] font-medium tracking-[-0.2px] rounded-lg transition-colors duration-300 hover:bg-ink/85">
          {t('lab.cta')}
        </a>
      </section>

    </div>
  </main>

  <div class="noise-overlay"></div>
</BaseLayout>

<style>
  /* ── Tags ── */
  .lab-tag {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.08px;
    text-transform: uppercase;
    color: var(--color-ghost);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    padding: 4px 10px;
    transition: border-color 0.2s, color 0.2s;
  }
  .lab-tag:hover {
    border-color: var(--color-ink);
    color: var(--color-ink);
  }

  /* ── Pulse card ── */
  .lab-pulse-card {
    position: relative;
    aspect-ratio: 16 / 10;
    background: var(--color-canvas);
    border-radius: 12px;
    border: 1px solid var(--color-border-light);
    display: flex;
    align-items: center;
    justify-content: center;
    animation: lab-pulse 3s ease-in-out infinite;
  }
  @keyframes lab-pulse {
    0%, 100% { border-color: var(--color-border-light); box-shadow: 0 0 0 rgba(0,0,0,0); }
    50% { border-color: var(--color-border); box-shadow: 0 0 20px rgba(0,0,0,0.03); }
  }

  .lab-counter {
    display: block;
    font-family: 'JetBrains Mono', 'SF Mono', 'Fira Code', monospace;
    font-size: 12px;
    color: var(--color-ghost);
    margin-bottom: 12px;
  }

  .lab-disciplines {
    font-family: 'JetBrains Mono', 'SF Mono', 'Fira Code', monospace;
    font-size: 11px;
    color: var(--color-ghost);
  }

  .lab-cta-link { display: inline-block; }
  .lab-cta-text {
    position: relative;
    font-size: 13px;
    font-weight: 500;
    color: var(--color-ink);
    cursor: pointer;
    padding-bottom: 2px;
  }
  .lab-cta-text::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--accent);
    transition: width 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .lab-cta-link:hover .lab-cta-text::after { width: 100%; }

  /* ── Dashboard ── */
  .dash {
    background: var(--color-canvas);
    border-radius: 12px;
    padding: 20px;
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
    position: relative;
    border: 1px solid var(--color-border-light);
  }

  @media (min-width: 768px) {
    .dash {
      grid-template-columns: 1fr 1fr;
      padding: 24px;
      gap: 16px;
    }
  }

  .dash-topbar {
    grid-column: 1 / -1;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--color-border-light);
  }

  .dash-project {
    font-family: 'JetBrains Mono', 'SF Mono', 'Fira Code', monospace;
    font-size: 12px;
    color: var(--color-muted);
  }

  .dash-status {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: 'JetBrains Mono', 'SF Mono', 'Fira Code', monospace;
    font-size: 11px;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .dash-status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    animation: dash-blink 2s ease-in-out infinite;
  }
  @keyframes dash-blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  .dash-clock {
    font-family: 'JetBrains Mono', 'SF Mono', 'Fira Code', monospace;
    font-size: 12px;
    color: var(--color-ghost);
    font-variant-numeric: tabular-nums;
  }

  .dash-card {
    background: var(--color-warm);
    border: 1px solid var(--color-border-light);
    border-radius: 8px;
    padding: 20px;
    transition: box-shadow 0.3s ease, border-color 0.3s ease;
  }
  .dash-card:hover {
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.04);
    border-color: var(--color-border);
  }

  .dash-card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
  }

  .dash-card-title {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.08px;
    text-transform: uppercase;
    color: var(--color-ghost);
    margin-bottom: 16px;
    display: block;
  }
  .dash-card-header .dash-card-title { margin-bottom: 0; }

  .dash-pct {
    font-family: 'JetBrains Mono', 'SF Mono', 'Fira Code', monospace;
    font-size: 14px;
    color: var(--accent);
    font-variant-numeric: tabular-nums;
  }

  .dash-progress-track {
    height: 4px;
    background: var(--color-border-light);
    border-radius: 2px;
    overflow: hidden;
    margin-bottom: 10px;
  }

  .dash-progress-fill {
    height: 100%;
    width: 0%;
    background: var(--accent);
    border-radius: 2px;
  }

  .dash-card-sub {
    font-family: 'JetBrains Mono', 'SF Mono', 'Fira Code', monospace;
    font-size: 11px;
    color: var(--color-ghost);
  }

  .dash-stats {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }
  @media (min-width: 768px) {
    .dash-stats { gap: 16px; }
  }

  .dash-stat {
    background: var(--color-warm);
    border: 1px solid var(--color-border-light);
    border-radius: 8px;
    padding: 20px;
    text-align: center;
    transition: box-shadow 0.3s ease, border-color 0.3s ease;
  }
  .dash-stat:hover {
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.04);
    border-color: var(--color-border);
  }

  .dash-stat-num {
    display: block;
    font-family: 'JetBrains Mono', 'SF Mono', 'Fira Code', monospace;
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 700;
    color: var(--color-ink);
    line-height: 1;
    margin-bottom: 8px;
    font-variant-numeric: tabular-nums;
  }

  .dash-stat-label {
    font-size: 11px;
    color: var(--color-ghost);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .dash-pipeline { display: flex; flex-direction: column; gap: 10px; }

  .dash-pipe-row {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .dash-pipe-name {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    color: var(--color-muted);
    min-width: 110px;
    flex-shrink: 0;
  }

  .dash-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .dash-dot--green { background: #22c55e; }
  .dash-dot--amber { background: #f59e0b; }
  .dash-dot--grey { background: var(--color-border); }

  .dash-pipe-track {
    flex: 1;
    height: 3px;
    background: var(--color-border-light);
    border-radius: 2px;
    overflow: hidden;
  }

  .dash-pipe-fill {
    height: 100%;
    width: 0%;
    background: var(--accent);
    border-radius: 2px;
    transition: width 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .dash-bottom {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
  }
  @media (min-width: 768px) {
    .dash-bottom { grid-template-columns: 1fr 1fr; gap: 16px; }
  }

  .dash-tools {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .dash-tool-pill {
    font-family: 'JetBrains Mono', 'SF Mono', 'Fira Code', monospace;
    font-size: 11px;
    color: var(--color-muted);
    border: 1px solid var(--color-border-light);
    border-radius: 4px;
    padding: 4px 10px;
    opacity: 0;
    transition: border-color 0.2s, color 0.2s;
  }
  .dash-tool-pill:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .dash-countdown {
    font-family: 'JetBrains Mono', 'SF Mono', 'Fira Code', monospace;
    font-size: clamp(24px, 3vw, 32px);
    font-weight: 700;
    color: var(--color-ink);
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.02em;
  }

  @media (prefers-reduced-motion: reduce) {
    .lab-pulse-card { animation: none; }
    .dash-status-dot { animation: none; }
    .dash-pipe-fill { transition: none; }
  }
</style>

<script>
  import Lenis from 'lenis';
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const lenis = new Lenis({
    duration: 1.2,
    easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
    touchMultiplier: 2,
  });

  lenis.on('scroll', ScrollTrigger.update);
  gsap.ticker.add((time) => { lenis.raf(time * 1000); });
  gsap.ticker.lagSmoothing(0);

  const nav = document.getElementById('main-nav');
  let lastNavScroll = 0;
  let navHidden = false;

  if (nav) {
    lenis.on('scroll', ({ scroll }: { scroll: number }) => {
      if (scroll > 50) nav.classList.add('nav-scrolled');
      else nav.classList.remove('nav-scrolled');

      if (scroll > lastNavScroll && scroll > 200 && !navHidden) {
        gsap.to(nav, { y: -80, duration: 0.4, ease: 'power3.in' });
        navHidden = true;
      } else if (scroll < lastNavScroll && navHidden) {
        gsap.to(nav, { y: 0, duration: 0.35, ease: 'power2.out' });
        navHidden = false;
      }
      lastNavScroll = scroll;
    });
  }

  /* ── Live clock ── */
  function updateClock() {
    const el = document.getElementById('dash-clock');
    if (!el) return;
    const now = new Date();
    el.textContent = now.toLocaleTimeString('en-GB');
  }
  updateClock();
  setInterval(updateClock, 1000);

  /* ── Countdown ── */
  const TARGET = new Date(Date.now() + 7 * 24 * 60 * 60 * 1000).getTime();
  function updateCountdown() {
    const el = document.getElementById('dash-countdown');
    if (!el) return;
    const diff = Math.max(0, TARGET - Date.now());
    const h = Math.floor(diff / 3600000);
    const m = Math.floor((diff % 3600000) / 60000);
    const s = Math.floor((diff % 60000) / 1000);
    el.textContent = [h, m, s].map(v => String(v).padStart(2, '0')).join(':');
  }
  updateCountdown();
  setInterval(updateCountdown, 1000);

  if (!prefersReducedMotion) {
    /* ── Hero entrance ── */
    const heroEls = document.querySelectorAll<HTMLElement>('.lab-anim');
    if (heroEls.length) {
      gsap.from(heroEls, {
        y: 24,
        autoAlpha: 0,
        duration: 0.8,
        ease: 'power2.out',
        stagger: 0.12,
      });
    }

    /* ── Selected work scroll animations ── */
    const selectedMedia = document.querySelector<HTMLElement>('.lab-pulse-card');
    if (selectedMedia) {
      gsap.from(selectedMedia, {
        x: -60,
        autoAlpha: 0,
        duration: 0.8,
        ease: 'power3.out',
        scrollTrigger: { trigger: selectedMedia, start: 'top 80%', once: true },
      });
    }

    const selectedContent = document.querySelector<HTMLElement>('.lab-counter');
    if (selectedContent) {
      gsap.from(selectedContent, {
        x: 40,
        autoAlpha: 0,
        duration: 0.7,
        ease: 'power3.out',
        scrollTrigger: { trigger: selectedContent, start: 'top 80%', once: true },
      });
    }

    /* ── Dashboard scroll animations ── */
    const dash = document.querySelector<HTMLElement>('.dash');
    if (dash) {
      const children = dash.children;
      gsap.from(Array.from(children), {
        y: 20,
        autoAlpha: 0,
        duration: 0.5,
        ease: 'power2.out',
        stagger: 0.08,
        scrollTrigger: { trigger: dash, start: 'top 80%', once: true },
      });

      /* Counter animation */
      document.querySelectorAll<HTMLElement>('[data-count-to]').forEach((el) => {
        const target = parseInt(el.dataset.countTo || '0', 10);
        const obj = { val: 0 };
        gsap.to(obj, {
          val: target,
          duration: 2,
          ease: 'power2.out',
          scrollTrigger: { trigger: el, start: 'top 85%', once: true },
          onUpdate: () => {
            el.textContent = String(Math.round(obj.val));
          },
        });
      });

      /* Pipeline fills */
      document.querySelectorAll<HTMLElement>('.dash-pipe-fill').forEach((bar, i) => {
        const fill = bar.dataset.fill || '0';
        gsap.to(bar, {
          width: fill + '%',
          duration: 0.8,
          delay: i * 0.15,
          ease: 'power3.out',
          scrollTrigger: { trigger: dash, start: 'top 75%', once: true },
        });
      });

      /* Tool pills fade in */
      const pills = document.querySelectorAll<HTMLElement>('.dash-tool-pill');
      if (pills.length) {
        gsap.to(pills, {
          autoAlpha: 1,
          duration: 0.4,
          stagger: 0.1,
          ease: 'power2.out',
          scrollTrigger: { trigger: pills[0], start: 'top 90%', once: true },
        });
      }
    }

    /* ── Render progress loop ── */
    const progressFill = document.getElementById('dash-progress') as HTMLElement | null;
    const pctEl = document.getElementById('dash-pct') as HTMLElement | null;
    if (progressFill && pctEl) {
      const progObj = { pct: 0 };
      function runProgress() {
        progObj.pct = 0;
        gsap.to(progObj, {
          pct: 100,
          duration: 8,
          ease: 'none',
          onUpdate: () => {
            if (progressFill) progressFill.style.width = progObj.pct + '%';
            if (pctEl) pctEl.textContent = Math.round(progObj.pct) + '%';
          },
          onComplete: runProgress,
        });
      }
      ScrollTrigger.create({
        trigger: progressFill,
        start: 'top 90%',
        once: true,
        onEnter: runProgress,
      });
    }

    /* ── CTA section ── */
    const ctaSection = document.querySelector<HTMLElement>('.border-t.text-center');
    if (ctaSection) {
      gsap.from(ctaSection, {
        y: 16,
        autoAlpha: 0,
        duration: 0.6,
        ease: 'power2.out',
        scrollTrigger: { trigger: ctaSection, start: 'top 90%', once: true },
      });
    }

    /* ── Magnetic CTA ── */
    document.querySelectorAll<HTMLElement>('.magnetic').forEach((el) => {
      el.addEventListener('mousemove', (e) => {
        const rect = el.getBoundingClientRect();
        const x = e.clientX - rect.left - rect.width / 2;
        const y = e.clientY - rect.top - rect.height / 2;
        gsap.to(el, { x: x * 0.15, y: y * 0.15, duration: 0.3, ease: 'power2.out' });
      });
      el.addEventListener('mouseleave', () => {
        gsap.to(el, { x: 0, y: 0, duration: 0.5, ease: 'elastic.out(1, 0.5)' });
      });
    });
  }
</script>
