---
import BaseLayout from '@layouts/BaseLayout.astro';
import Navigation from '@components/Navigation.astro';
import { useTranslations, defaultLang, type Language } from '@i18n/ui';
import IconArrowUpRight from '@components/icons/IconArrowUpRight.astro';

const lang = (Astro.currentLocale ?? defaultLang) as Language;
const t = useTranslations(lang);
---

<BaseLayout
  title={lang === 'es' ? 'Koora.studio — Álvaro Ares' : 'Koora.studio — Álvaro Ares'}
  transitionLine1={t('transition.studio.line1')}
  transitionLine2={t('transition.studio.line2')}
>
  <Navigation />

  <main class="bg-warm min-h-screen">
    <div class="max-w-[1200px] mx-auto px-xl lg:px-3xl">

      <!-- Hero -->
      <section class="relative h-screen flex items-center">
        <div class="hero-blob" style="top: -60px; right: -80px;"></div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-2xl lg:gap-3xl items-center w-full">
          <div class="lg:col-span-5">
            <span class="relative text-ghost text-[11px] font-medium tracking-[0.14px] uppercase mb-sm block">{t('koora.meta')}</span>
            <h1 class="relative text-[clamp(32px,4.5vw,52px)] font-light leading-[1.02] tracking-[-0.045em] text-ink text-balance mb-lg">
              {t('koora.heading')}
            </h1>
            <p class="relative text-[clamp(15px,1.5vw,18px)] leading-[1.65] text-muted">
              <strong class="text-ink font-medium">{t('koora.lede')}</strong>{t('koora.ledeBold')}
            </p>
          </div>
          <div class="lg:col-span-6 lg:col-start-7">
            <!-- Showreel -->
            <div class="relative aspect-[16/9] bg-canvas rounded-2xl border border-border-light overflow-hidden shadow-sm">
              <video
                class="absolute inset-0 w-full h-full object-cover"
                controls
                playsinline
              >
                <source src="/kooraShowreel.webm" type="video/webm" />
              </video>
            </div>
            <!-- Stats — dark background -->
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-sm mt-lg">
              <div class="bg-ink rounded-xl px-md py-lg">
                <span class="font-accent text-[clamp(22px,2.5vw,30px)] font-bold leading-none tracking-[-0.04em] text-canvas block mb-xs">{t('koora.stats.years.value')}</span>
                <span class="text-canvas/50 text-[10px] lg:text-[11px] font-medium leading-tight block">{t('koora.stats.years')}</span>
              </div>
              <div class="bg-ink rounded-xl px-md py-lg">
                <span class="font-accent text-[clamp(22px,2.5vw,30px)] font-bold leading-none tracking-[-0.04em] text-canvas block mb-xs">{t('koora.stats.projects.value')}</span>
                <span class="text-canvas/50 text-[10px] lg:text-[11px] font-medium leading-tight block">{t('koora.stats.projects')}</span>
              </div>
              <div class="bg-ink rounded-xl px-md py-lg">
                <span class="font-accent text-[clamp(22px,2.5vw,30px)] font-bold leading-none tracking-[-0.04em] text-canvas block mb-xs">{t('koora.stats.languages.value')}</span>
                <span class="text-canvas/50 text-[10px] lg:text-[11px] font-medium leading-tight block">{t('koora.stats.languages')}</span>
              </div>
              <div class="bg-ink rounded-xl px-md py-lg">
                <span class="font-accent text-[clamp(22px,2.5vw,30px)] font-bold leading-none tracking-[-0.04em] text-canvas block mb-xs">{t('koora.stats.countries.value')}</span>
                <span class="text-canvas/50 text-[10px] lg:text-[11px] font-medium leading-tight block">{t('koora.stats.countries')}</span>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Narrative -->
      <section class="mt-xl lg:mt-2xl mb-section-mobile lg:mb-section">
        <div class="mb-3xl">
          <span class="text-ghost text-[11px] font-medium tracking-[0.14px] uppercase mb-sm block">{t('koora.narrative.label')}</span>
          <h2 class="text-[clamp(28px,3.5vw,44px)] font-light leading-[1.06] tracking-[-0.04em] text-ink text-balance max-w-[600px]">
            {t('koora.narrative.heading')}
          </h2>
        </div>

        <!-- Block 01 — International reach — video left -->
        <div class="narrative-block relative grid grid-cols-1 lg:grid-cols-12 gap-xl items-start mb-section-mobile lg:mb-4xl">
          <span class="big-num absolute top-0 right-0 text-ink/[0.04] text-[100px] font-accent font-bold leading-none tracking-[-0.06em] select-none pointer-events-none z-[1]">01</span>
          <div class="video-col lg:col-span-7 lg:sticky lg:top-[72px]">
            <div class="relative aspect-[16/9] bg-canvas rounded-xl border border-border-light overflow-hidden">
              <div class="absolute inset-0 flex items-center justify-center text-ghost text-[13px]">
                [International campaign video]
              </div>
            </div>
          </div>
          <div class="text-col relative z-[2] lg:col-span-4 lg:col-start-9">
            <span class="text-ghost text-[10px] font-medium tracking-[0.08px] uppercase px-2.5 py-1 border border-border rounded-sm mb-md inline-block">{t('koora.narrative1.tag')}</span>
            <h3 class="text-[clamp(22px,2.5vw,30px)] font-light leading-[1.18] tracking-[-0.03em] text-ink text-balance mb-sm">
              {t('koora.narrative1.title')}
            </h3>
            <p class="text-muted text-[15px] leading-[1.75]">
              {t('koora.narrative1.body')}
            </p>
          </div>
        </div>

        <!-- Block 02 — The team — video right -->
        <div class="narrative-block relative grid grid-cols-1 lg:grid-cols-12 gap-xl items-start mb-section-mobile lg:mb-4xl">
          <span class="big-num absolute top-0 left-0 text-ink/[0.04] text-[100px] font-accent font-bold leading-none tracking-[-0.06em] select-none pointer-events-none z-[1]">02</span>
          <div class="text-col relative z-[2] lg:col-span-4 lg:order-1">
            <span class="text-ghost text-[10px] font-medium tracking-[0.08px] uppercase px-2.5 py-1 border border-border rounded-sm mb-md inline-block">{t('koora.narrative2.tag')}</span>
            <h3 class="text-[clamp(22px,2.5vw,30px)] font-light leading-[1.18] tracking-[-0.03em] text-ink text-balance mb-sm">
              {t('koora.narrative2.title')}
            </h3>
            <p class="text-muted text-[15px] leading-[1.75]">
              {t('koora.narrative2.body')}
            </p>
          </div>
          <div class="video-col lg:col-span-7 lg:col-start-6 lg:order-2 lg:sticky lg:top-[72px]">
            <div class="relative aspect-[16/9] bg-canvas rounded-xl border border-border-light overflow-hidden">
              <video
                class="absolute inset-0 w-full h-full object-cover"
                autoplay
                loop
                muted
                playsinline
              >
                <source src="/kooraExtract_1.webm" type="video/webm" />
              </video>
            </div>
          </div>
        </div>
      </section>

      <!-- Clients marquee — dark, extra air -->
      <div class="relative bg-ink w-screen overflow-hidden py-[100px]" style="margin-left: calc(-50vw + 50%);">
        <p class="text-center text-canvas/50 text-[11px] font-medium tracking-[0.14px] uppercase mb-xl">
          {t('koora.clients.label')}
        </p>
        <div class="overflow-hidden mb-lg">
          <div class="marquee-track marquee-left">
            <div class="flex items-center gap-xl shrink-0 px-2xl">
              <span class="client-name">SIEMENS</span>
              <span class="client-name">SMC</span>
              <span class="client-name">CEGASA</span>
              <span class="client-name">EITB</span>
              <span class="client-name">VIRTUALWARE</span>
              <span class="client-name">KANTAR</span>
              <span class="client-name">TECNALIA</span>
              <span class="client-name">TKNIKA</span>
              <span class="client-name">CFEED</span>
              <span class="client-name">MRA</span>
              <span class="client-name">GESTAMP</span>
              <span class="client-name">CAROLINA HERRERA</span>
              <span class="client-name">JEAN PAUL GAULTIER</span>
              <span class="client-name">UNIVERSIDAD DE DEUSTO</span>
              <span class="client-name">MINISTERIO DE EDUCACIÓN</span>
              <span class="client-name">CENTRO CRIPTOLÓGICO NACIONAL</span>
            </div>
            <div class="flex items-center gap-xl shrink-0 px-2xl">
              <span class="client-name">SIEMENS</span>
              <span class="client-name">SMC</span>
              <span class="client-name">CEGASA</span>
              <span class="client-name">EITB</span>
              <span class="client-name">VIRTUALWARE</span>
              <span class="client-name">KANTAR</span>
              <span class="client-name">TECNALIA</span>
              <span class="client-name">TKNIKA</span>
              <span class="client-name">CFEED</span>
              <span class="client-name">MRA</span>
              <span class="client-name">GESTAMP</span>
              <span class="client-name">CAROLINA HERRERA</span>
              <span class="client-name">JEAN PAUL GAULTIER</span>
              <span class="client-name">UNIVERSIDAD DE DEUSTO</span>
              <span class="client-name">MINISTERIO DE EDUCACIÓN</span>
              <span class="client-name">CENTRO CRIPTOLÓGICO NACIONAL</span>
            </div>
          </div>
        </div>
        <div class="overflow-hidden">
          <div class="marquee-track marquee-right">
            <div class="flex items-center gap-xl shrink-0 px-2xl">
              <span class="client-name">BITLIFEMEDIA</span>
              <span class="client-name">BIZKAIRED</span>
              <span class="client-name">PROFESIOLAN</span>
              <span class="client-name">CONFOLAR</span>
              <span class="client-name">HELIAN</span>
              <span class="client-name">PLEKARI</span>
              <span class="client-name">SAICA</span>
              <span class="client-name">DIBAL</span>
              <span class="client-name">DTCreativos</span>
              <span class="client-name">H2SITE</span>
              <span class="client-name">FRACHT</span>
              <span class="client-name">EGIBIDE</span>
              <span class="client-name">MEDIAPRO</span>
              <span class="client-name">CIRCMAR</span>
              <span class="client-name">BIZKAIKO FORU ALDUNDIA</span>
              <span class="client-name">BITLIFEMEDIA</span>
            </div>
            <div class="flex items-center gap-xl shrink-0 px-2xl">
              <span class="client-name">BITLIFEMEDIA</span>
              <span class="client-name">BIZKAIRED</span>
              <span class="client-name">PROFESIOLAN</span>
              <span class="client-name">CONFOLAR</span>
              <span class="client-name">HELIAN</span>
              <span class="client-name">PLEKARI</span>
              <span class="client-name">SAICA</span>
              <span class="client-name">DIBAL</span>
              <span class="client-name">DTCreativos</span>
              <span class="client-name">H2SITE</span>
              <span class="client-name">FRACHT</span>
              <span class="client-name">EGIBIDE</span>
              <span class="client-name">MEDIAPRO</span>
              <span class="client-name">CIRCMAR</span>
              <span class="client-name">BIZKAIKO FORU ALDUNDIA</span>
              <span class="client-name">BITLIFEMEDIA</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Narrative continued -->
      <section class="mt-section-mobile lg:mt-section mb-section-mobile lg:mb-section">
        <!-- Block 03 — Consistency — video left -->
        <div class="narrative-block relative grid grid-cols-1 lg:grid-cols-12 gap-xl items-start mb-section-mobile lg:mb-4xl">
          <span class="big-num absolute top-0 right-0 text-ink/[0.04] text-[100px] font-accent font-bold leading-none tracking-[-0.06em] select-none pointer-events-none z-[1]">03</span>
          <div class="video-col lg:col-span-7 lg:sticky lg:top-[72px]">
            <div class="relative aspect-[16/9] bg-canvas rounded-xl border border-border-light overflow-hidden">
              <div class="absolute inset-0 flex items-center justify-center text-ghost text-[13px]">
                [Consistency showcase video]
              </div>
            </div>
          </div>
          <div class="text-col relative z-[2] lg:col-span-4 lg:col-start-9">
            <span class="text-ghost text-[10px] font-medium tracking-[0.08px] uppercase px-2.5 py-1 border border-border rounded-sm mb-md inline-block">{t('koora.narrative3.tag')}</span>
            <h3 class="text-[clamp(22px,2.5vw,30px)] font-light leading-[1.18] tracking-[-0.03em] text-ink text-balance mb-sm">
              {t('koora.narrative3.title')}
            </h3>
            <p class="text-muted text-[15px] leading-[1.75]">
              {t('koora.narrative3.body')}
            </p>
          </div>
        </div>

        <!-- Block 04 — Pipeline — video right -->
        <div class="narrative-block relative grid grid-cols-1 lg:grid-cols-12 gap-xl items-start">
          <span class="big-num absolute top-0 left-0 text-ink/[0.04] text-[100px] font-accent font-bold leading-none tracking-[-0.06em] select-none pointer-events-none z-[1]">04</span>
          <div class="text-col relative z-[2] lg:col-span-4 lg:order-1">
            <span class="text-ghost text-[10px] font-medium tracking-[0.08px] uppercase px-2.5 py-1 border border-border rounded-sm mb-md inline-block">{t('koora.narrative4.tag')}</span>
            <h3 class="text-[clamp(22px,2.5vw,30px)] font-light leading-[1.18] tracking-[-0.03em] text-ink text-balance mb-sm">
              {t('koora.narrative4.title')}
            </h3>
            <p class="text-muted text-[15px] leading-[1.75]">
              {t('koora.narrative4.body')}
            </p>
          </div>
          <div class="video-col lg:col-span-7 lg:col-start-6 lg:order-2 lg:sticky lg:top-[72px]">
            <div class="relative aspect-[16/9] bg-canvas rounded-xl border border-border-light overflow-hidden">
              <div class="absolute inset-0 flex items-center justify-center text-ghost text-[13px]">
                [Pipeline showcase video]
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Trail — text only -->
      <section class="mt-section-mobile lg:mt-section mb-section-mobile lg:mb-section">
        <div class="max-w-[800px] mx-auto text-center">
          <h2 class="text-[clamp(28px,3.5vw,44px)] font-light leading-[1.06] tracking-[-0.04em] text-ink text-balance mb-lg">
            {t('koora.trail.title')}
          </h2>
          <p class="text-muted text-[15px] leading-[1.75]">
            {t('koora.trail.body')}
          </p>
        </div>
      </section>

      <!-- CTA — dark -->
      <div class="relative bg-ink w-screen overflow-hidden text-center py-section-mobile lg:py-section" style="margin-left: calc(-50vw + 50%);">
        <h2 class="text-[clamp(24px,3vw,36px)] font-light leading-[1.15] tracking-[-0.03em] text-canvas text-balance mb-sm">
          {t('koora.portfolio.heading')}
        </h2>
        <p class="text-canvas/60 text-[16px] leading-[1.6] mb-xl max-w-[480px] mx-auto">
          {t('koora.portfolio.subheading')}
        </p>
        <a
          href="https://koora.studio"
          target="_blank"
          rel="noopener noreferrer"
          class="magnetic inline-flex items-center justify-center px-6 py-3 bg-canvas text-ink text-[14px] font-medium tracking-[-0.2px] rounded-lg transition-colors duration-300 hover:bg-canvas/90"
        >
          {t('koora.portfolio.button')}
          <IconArrowUpRight class="ml-sm" />
        </a>
        <p class="text-canvas/40 text-[12px] mt-md">
          {t('koora.portfolio.cta')}
        </p>
      </div>

    </div>
  </main>


</BaseLayout>

<script>
  import { initSmoothScroll, initNavHideShow, initMagneticButtons, gsap, prefersReducedMotion } from '@utils/shared';

  const lenis = initSmoothScroll();
  initNavHideShow(lenis);
  initMagneticButtons();

  if (!prefersReducedMotion) {
    const heroHeading = document.querySelector('main h1');
    if (heroHeading) {
      gsap.from(heroHeading, { y: 24, autoAlpha: 0, duration: 0.8, ease: 'power2.out', delay: 0.1 });
    }

    const heroLede = heroHeading?.closest('section')?.querySelector('p');
    if (heroLede && heroHeading) {
      gsap.from(heroLede, { y: 16, autoAlpha: 0, duration: 0.7, ease: 'power2.out', delay: 0.25 });
    }

    const heroVideo = document.querySelector('section:first-of-type .aspect-\\[16\\/9\\]');
    if (heroVideo) {
      gsap.from(heroVideo, {
        scale: 0.96,
        autoAlpha: 0,
        duration: 0.95,
        ease: 'power3.out',
        delay: 0.2,
      });
    }

    const heroStats = document.querySelector('section:first-of-type .grid.grid-cols-4');
    if (heroStats) {
      const statEls = heroStats.querySelectorAll(':scope > div');
      gsap.from(statEls, {
        y: 12, autoAlpha: 0, duration: 0.4, ease: 'power2.out', stagger: 0.06, delay: 0.5,
      });
    }

    const narrativeSection = document.querySelector('section:nth-of-type(2)');
    if (narrativeSection) {
      const narrativeLabel = narrativeSection.querySelector(':scope > div:first-child span');
      const narrativeHeading = narrativeSection.querySelector(':scope > div:first-child h2');
      if (narrativeLabel) {
        gsap.from(narrativeLabel, {
          y: 12, autoAlpha: 0, duration: 0.5, ease: 'power2.out',
          scrollTrigger: { trigger: narrativeLabel, start: 'top 88%', once: true },
        });
      }
      if (narrativeHeading) {
        gsap.from(narrativeHeading, {
          y: 16, autoAlpha: 0, duration: 0.7, ease: 'power2.out',
          scrollTrigger: { trigger: narrativeHeading, start: 'top 85%', once: true },
        });
      }
    }

    document.querySelectorAll('.narrative-block').forEach((block) => {
      const textCol = block.querySelector('.text-col');
      const bigNum = block.querySelector('.big-num');

      if (bigNum) {
        gsap.fromTo(bigNum, { y: 40 }, {
          y: -40, ease: 'none',
          scrollTrigger: { trigger: block, start: 'top bottom', end: 'bottom top', scrub: true },
        });
      }

      if (textCol) {
        const textEls = textCol.querySelectorAll(':scope > span:not(:first-child), :scope > h3, :scope > p');
        if (textEls.length) {
          gsap.from(textEls, {
            y: 18, autoAlpha: 0, duration: 0.5, ease: 'power2.out', stagger: 0.1,
            scrollTrigger: { trigger: block, start: 'top 76%', once: true },
          });
        }
      }
    });

    const darkMarquee = document.querySelector('.bg-ink.w-screen');
    if (darkMarquee) {
      gsap.from(darkMarquee.querySelectorAll(':scope > p, :scope > div'), {
        y: 16, autoAlpha: 0, duration: 0.6, ease: 'power2.out', stagger: 0.1,
        scrollTrigger: { trigger: darkMarquee, start: 'top 88%', once: true },
      });
    }

    const ctaSection = document.querySelector('.bg-ink.w-screen.text-center');
    if (ctaSection) {
      gsap.from(ctaSection.querySelectorAll(':scope > *'), {
        y: 16, autoAlpha: 0, duration: 0.6, ease: 'power2.out', stagger: 0.1,
        scrollTrigger: { trigger: ctaSection, start: 'top 88%', once: true },
      });
    }
  }
</script>
