---
import BaseLayout from '@layouts/BaseLayout.astro';
import Navigation from '@components/Navigation.astro';
import { useTranslations, defaultLang, type Language } from '@i18n/ui';

const lang = (Astro.currentLocale ?? defaultLang) as Language;
const t = useTranslations(lang);

const rows = [
  ['cafe', 'bar', 'bonbon', 'bravas-1', 'bravas-2', 'chocolate-bar', 'churro'],
  ['churros', 'coulant', 'gyoza', 'honey-cake', 'chocolate-hover', 'huesito', 'kortxo'],
  ['macaron', 'matcha-cookies', 'panellet-1', 'panellet-2', 'panellet-3', 'pansuflado', 'pasta'],
  ['pineapple', 'pringle', 'snack', 'spoonful', 'tea-matcha', 'topoki', 'waffle-honey'],
];
---

<BaseLayout
  title={lang === 'es' ? 'Eyes Eat First — Álvaro Ares' : 'Eyes Eat First — Álvaro Ares'}
  transitionLine1={t('transition.renders.line1')}
  transitionLine2={t('transition.renders.line2')}
>
  <Navigation />

  <main class="immersive-canvas" id="immersive-canvas">
    <div class="grid-rows" id="grid-rows">
      {rows.map((row, i) => (
        <div class="grid-row" data-row={i}>
          <div class="grid-row__track">
            {[...row, ...row].map((file) => (
              <div class="render-card">
                <img
                  src={`/food-renders/${file}.webp`}
                  alt={`${file} — 3D food render`}
                  loading={i < 2 ? 'eager' : 'lazy'}
                  decoding="async"
                />
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

    <div class="hero-text" id="hero-text">
      <h1>eyes<br />eats<br />first</h1>
    </div>

    <div class="scroll-hint" id="scroll-hint">
      <span>Scroll to explore</span>
    </div>

    <div class="bottom-bar">
      <div class="bottom-bar__inner">
        <div class="bottom-bar__stats">
          <div>
            <span class="bottom-bar__value">{t('renders.stats.1.value')}</span>
            <span class="bottom-bar__label">{t('renders.stats.1.label')}</span>
          </div>
          <div class="bottom-bar__divider"></div>
          <div>
            <span class="bottom-bar__value">{t('renders.stats.2.value')}</span>
            <span class="bottom-bar__label">{t('renders.stats.2.label')}</span>
          </div>
          <div class="bottom-bar__divider"></div>
          <div>
            <span class="bottom-bar__value">{t('renders.stats.3.value')}</span>
            <span class="bottom-bar__label">{t('renders.stats.3.label')}</span>
          </div>
          <div class="bottom-bar__divider"></div>
          <div>
            <span class="bottom-bar__value">{t('renders.stats.4.value')}</span>
            <span class="bottom-bar__label">{t('renders.stats.4.label')}</span>
          </div>
        </div>
        <a href={lang === defaultLang ? '/#contact' : '/es/#contact'} class="bottom-bar__cta">
          {t('renders.cta')}
        </a>
      </div>
    </div>
  </main>

  <div class="noise-overlay"></div>
</BaseLayout>

<style>
  :root {
    --card-w: 160px;
    --gap: 14px;
  }

  @media (max-width: 768px) {
    :root {
      --card-w: 100px;
      --gap: 8px;
    }
  }

  @media (min-width: 769px) and (max-width: 1024px) {
    :root {
      --card-w: 130px;
      --gap: 10px;
    }
  }

  :global(#main-nav) {
    background-color: color-mix(in srgb, var(--color-canvas) 82%, transparent) !important;
    backdrop-filter: blur(20px) !important;
    -webkit-backdrop-filter: blur(20px) !important;
    border-bottom: 1px solid var(--color-border-light);
  }

  .immersive-canvas {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    overflow: hidden;
    background: var(--color-warm);
    touch-action: none;
    -webkit-user-select: none;
    user-select: none;
  }

  .grid-rows {
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    transform: translateY(-50%);
    display: flex;
    flex-direction: column;
    gap: var(--gap);
    pointer-events: none;
  }

  .grid-row {
    overflow: hidden;
    width: 100%;
  }

  .grid-row__track {
    display: flex;
    gap: var(--gap);
    width: max-content;
    will-change: transform;
  }

  .render-card {
    width: var(--card-w);
    aspect-ratio: 3 / 4;
    border-radius: 14px;
    overflow: hidden;
    flex-shrink: 0;
    background: var(--color-surface);
    box-shadow:
      0 2px 8px rgba(0, 0, 0, 0.06),
      0 12px 40px rgba(0, 0, 0, 0.1);
  }

  .render-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: saturate(0.9);
  }

  .hero-text {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 20;
    pointer-events: none;
    text-align: center;
  }

  .hero-text h1 {
    font-family: 'Bricolage Grotesque', sans-serif;
    font-size: clamp(48px, 9vw, 120px);
    font-weight: 700;
    line-height: 0.9;
    letter-spacing: -0.04em;
    color: #fff;
    margin: 0;
    text-transform: lowercase;
    mix-blend-mode: difference;
    user-select: none;
  }

  .bottom-bar {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: color-mix(in srgb, var(--color-canvas) 82%, transparent);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-top: 1px solid var(--color-border-light);
    padding: 14px 32px;
  }

  .bottom-bar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .bottom-bar__stats {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .bottom-bar__value {
    font-family: var(--font-accent);
    font-size: 16px;
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--color-ink);
    display: block;
    line-height: 1;
    margin-bottom: 2px;
  }

  .bottom-bar__label {
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-ghost);
    display: block;
  }

  .bottom-bar__divider {
    width: 1px;
    height: 24px;
    background: var(--color-border-light);
  }

  .bottom-bar__cta {
    display: inline-flex;
    align-items: center;
    padding: 8px 18px;
    background: var(--color-ink);
    color: var(--color-canvas);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.02px;
    border-radius: 100px;
    text-decoration: none;
    transition: opacity 0.3s ease;
    flex-shrink: 0;
  }

  .bottom-bar__cta:hover {
    opacity: 0.85;
  }

  .scroll-hint {
    position: fixed;
    bottom: 72px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 100;
    color: var(--color-ghost);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    opacity: 1;
    transition: opacity 0.5s ease;
    animation: pulse-hint 2.5s ease-in-out infinite;
  }

  .scroll-hint.is-hidden {
    opacity: 0;
    pointer-events: none;
  }

  @keyframes pulse-hint {
    0%, 100% { opacity: 0.35; }
    50% { opacity: 0.6; }
  }

  @media (max-width: 768px) {
    .bottom-bar {
      padding: 12px 20px;
    }

    .bottom-bar__stats {
      gap: 12px;
    }

    .bottom-bar__value {
      font-size: 13px;
    }

    .bottom-bar__label {
      font-size: 8px;
    }

    .bottom-bar__divider {
      height: 20px;
    }

    .bottom-bar__cta {
      padding: 7px 14px;
      font-size: 11px;
    }

    .scroll-hint {
      bottom: 58px;
      font-size: 9px;
    }

    .render-card {
      border-radius: 10px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .scroll-hint {
      animation: none;
      opacity: 0.5;
    }
  }
</style>

<script>
  import { gsap } from 'gsap';

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!prefersReducedMotion) {
    const canvas = document.getElementById('immersive-canvas') as HTMLElement;
    const scrollHint = document.getElementById('scroll-hint') as HTMLElement;
    const tracks = document.querySelectorAll<HTMLElement>('.grid-row__track');

    const style = getComputedStyle(document.documentElement);
    const cardW = parseFloat(style.getPropertyValue('--card-w'));
    const gap = parseFloat(style.getPropertyValue('--gap'));
    const loopW = 7 * (cardW + gap);

    const rowConfigs = [
      { direction: 1, speed: 0.45, offset: 0 },
      { direction: -1, speed: 0.7, offset: 0.4 },
      { direction: 1, speed: 0.55, offset: 0.15 },
      { direction: -1, speed: 0.8, offset: 0.6 },
    ];

    const scroll = { y: 0, vy: 0 };
    const FRICTION = 0.94;
    const WHEEL_SENS = 0.6;

    let isTouching = false;
    let lastTouchY = 0;
    let lastTouchTime = 0;
    let touchVy = 0;
    let hintHidden = false;

    const hideHint = () => {
      if (!hintHidden && scrollHint) {
        scrollHint.classList.add('is-hidden');
        hintHidden = true;
      }
    };

    canvas.addEventListener('wheel', (e) => {
      e.preventDefault();
      hideHint();
      scroll.vy += e.deltaY * WHEEL_SENS;
    }, { passive: false });

    canvas.addEventListener('touchstart', (e) => {
      hideHint();
      isTouching = true;
      lastTouchY = e.touches[0].clientY;
      lastTouchTime = performance.now();
      scroll.vy = 0;
      touchVy = 0;
    }, { passive: true });

    canvas.addEventListener('touchmove', (e) => {
      e.preventDefault();
      const touch = e.touches[0];
      const dy = touch.clientY - lastTouchY;
      const now = performance.now();
      const dt = Math.max(now - lastTouchTime, 1);
      touchVy = (dy / dt) * 16;
      scroll.y += dy;
      lastTouchY = touch.clientY;
      lastTouchTime = now;
    }, { passive: false });

    canvas.addEventListener('touchend', () => {
      isTouching = false;
      scroll.vy = touchVy * 2.5;
    });

    gsap.ticker.add(() => {
      scroll.y += scroll.vy;

      if (!isTouching) {
        scroll.vy *= FRICTION;
        if (Math.abs(scroll.vy) < 0.05) scroll.vy = 0;
      }

      tracks.forEach((track, i) => {
        const cfg = rowConfigs[i];
        const raw = cfg.offset * loopW + scroll.y * cfg.speed * cfg.direction;
        const x = ((raw % loopW) + loopW) % loopW;
        track.style.transform = `translate3d(${-x}px, 0, 0)`;
      });
    });

    const tl = gsap.timeline({ delay: 0.2 });

    tl.from('.hero-text h1', {
      y: 40,
      autoAlpha: 0,
      duration: 1.2,
      ease: 'power3.out',
    });

    tl.from('.grid-row__track', {
      x: (i) => rowConfigs[i].direction > 0 ? -loopW * 0.15 : loopW * 0.15,
      autoAlpha: 0,
      duration: 0.9,
      ease: 'power3.out',
      stagger: 0.12,
    }, '-=0.8');

    tl.from('.bottom-bar', {
      y: 30,
      autoAlpha: 0,
      duration: 0.6,
      ease: 'power2.out',
    }, '-=0.4');

    tl.from('.scroll-hint', {
      y: 8,
      autoAlpha: 0,
      duration: 0.4,
      ease: 'power2.out',
    }, '-=0.2');
  }
</script>
