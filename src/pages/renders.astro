---
import BaseLayout from '@layouts/BaseLayout.astro';
import Navigation from '@components/Navigation.astro';
import ThemeSwitcher from '@components/ThemeSwitcher.astro';
---

<BaseLayout title="Renders — Álvaro Ares">
  <Navigation />

  <main class="bg-warm min-h-screen">
    <div class="sticky top-16 z-20 bg-warm/85 backdrop-blur-lg py-4 px-xl lg:px-3xl border-b border-border-light">
      <div class="max-w-[1200px] mx-auto flex justify-between items-center">
        <span class="inline-flex items-center gap-sm text-ghost text-[11px] font-medium tracking-[0.14px] uppercase">
          <span class="accent-dot"></span>
          Renders · Food & Product CGI
        </span>
        <a href="/" class="text-ghost text-[11px] font-medium tracking-[0.14px] uppercase hover:text-ink transition-colors duration-200">&larr; Back</a>
      </div>
    </div>

    <div class="max-w-[1200px] mx-auto px-xl lg:px-3xl pt-section pb-section">

      <div class="mb-3xl renders-reveal">
        <span class="text-ghost text-[11px] font-medium tracking-[0.14px] uppercase mb-sm block">Food · Product · Packaging · CGI</span>
        <h1 class="text-[clamp(44px,6vw,72px)] font-light leading-[1.02] tracking-[-0.045em] text-ink text-balance mb-xl">
          Photoreal CGI<br />that sells.
        </h1>
        <p class="text-[17px] leading-[1.65] text-muted max-w-[560px]">
          <strong class="text-ink">Food that makes you hungry. Products that look better than real life.</strong> Every texture, every reflection, every particle — hand-crafted in Maya + V-Ray. Zero shortcuts.
        </p>
      </div>

      <!-- Stats -->
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-xl border-t border-border-light pt-xl mb-3xl">
        <div class="renders-reveal" style="transition-delay: 0.05s;">
          <span class="font-accent text-[clamp(28px,3.5vw,42px)] font-bold leading-none tracking-[-0.04em] text-ink block mb-xs">200+</span>
          <span class="text-ghost text-[11px] tracking-[0.14px] uppercase">Renders delivered</span>
        </div>
        <div class="renders-reveal" style="transition-delay: 0.1s;">
          <span class="font-accent text-[clamp(28px,3.5vw,42px)] font-bold leading-none tracking-[-0.04em] text-ink block mb-xs">Maya</span>
          <span class="text-ghost text-[11px] tracking-[0.14px] uppercase">Primary tool</span>
        </div>
        <div class="renders-reveal" style="transition-delay: 0.15s;">
          <span class="font-accent text-[clamp(28px,3.5vw,42px)] font-bold leading-none tracking-[-0.04em] text-ink block mb-xs">V-Ray</span>
          <span class="text-ghost text-[11px] tracking-[0.14px] uppercase">Renderer</span>
        </div>
        <div class="renders-reveal" style="transition-delay: 0.2s;">
          <span class="font-accent text-[clamp(28px,3.5vw,42px)] font-bold leading-none tracking-[-0.04em] text-ink block mb-xs">4K</span>
          <span class="text-ghost text-[11px] tracking-[0.14px] uppercase">Resolution</span>
        </div>
      </div>

      <!-- Showcases -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-xl items-center mb-3xl">
        <div class="lg:col-span-7 renders-reveal">
          <div class="relative aspect-[16/10] bg-canvas rounded-xl border border-border-light overflow-hidden group">
            <div class="absolute inset-0 flex items-center justify-center text-ghost text-[13px]">[Food CGI]</div>
            <div class="absolute inset-0 bg-ink/0 group-hover:bg-ink/[0.03] transition-colors duration-500"></div>
          </div>
        </div>
        <div class="lg:col-span-4 lg:col-start-9 renders-reveal" style="transition-delay: 0.1s;">
          <span class="text-ghost text-[11px] font-medium tracking-[0.14px] uppercase mb-xs block">Food Styling</span>
          <h3 class="text-[20px] font-light leading-[1.2] tracking-[-0.02em] text-ink mb-sm">Looks delicious. Doesn't exist yet.</h3>
          <p class="text-muted text-[14px] leading-[1.55]">
            <strong class="text-ink">CGI food styling.</strong> Every drip, every crumb, every steam particle. Photoreal enough to make you order it — and it hasn't been cooked yet.
          </p>
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-xl items-center mb-3xl">
        <div class="lg:col-span-4 lg:order-1 renders-reveal" style="transition-delay: 0.1s;">
          <span class="text-ghost text-[11px] font-medium tracking-[0.14px] uppercase mb-xs block">Product Shots</span>
          <h3 class="text-[20px] font-medium leading-[1.2] tracking-[-0.02em] text-ink mb-sm">Better than the real thing.</h3>
          <p class="text-muted text-[14px] leading-[1.55]">
            <strong class="text-ink">Packaging hero shots. Product visualization.</strong> Every angle, every material, every lighting setup — controlled and perfect. No reshoots needed.
          </p>
        </div>
        <div class="lg:col-span-7 lg:col-start-6 lg:order-2 renders-reveal">
          <div class="relative aspect-[16/10] bg-canvas rounded-xl border border-border-light overflow-hidden group">
            <div class="absolute inset-0 flex items-center justify-center text-ghost text-[13px]">[Product CGI]</div>
            <div class="absolute inset-0 bg-ink/0 group-hover:bg-ink/[0.03] transition-colors duration-500"></div>
          </div>
        </div>
      </div>

      <!-- CTA -->
      <div class="border-t border-border-light pt-xl text-center renders-reveal">
        <a href="/#contact" class="magnetic inline-flex items-center justify-center px-6 py-3 bg-ink text-canvas text-[13px] font-medium tracking-[-0.2px] rounded-lg transition-all duration-300 hover:bg-ink/85">
          Need product renders?
        </a>
      </div>
    </div>
  </main>

  <ThemeSwitcher />
  <div class="noise-overlay"></div>
</BaseLayout>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!prefersReducedMotion) {
    document.querySelectorAll('.renders-reveal').forEach((el) => {
      gsap.fromTo(el,
        { opacity: 0, y: 28 },
        {
          opacity: 1,
          y: 0,
          duration: 0.75,
          ease: 'power3.out',
          scrollTrigger: {
            trigger: el,
            start: 'top 90%',
            toggleActions: 'play none none none',
          },
        }
      );
    });
  }
</script>
