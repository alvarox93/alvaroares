---
import BaseLayout from '@layouts/BaseLayout.astro';
import Navigation from '@components/Navigation.astro';
---

<BaseLayout title="Lapatzak — Álvaro Ares">
  <Navigation />

  <main class="bg-canvas min-h-screen">
    <div class="sticky top-16 z-20 bg-canvas/85 backdrop-blur-lg py-4 px-xl lg:px-3xl border-b border-border-light">
      <div class="max-w-[1200px] mx-auto flex justify-between items-center">
        <span class="inline-flex items-center gap-sm text-ghost text-[11px] font-medium tracking-[0.14px] uppercase">
          <span class="accent-dot"></span>
          Lapatzak · Brand & Product
        </span>
        <a href="/" class="text-ghost text-[11px] font-medium tracking-[0.14px] uppercase hover:text-ink transition-colors duration-200">&larr; Back</a>
      </div>
    </div>

    <div class="max-w-[1200px] mx-auto px-xl lg:px-3xl pt-section pb-section">

      <div class="mb-3xl">
        <span class="text-ghost text-[11px] font-medium tracking-[0.14px] uppercase mb-sm block">Own Brand · End to End · 2020—Present</span>
        <h1 class="text-[clamp(44px,6vw,72px)] font-light leading-[1.02] tracking-[-0.045em] text-ink text-balance mb-xl">
          From brand<br />to market.
        </h1>
        <p class="text-[17px] leading-[1.65] text-muted max-w-[560px]">
          <strong class="text-ink font-medium">Not a side project. A full product lab.</strong> Designing, prototyping and shipping a niche brand from zero — identity, packaging, digital presence and commerce.
        </p>
      </div>

      <!-- 3 Pillars -->
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-xl mb-3xl">
        <div class="bg-warm rounded-xl p-xl">
          <div class="relative aspect-[4/3] bg-surface rounded-lg overflow-hidden mb-lg">
            <div class="absolute inset-0 flex items-center justify-center text-ghost text-[13px]">[Branding]</div>
          </div>
          <span class="text-ghost text-[11px] font-medium tracking-[0.14px] uppercase mb-xs block">Branding & Identity</span>
          <h3 class="text-[18px] font-light leading-[1.2] tracking-[-0.02em] text-ink mb-sm">Visual Ecosystem</h3>
          <p class="text-muted text-[13px] leading-[1.5]">
            <strong class="text-ink font-medium">Naming. Identity. Guidelines.</strong> A brand is a system that breathes at every touchpoint.
          </p>
        </div>

        <div class="bg-warm rounded-xl p-xl">
          <div class="relative aspect-[4/3] bg-surface rounded-lg overflow-hidden mb-lg">
            <div class="absolute inset-0 flex items-center justify-center text-ghost text-[13px]">[Packaging]</div>
          </div>
          <span class="text-ghost text-[11px] font-medium tracking-[0.14px] uppercase mb-xs block">Multimedia & Packaging</span>
          <h3 class="text-[18px] font-light leading-[1.2] tracking-[-0.02em] text-ink mb-sm">Applied Art Direction</h3>
          <p class="text-muted text-[13px] leading-[1.5]">
            <strong class="text-ink font-medium">Physical packaging. Digital content.</strong> Art direction that connects product to person.
          </p>
        </div>

        <div class="bg-warm rounded-xl p-xl">
          <div class="relative aspect-[4/3] bg-surface rounded-lg overflow-hidden mb-lg">
            <div class="absolute inset-0 flex items-center justify-center text-ghost text-[13px]">[E-commerce]</div>
          </div>
          <span class="text-ghost text-[11px] font-medium tracking-[0.14px] uppercase mb-xs block">E-commerce</span>
          <h3 class="text-[18px] font-light leading-[1.2] tracking-[-0.02em] text-ink mb-sm">Interfaces That Convert</h3>
          <p class="text-muted text-[13px] leading-[1.5]">
            <strong class="text-ink font-medium">Store design focused on conversion.</strong> Clear UX, purchase flow that doesn't make you think.
          </p>
        </div>
      </div>

      <!-- CTA -->
      <div class="border-t border-border-light pt-xl text-center">
        <a href="/#contact" class="magnetic inline-flex items-center justify-center px-6 py-3 bg-ink text-canvas text-[13px] font-medium tracking-[-0.2px] rounded-lg transition-colors duration-300 hover:bg-ink/85">
          Want to talk brand strategy?
        </a>
      </div>
    </div>
  </main>

  <div class="noise-overlay"></div>
</BaseLayout>

<script>
  import Lenis from 'lenis';
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const lenis = new Lenis({
    duration: 1.2,
    easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
    touchMultiplier: 2,
  });

  lenis.on('scroll', ScrollTrigger.update);
  gsap.ticker.add((time) => { lenis.raf(time * 1000); });
  gsap.ticker.lagSmoothing(0);

  const nav = document.getElementById('main-nav');
  let lastNavScroll = 0;
  let navHidden = false;

  if (nav) {
    lenis.on('scroll', ({ scroll }: { scroll: number }) => {
      if (scroll > 50) nav.classList.add('nav-scrolled');
      else nav.classList.remove('nav-scrolled');

      if (scroll > lastNavScroll && scroll > 200 && !navHidden) {
        gsap.to(nav, { y: -80, duration: 0.4, ease: 'power3.in' });
        navHidden = true;
      } else if (scroll < lastNavScroll && navHidden) {
        gsap.to(nav, { y: 0, duration: 0.35, ease: 'power2.out' });
        navHidden = false;
      }
      lastNavScroll = scroll;
    });
  }

  if (!prefersReducedMotion) {
    const heroTitle = document.querySelector('main h1');
    if (heroTitle) {
      gsap.from(heroTitle, { y: 20, autoAlpha: 0, duration: 0.8, ease: 'power2.out', delay: 0.15 });
    }

    document.querySelectorAll('main .grid').forEach((grid) => {
      const cards = grid.querySelectorAll(':scope > div');
      if (cards.length > 1) {
        gsap.from(cards, {
          y: 24, autoAlpha: 0, duration: 0.6, ease: 'power2.out', stagger: 0.12,
          scrollTrigger: { trigger: grid, start: 'top 82%', once: true },
        });
      }

      grid.querySelectorAll('.aspect-\\[4\\/3\\]').forEach((img) => {
        gsap.from(img, {
          scale: 0.95, autoAlpha: 0, duration: 0.6, ease: 'power2.out',
          scrollTrigger: { trigger: img, start: 'top 85%', once: true },
        });
      });

      cards.forEach((card) => {
        const textEls = card.querySelectorAll('span[class*="ghost"], h3, p');
        if (textEls.length > 1) {
          gsap.from(textEls, {
            y: 14, autoAlpha: 0, duration: 0.4, ease: 'power2.out', stagger: 0.08,
            scrollTrigger: { trigger: card, start: 'top 82%', once: true },
          });
        }
      });
    });

    document.querySelectorAll('main .border-t').forEach((el) => {
      gsap.from(el, {
        y: 16, autoAlpha: 0, duration: 0.6, ease: 'power2.out',
        scrollTrigger: { trigger: el, start: 'top 90%', once: true },
      });
    });

    document.querySelectorAll('.magnetic').forEach((el) => {
      el.addEventListener('mousemove', (e) => {
        const rect = (el as HTMLElement).getBoundingClientRect();
        const x = (e as MouseEvent).clientX - rect.left - rect.width / 2;
        const y = (e as MouseEvent).clientY - rect.top - rect.height / 2;
        gsap.to(el, { x: x * 0.15, y: y * 0.15, duration: 0.3, ease: 'power2.out' });
      });
      el.addEventListener('mouseleave', () => {
        gsap.to(el, { x: 0, y: 0, duration: 0.5, ease: 'elastic.out(1, 0.5)' });
      });
    });
  }
</script>
