---
import { getCollection } from 'astro:content';
import PostLayout from '@layouts/PostLayout.astro';
import { type Language } from '@i18n/ui';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  const esPosts = posts.filter((p) => p.data.lang === 'es');
  return esPosts.map((post) => {
    const slug = post.slug.replace(/^es\//, '');
    return {
      params: { slug },
      props: { post },
    };
  });
}

const { post } = Astro.props;
const { Content } = await post.render();

const lang = 'es' as Language;

const slug = post.slug.replace(/^es\//, '');
const transitions: Record<string, string> = {
  'motion-design-systems': 'Motion que mueve',
  'cgi-vs-photography': 'Cada píxel merecido',
  'ai-pipeline': 'La mitad del tiempo, todo el criterio',
  'designing-in-code': 'Código como oficio',
  'building-lapatzak': 'Construido desde cero',
};

const transitionLine1 = transitions[slug] ?? post.data.title;
const transitionLine2 = '';
---

<PostLayout
  title={post.data.title}
  category={post.data.category}
  readTime={post.data.readTime}
  date={post.data.date}
  description={post.data.description}
  lang={lang}
  transitionLine1={transitionLine1}
  transitionLine2={transitionLine2}
>
  <Content />
</PostLayout>
