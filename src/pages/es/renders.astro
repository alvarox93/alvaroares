---
import BaseLayout from '@layouts/BaseLayout.astro';
import Navigation from '@components/Navigation.astro';
import { useTranslations, defaultLang, type Language } from '@i18n/ui';
import IconArrow from '@components/icons/IconArrow.astro';

const lang = (Astro.currentLocale ?? defaultLang) as Language;
const t = useTranslations(lang);

const row1 = ['matcha-cookies', 'huesito', 'pansuflado', 'bravas-1', 'topoki', 'panellet-1', 'chocolate-bar', 'cafe', 'bar', 'bonbon', 'bravas-2', 'churro', 'churros', 'coulant', 'gyoza', 'honey-cake', 'chocolate-hover', 'kortxo', 'macaron', 'panellet-2', 'pasta', 'pringle', 'tea-matcha', 'panellet-3', 'snack', 'pineapple', 'spoonful', 'waffle-honey'];
const row2 = ['bonbon', 'churros', 'honey-cake', 'kortxo', 'panellet-2', 'pasta', 'pringle', 'tea-matcha', 'bravas-2', 'gyoza', 'chocolate-hover', 'macaron', 'panellet-3', 'snack', 'cafe', 'bar', 'matcha-cookies', 'huesito', 'pansuflado', 'bravas-1', 'topoki', 'panellet-1', 'chocolate-bar', 'churro', 'coulant', 'pineapple', 'spoonful', 'waffle-honey'];
const row3 = ['cafe', 'churro', 'coulant', 'huesito', 'panellet-1', 'pineapple', 'spoonful', 'topoki', 'bar', 'bravas-1', 'chocolate-bar', 'matcha-cookies', 'pansuflado', 'waffle-honey', 'bonbon', 'churros', 'honey-cake', 'kortxo', 'panellet-2', 'pasta', 'pringle', 'tea-matcha', 'bravas-2', 'gyoza', 'chocolate-hover', 'macaron', 'panellet-3', 'snack'];
const row4 = ['coulant', 'snack', 'bar', 'pineapple', 'gyoza', 'churros', 'waffle-honey', 'cafe', 'churro', 'huesito', 'panellet-1', 'topoki', 'bravas-1', 'chocolate-bar', 'matcha-cookies', 'pansuflado', 'bonbon', 'bravas-2', 'honey-cake', 'kortxo', 'panellet-2', 'pasta', 'pringle', 'tea-matcha', 'chocolate-hover', 'macaron', 'panellet-3', 'spoonful'];

const rows = [row1, row2, row3, row4];
const rowLengths = rows.map(r => r.length);
---

<BaseLayout
  title={lang === 'es' ? 'Eyes Eat First — Álvaro Ares' : 'Eyes Eat First — Álvaro Ares'}
  transitionLine1={t('transition.renders.line1')}
  transitionLine2={t('transition.renders.line2')}
>
  <Navigation />

  <main class="immersive-canvas" id="immersive-canvas">
    <div class="grid-rows" id="grid-rows" data-row-lengths={JSON.stringify(rowLengths)}>
      {rows.map((row, i) => (
        <div class="grid-row" data-row={i}>
          <div class="grid-row__track">
            {[...row, ...row].map((file) => (
              <div class="render-card">
                <img
                  src={`/food-renders/${file}.webp`}
                  alt={`${file} — 3D food render`}
                  loading={i === 0 ? "eager" : "lazy"}
                  decoding="async"
                />
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

    <div class="hero-text" id="hero-text">
      <h1>eyes<br />eats<br />first</h1>
    </div>

    <div class="bottom-bar">
      <div class="bottom-bar__hero">
        <div class="bottom-bar__content">
          <h3 class="bottom-bar__title">{t('renders.copy.title')}</h3>
          <div class="bottom-bar__text">
            <p class="bottom-bar__copy">{t('renders.copy')}</p>
          </div>
          <div class="bottom-bar__tools">
            {t('renders.tools').split(',').map((tool) => (
              <span class="bottom-bar__tool-tag">{tool.trim()}</span>
            ))}
          </div>
        </div>
        <a href={lang === defaultLang ? '/#contact' : '/es/#contact'} class="bottom-bar__cta">
          {t('renders.cta')}
          <IconArrow />
        </a>
      </div>
    </div>
  </main>

  <div class="noise-overlay"></div>
</BaseLayout>

<style>
  :root {
    --gap: 14px;
  }

  @media (max-width: 768px) {
    :root {
      --gap: 8px;
    }
  }

  @media (min-width: 769px) and (max-width: 1024px) {
    :root {
      --gap: 10px;
    }
  }

  :global(#main-nav) {
    background-color: color-mix(in srgb, var(--color-canvas) 82%, transparent) !important;
    backdrop-filter: blur(20px) !important;
    -webkit-backdrop-filter: blur(20px) !important;
    border-bottom: 1px solid var(--color-border-light);
  }

  .immersive-canvas {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100dvh;
    overflow: hidden;
    background: #ffffff;
    touch-action: none;
    -webkit-user-select: none;
    user-select: none;
  }

  .grid-rows {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    gap: var(--gap);
    pointer-events: none;
  }

  .grid-row {
    flex: 1;
    min-height: 0;
    overflow: hidden;
    width: 100%;
    background: #ffffff;
  }

  .grid-row__track {
    display: flex;
    gap: var(--gap);
    height: 100%;
    width: max-content;
    will-change: transform;
  }

  .render-card {
    height: 100%;
    aspect-ratio: 3 / 4;
    border-radius: 14px;
    overflow: hidden;
    flex-shrink: 0;
    background: #ffffff;
  }

  .render-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: saturate(0.9);
  }

  .hero-text {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 20;
    pointer-events: none;
    text-align: center;
  }

  .hero-text::before {
    content: '';
    position: absolute;
    inset: -80%;
    background: radial-gradient(ellipse at center, rgba(26, 26, 26, 0.18) 0%, transparent 60%);
    z-index: -1;
    pointer-events: none;
    border-radius: 50%;
  }

  .hero-text h1 {
    font-family: 'Bricolage Grotesque', sans-serif;
    font-size: clamp(44px, 9vw, 120px);
    font-weight: 700;
    line-height: 0.9;
    letter-spacing: -0.04em;
    color: #fff;
    margin: 0;
    text-transform: lowercase;
    mix-blend-mode: difference;
    user-select: none;
    text-shadow: 
      0 0 40px rgba(0, 0, 0, 0.3),
      0 0 80px rgba(0, 0, 0, 0.2),
      0 4px 20px rgba(0, 0, 0, 0.15);
  }

  .bottom-bar {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: color-mix(in srgb, var(--color-canvas) 88%, transparent);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border-top: 1px solid var(--color-border-light);
    padding: 20px 32px;
  }

  .bottom-bar__hero {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 32px;
  }

  .bottom-bar__content {
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex: 1;
  }

  .bottom-bar__title {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    margin: 0;
    line-height: 1.2;
  }

  .bottom-bar__text {
    max-width: 600px;
  }

  .bottom-bar__copy {
    font-size: 15px;
    font-weight: 400;
    line-height: 1.6;
    color: var(--color-muted);
    margin: 0;
  }

  .bottom-bar__tools {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 4px;
  }

  .bottom-bar__tool-tag {
    display: inline-block;
    padding: 4px 12px;
    background: var(--color-surface);
    color: var(--color-muted);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.02em;
    border-radius: 6px;
    border: 1px solid var(--color-border-light);
  }

  .bottom-bar__cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    background: var(--color-ink);
    color: var(--color-canvas);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.02px;
    border-radius: 8px;
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    flex-shrink: 0;
    white-space: nowrap;
  }

  .bottom-bar__cta:hover {
    background: var(--color-ink);
    transform: translateX(2px);
  }

  .bottom-bar__cta svg {
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .bottom-bar__cta:hover svg {
    transform: translateX(2px);
  }

  @media (max-width: 768px) {
    .bottom-bar {
      padding: 16px 20px;
    }

    .bottom-bar__hero {
      flex-direction: column;
      align-items: flex-start;
      gap: 16px;
    }

    .bottom-bar__title {
      font-size: 18px;
    }

    .bottom-bar__text {
      width: 100%;
    }

    .bottom-bar__copy {
      font-size: 13px;
    }

    .bottom-bar__tools {
      gap: 6px;
    }

    .bottom-bar__tool-tag {
      padding: 3px 10px;
      font-size: 11px;
    }

    .bottom-bar__cta {
      width: 100%;
      justify-content: center;
      padding: 11px 20px;
      font-size: 12px;
    }

    .render-card {
      border-radius: 10px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .render-card {
      transition: box-shadow 0.3s ease;
    }
  }
</style>

<script>
  import { gsap } from 'gsap';

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // Wait for first row images to load before starting animation (progressive loading)
  const waitForImages = (): Promise<void> => {
    return new Promise((resolve) => {
      const firstRowImages = document.querySelectorAll<HTMLImageElement>('.grid-row[data-row="0"] .render-card img');
      let loaded = 0;
      const total = firstRowImages.length;

      if (total === 0) {
        resolve();
        return;
      }

      const checkComplete = () => {
        loaded++;
        if (loaded >= total) {
          resolve();
        }
      };

      firstRowImages.forEach(img => {
        if (img.complete && img.naturalWidth > 0) {
          checkComplete();
        } else {
          img.addEventListener('load', checkComplete, { once: true });
          img.addEventListener('error', checkComplete, { once: true });
        }
      });
    });
  };

  const initAnimation = async () => {
    await waitForImages();
    
    // Wait a bit more for layout to stabilize
    await new Promise(resolve => setTimeout(resolve, 100));

    if (!prefersReducedMotion) {
      const canvas = document.getElementById('immersive-canvas') as HTMLElement;
      const tracks = document.querySelectorAll<HTMLElement>('.grid-row__track');
      const gridRows = document.getElementById('grid-rows') as HTMLElement;
      const rowLengths: number[] = JSON.parse(gridRows?.dataset.rowLengths || '[]');

      const rowConfigs = [
        { direction: 1, speed: 0.45, offset: 0 },
        { direction: -1, speed: 0.7, offset: 0.4 },
        { direction: 1, speed: 0.55, offset: 0.15 },
        { direction: -1, speed: 0.8, offset: 0.6 },
      ];

      // Calculate loopW by measuring the actual width of one complete set of images
      const calculateLoopWidths = () => {
        return Array.from(tracks).map((track, i) => {
          const cards = track.querySelectorAll('.render-card');
          if (cards.length === 0) return 1000;
          
          // Measure the actual width of the first complete set of images
          // We measure from the first card to the card at position [numCards]
          const numCards = rowLengths[i];
          const firstCard = cards[0];
          const duplicateCard = cards[numCards];
          
          if (duplicateCard) {
            // The loop width is the distance from the first card to the duplicate
            return (duplicateCard as HTMLElement).offsetLeft - (firstCard as HTMLElement).offsetLeft;
          }
          
          // Fallback: calculate manually
          const cardWidth = firstCard.getBoundingClientRect().width;
          const gap = parseFloat(getComputedStyle(track).gap) || 14;
          return (cardWidth * numCards) + (gap * (numCards - 1));
        });
      };

      // Initial calculation
      let loopWidths = calculateLoopWidths();

      // Recalculate multiple times to ensure accuracy
      setTimeout(() => { loopWidths = calculateLoopWidths(); }, 100);
      setTimeout(() => { loopWidths = calculateLoopWidths(); }, 500);
      setTimeout(() => { loopWidths = calculateLoopWidths(); }, 1000);

      // Auto-scroll state
      const scroll = { y: 0, vy: 0 };
      const BASE_SPEED = 0.3;
      const FRICTION = 0.94;
      const WHEEL_SENS = 0.15;

      let isTouching = false;
      let lastTouchY = 0;
      let lastTouchTime = 0;
      let touchVy = 0;

      canvas.addEventListener('wheel', (e) => {
        e.preventDefault();
        scroll.vy += e.deltaY * WHEEL_SENS;
      }, { passive: false });

      canvas.addEventListener('touchstart', (e) => {
        isTouching = true;
        lastTouchY = e.touches[0].clientY;
        lastTouchTime = performance.now();
        scroll.vy = 0;
        touchVy = 0;
      }, { passive: true });

      canvas.addEventListener('touchmove', (e) => {
        e.preventDefault();
        const touch = e.touches[0];
        const dy = touch.clientY - lastTouchY;
        const now = performance.now();
        const dt = Math.max(now - lastTouchTime, 1);
        touchVy = (dy / dt) * 16;
        scroll.y += dy;
        lastTouchY = touch.clientY;
        lastTouchTime = now;
      }, { passive: false });

      canvas.addEventListener('touchend', () => {
        isTouching = false;
        scroll.vy = touchVy * 0.8;
      });

      gsap.ticker.add(() => {
        // Always add base speed (auto-movement)
        scroll.y += BASE_SPEED;
        
        // Add user velocity
        scroll.y += scroll.vy;

        // Friction on user velocity only (returns to base speed)
        if (!isTouching) {
          scroll.vy *= FRICTION;
          if (Math.abs(scroll.vy) < 0.05) scroll.vy = 0;
        }

        tracks.forEach((track, i) => {
          const cfg = rowConfigs[i];
          const loopW = loopWidths[i];
          if (!loopW) return;
          const raw = cfg.offset * loopW + scroll.y * cfg.speed * cfg.direction;
          const x = ((raw % loopW) + loopW) % loopW;
          track.style.transform = `translate3d(${-x}px, 0, 0)`;
        });
      });

      const tl = gsap.timeline({ delay: 0.2 });

      tl.from('.hero-text h1', {
        y: 40,
        autoAlpha: 0,
        duration: 1.2,
        ease: 'power3.out',
      });

      tl.from('.grid-row__track', {
        x: (i) => rowConfigs[i].direction > 0 ? -loopWidths[i] * 0.15 : loopWidths[i] * 0.15,
        autoAlpha: 0,
        duration: 0.9,
        ease: 'power3.out',
        stagger: 0.12,
      }, '-=0.8');

      tl.from('.bottom-bar', {
        y: 30,
        autoAlpha: 0,
        duration: 0.6,
        ease: 'power2.out',
      }, '-=0.4');
    }
  };

  initAnimation();
</script>
