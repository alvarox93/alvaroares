---
import BaseLayout from '@layouts/BaseLayout.astro';
import Navigation from '@components/Navigation.astro';
import { useTranslations, defaultLang, type Language } from '@i18n/ui';

const lang = (Astro.currentLocale ?? defaultLang) as Language;
const t = useTranslations(lang);

const outerRow1 = ['matcha-cookies', 'huesito', 'pansuflado', 'bravas-1', 'topoki', 'panellet-1', 'chocolate-bar'];
const middleRow1 = ['bonbon', 'churros', 'honey-cake', 'kortxo', 'panellet-2', 'pasta', 'pringle', 'tea-matcha', 'bravas-2', 'gyoza', 'chocolate-hover', 'macaron', 'panellet-3', 'snack'];
const middleRow2 = ['cafe', 'churro', 'coulant', 'huesito', 'panellet-1', 'pineapple', 'spoonful', 'topoki', 'bar', 'bravas-1', 'chocolate-bar', 'matcha-cookies', 'pansuflado', 'waffle-honey'];
const outerRow2 = ['coulant', 'snack', 'bar', 'pineapple', 'gyoza', 'churros', 'waffle-honey'];

const rows = [outerRow1, middleRow1, middleRow2, outerRow2];
---

<BaseLayout
  title={lang === 'es' ? 'Eyes Eat First — Álvaro Ares' : 'Eyes Eat First — Álvaro Ares'}
  transitionLine1={t('transition.renders.line1')}
  transitionLine2={t('transition.renders.line2')}
>
  <Navigation />

  <main class="immersive-canvas" id="immersive-canvas">
    <div class="grid-rows" id="grid-rows">
      {rows.map((row, i) => (
        <div class="grid-row" data-row={i}>
          <div class="grid-row__track">
            {[...row, ...row].map((file) => (
              <div class="render-card">
                <img
                  src={`/food-renders/${file}.webp`}
                  alt={`${file} — 3D food render`}
                  loading={i >= 1 && i <= 2 ? 'eager' : 'lazy'}
                  decoding="async"
                />
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

    <div class="hero-text" id="hero-text">
      <h1>eyes<br />eats<br />first</h1>
    </div>

    <div class="bottom-bar">
      <div class="bottom-bar__inner">
        <div class="bottom-bar__stats">
          <div>
            <span class="bottom-bar__value">{t('renders.stats.1.value')}</span>
            <span class="bottom-bar__label">{t('renders.stats.1.label')}</span>
          </div>
          <div class="bottom-bar__divider"></div>
          <div>
            <span class="bottom-bar__value">{t('renders.stats.2.value')}</span>
            <span class="bottom-bar__label">{t('renders.stats.2.label')}</span>
          </div>
          <div class="bottom-bar__divider"></div>
          <div>
            <span class="bottom-bar__value">{t('renders.stats.3.value')}</span>
            <span class="bottom-bar__label">{t('renders.stats.3.label')}</span>
          </div>
          <div class="bottom-bar__divider"></div>
          <div>
            <span class="bottom-bar__value">{t('renders.stats.4.value')}</span>
            <span class="bottom-bar__label">{t('renders.stats.4.label')}</span>
          </div>
        </div>
        <div class="bottom-bar__right">
          <span class="bottom-bar__copy">{t('renders.copy')}</span>
        </div>
      </div>
    </div>
  </main>

  <div class="noise-overlay"></div>
</BaseLayout>

<style>
  :root {
    --gap: 14px;
  }

  @media (max-width: 768px) {
    :root {
      --gap: 8px;
    }
  }

  @media (min-width: 769px) and (max-width: 1024px) {
    :root {
      --gap: 10px;
    }
  }

  :global(#main-nav) {
    background-color: color-mix(in srgb, var(--color-canvas) 82%, transparent) !important;
    backdrop-filter: blur(20px) !important;
    -webkit-backdrop-filter: blur(20px) !important;
    border-bottom: 1px solid var(--color-border-light);
  }

  .immersive-canvas {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100dvh;
    overflow: hidden;
    background: var(--color-warm);
    touch-action: none;
    -webkit-user-select: none;
    user-select: none;
  }

  .grid-rows {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    gap: var(--gap);
    pointer-events: none;
  }

  .grid-row {
    flex: 1;
    min-height: 0;
    overflow: hidden;
    width: 100%;
  }

  .grid-row__track {
    display: flex;
    gap: var(--gap);
    height: 100%;
    width: max-content;
    will-change: transform;
  }

  .render-card {
    height: 100%;
    aspect-ratio: 3 / 4;
    border-radius: 14px;
    overflow: hidden;
    flex-shrink: 0;
    background: var(--color-surface);
    box-shadow:
      0 2px 8px rgba(0, 0, 0, 0.06),
      0 12px 40px rgba(0, 0, 0, 0.1);
  }

  .render-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: saturate(0.9);
  }

  .hero-text {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 20;
    pointer-events: none;
    text-align: center;
  }

  .hero-text::before {
    content: '';
    position: absolute;
    inset: -80%;
    background: radial-gradient(ellipse at center, rgba(26, 26, 26, 0.18) 0%, transparent 60%);
    z-index: -1;
    pointer-events: none;
    border-radius: 50%;
  }

  .hero-text h1 {
    font-family: 'Bricolage Grotesque', sans-serif;
    font-size: clamp(44px, 9vw, 120px);
    font-weight: 700;
    line-height: 0.9;
    letter-spacing: -0.04em;
    color: #fff;
    margin: 0;
    text-transform: lowercase;
    mix-blend-mode: difference;
    user-select: none;
    text-shadow: 
      0 0 40px rgba(0, 0, 0, 0.3),
      0 0 80px rgba(0, 0, 0, 0.2),
      0 4px 20px rgba(0, 0, 0, 0.15);
  }

  .bottom-bar {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: color-mix(in srgb, var(--color-canvas) 82%, transparent);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-top: 1px solid var(--color-border-light);
    padding: 14px 32px;
  }

  .bottom-bar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
  }

  .bottom-bar__stats {
    display: flex;
    align-items: center;
    gap: 20px;
    flex-shrink: 0;
  }

  .bottom-bar__value {
    font-family: var(--font-accent);
    font-size: 16px;
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--color-ink);
    display: block;
    line-height: 1;
    margin-bottom: 2px;
  }

  .bottom-bar__label {
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-ghost);
    display: block;
  }

  .bottom-bar__divider {
    width: 1px;
    height: 24px;
    background: var(--color-border-light);
  }

  .bottom-bar__copy {
    font-size: 12px;
    font-weight: 500;
    color: var(--color-muted);
    letter-spacing: -0.01em;
    white-space: nowrap;
  }

  .bottom-bar__right {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .bottom-bar {
      padding: 10px 16px;
    }

    .bottom-bar__inner {
      gap: 12px;
    }

    .bottom-bar__stats {
      gap: 10px;
    }

    .bottom-bar__value {
      font-size: 13px;
    }

    .bottom-bar__label {
      font-size: 7px;
    }

    .bottom-bar__divider {
      height: 20px;
    }

    .bottom-bar__copy {
      font-size: 10px;
    }

    .bottom-bar__scroll {
      font-size: 9px;
    }

    .bottom-bar__right {
      gap: 10px;
    }

    .render-card {
      border-radius: 10px;
    }
  }

  @media (max-width: 400px) {
    .bottom-bar__copy {
      display: none;
    }

    .bottom-bar__right {
      justify-content: flex-end;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .render-card {
      transition: box-shadow 0.3s ease;
    }
  }
</style>

<script>
  import { gsap } from 'gsap';

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // Preload all images
  const preloadImages = () => {
    const images = document.querySelectorAll<HTMLImageElement>('.render-card img');
    images.forEach(img => {
      if (img.complete) return;
      const src = img.src;
      const preload = new Image();
      preload.src = src;
    });
  };
  preloadImages();

  if (!prefersReducedMotion) {
    const canvas = document.getElementById('immersive-canvas') as HTMLElement;
    const tracks = document.querySelectorAll<HTMLElement>('.grid-row__track');

    const rowConfigs = [
      { direction: 1, speed: 0.45, offset: 0 },
      { direction: -1, speed: 0.7, offset: 0.4 },
      { direction: 1, speed: 0.55, offset: 0.15 },
      { direction: -1, speed: 0.8, offset: 0.6 },
    ];

    const loopWidths = Array.from(tracks).map(track => track.scrollWidth / 2);

    // Auto-scroll state
    const scroll = { y: 0, vy: 0 };
    const BASE_SPEED = 0.35; // Constant auto-movement
    const FRICTION = 0.94;
    const WHEEL_SENS = 0.8;

    let isTouching = false;
    let lastTouchY = 0;
    let lastTouchTime = 0;
    let touchVy = 0;

    canvas.addEventListener('wheel', (e) => {
      e.preventDefault();
      // Add to velocity (can accelerate or reverse direction)
      scroll.vy += e.deltaY * WHEEL_SENS;
    }, { passive: false });

    canvas.addEventListener('touchstart', (e) => {
      isTouching = true;
      lastTouchY = e.touches[0].clientY;
      lastTouchTime = performance.now();
      scroll.vy = 0;
      touchVy = 0;
    }, { passive: true });

    canvas.addEventListener('touchmove', (e) => {
      e.preventDefault();
      const touch = e.touches[0];
      const dy = touch.clientY - lastTouchY;
      const now = performance.now();
      const dt = Math.max(now - lastTouchTime, 1);
      touchVy = (dy / dt) * 16;
      scroll.y += dy;
      lastTouchY = touch.clientY;
      lastTouchTime = now;
    }, { passive: false });

    canvas.addEventListener('touchend', () => {
      isTouching = false;
      scroll.vy = touchVy * 2.5;
    });

    gsap.ticker.add(() => {
      // Always add base speed (auto-movement)
      scroll.y += BASE_SPEED;
      
      // Add user velocity
      scroll.y += scroll.vy;

      // Friction on user velocity only (returns to base speed)
      if (!isTouching) {
        scroll.vy *= FRICTION;
        if (Math.abs(scroll.vy) < 0.05) scroll.vy = 0;
      }

      tracks.forEach((track, i) => {
        const cfg = rowConfigs[i];
        const loopW = loopWidths[i];
        const raw = cfg.offset * loopW + scroll.y * cfg.speed * cfg.direction;
        const x = ((raw % loopW) + loopW) % loopW;
        track.style.transform = `translate3d(${-x}px, 0, 0)`;
      });
    });

    const tl = gsap.timeline({ delay: 0.2 });

    tl.from('.hero-text h1', {
      y: 40,
      autoAlpha: 0,
      duration: 1.2,
      ease: 'power3.out',
    });

    tl.from('.grid-row__track', {
      x: (i) => rowConfigs[i].direction > 0 ? -loopWidths[i] * 0.15 : loopWidths[i] * 0.15,
      autoAlpha: 0,
      duration: 0.9,
      ease: 'power3.out',
      stagger: 0.12,
    }, '-=0.8');

    tl.from('.bottom-bar', {
      y: 30,
      autoAlpha: 0,
      duration: 0.6,
      ease: 'power2.out',
    }, '-=0.4');
  }
</script>
