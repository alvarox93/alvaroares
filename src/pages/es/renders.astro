---
import BaseLayout from '@layouts/BaseLayout.astro';
import Navigation from '@components/Navigation.astro';
import { useTranslations, defaultLang, type Language } from '@i18n/ui';

const lang = (Astro.currentLocale ?? defaultLang) as Language;
const t = useTranslations(lang);
const backHref = lang === defaultLang ? '/' : '/es';
---

<BaseLayout title={lang === 'es' ? 'Renders — Álvaro Ares' : 'Renders — Álvaro Ares'}>
  <Navigation />

  <main class="bg-warm min-h-screen">
    <div class="sticky top-16 z-20 bg-warm/85 backdrop-blur-lg py-4 px-xl lg:px-3xl border-b border-border-light">
      <div class="max-w-[1200px] mx-auto flex justify-between items-center">
        <span class="inline-flex items-center gap-sm text-ghost text-[11px] font-medium tracking-[0.14px] uppercase">
          <span class="accent-dot"></span>
          {t('renders.title')}
        </span>
        <a href={backHref} class="text-ghost text-[11px] font-medium tracking-[0.14px] uppercase hover:text-ink transition-colors duration-200">&larr; {t('nav.back')}</a>
      </div>
    </div>

    <div class="max-w-[1200px] mx-auto px-xl lg:px-3xl pt-section pb-section">

      <div class="mb-3xl">
        <span class="text-ghost text-[11px] font-medium tracking-[0.14px] uppercase mb-sm block">{t('renders.meta')}</span>
        <h1 class="text-[clamp(44px,6vw,72px)] font-light leading-[1.02] tracking-[-0.045em] text-ink text-balance mb-xl">
          {t('renders.heading.line1')}<br />{t('renders.heading.line2')}
        </h1>
        <p class="text-[17px] leading-[1.65] text-muted max-w-[560px]">
          <strong class="text-ink">{t('renders.lede')}</strong> {t('renders.ledeBold')}
        </p>
      </div>

      <div class="grid grid-cols-2 lg:grid-cols-4 gap-xl border-t border-border-light pt-xl mb-3xl">
        <div>
          <span class="font-accent text-[clamp(28px,3.5vw,42px)] font-bold leading-none tracking-[-0.04em] text-ink block mb-xs">{t('renders.stats.1.value')}</span>
          <span class="text-ghost text-[11px] tracking-[0.14px] uppercase">{t('renders.stats.1.label')}</span>
        </div>
        <div>
          <span class="font-accent text-[clamp(28px,3.5vw,42px)] font-bold leading-none tracking-[-0.04em] text-ink block mb-xs">{t('renders.stats.2.value')}</span>
          <span class="text-ghost text-[11px] tracking-[0.14px] uppercase">{t('renders.stats.2.label')}</span>
        </div>
        <div>
          <span class="font-accent text-[clamp(28px,3.5vw,42px)] font-bold leading-none tracking-[-0.04em] text-ink block mb-xs">{t('renders.stats.3.value')}</span>
          <span class="text-ghost text-[11px] tracking-[0.14px] uppercase">{t('renders.stats.3.label')}</span>
        </div>
        <div>
          <span class="font-accent text-[clamp(28px,3.5vw,42px)] font-bold leading-none tracking-[-0.04em] text-ink block mb-xs">{t('renders.stats.4.value')}</span>
          <span class="text-ghost text-[11px] tracking-[0.14px] uppercase">{t('renders.stats.4.label')}</span>
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-xl items-center mb-3xl">
        <div class="lg:col-span-7">
          <div class="relative aspect-[16/10] bg-canvas rounded-xl border border-border-light overflow-hidden group">
            <div class="absolute inset-0 flex items-center justify-center text-ghost text-[13px]">[Food CGI]</div>
            <div class="absolute inset-0 bg-ink/0 group-hover:bg-ink/[0.03] transition-colors duration-500"></div>
          </div>
        </div>
        <div class="lg:col-span-4 lg:col-start-9">
          <span class="text-ghost text-[11px] font-medium tracking-[0.14px] uppercase mb-xs block">{t('renders.project1.tag')}</span>
          <h3 class="text-[20px] font-light leading-[1.2] tracking-[-0.02em] text-ink mb-sm">{t('renders.project1.title')}</h3>
          <p class="text-muted text-[14px] leading-[1.55]">
            <strong class="text-ink">{t('renders.project1.body')}</strong> {t('renders.project1.bodyBold')}
          </p>
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-xl items-center mb-3xl">
        <div class="lg:col-span-4 lg:order-1">
          <span class="text-ghost text-[11px] font-medium tracking-[0.14px] uppercase mb-xs block">{t('renders.project2.tag')}</span>
          <h3 class="text-[20px] font-medium leading-[1.2] tracking-[-0.02em] text-ink mb-sm">{t('renders.project2.title')}</h3>
          <p class="text-muted text-[14px] leading-[1.55]">
            <strong class="text-ink">{t('renders.project2.body')}</strong> {t('renders.project2.bodyBold')}
          </p>
        </div>
        <div class="lg:col-span-7 lg:col-start-6 lg:order-2">
          <div class="relative aspect-[16/10] bg-canvas rounded-xl border border-border-light overflow-hidden group">
            <div class="absolute inset-0 flex items-center justify-center text-ghost text-[13px]">[Product CGI]</div>
            <div class="absolute inset-0 bg-ink/0 group-hover:bg-ink/[0.03] transition-colors duration-500"></div>
          </div>
        </div>
      </div>

      <div class="border-t border-border-light pt-xl text-center">
        <a href={lang === defaultLang ? '/#contact' : '/es/#contact'} class="magnetic inline-flex items-center justify-center px-6 py-3 bg-ink text-canvas text-[13px] font-medium tracking-[-0.2px] rounded-lg transition-colors duration-300 hover:bg-ink/85">
          {t('renders.cta')}
        </a>
      </div>
    </div>
  </main>

  <div class="noise-overlay"></div>
</BaseLayout>

<script>
  import Lenis from 'lenis';
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const lenis = new Lenis({
    duration: 1.2,
    easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
    touchMultiplier: 2,
  });

  lenis.on('scroll', ScrollTrigger.update);
  gsap.ticker.add((time) => { lenis.raf(time * 1000); });
  gsap.ticker.lagSmoothing(0);

  const nav = document.getElementById('main-nav');
  let lastNavScroll = 0;
  let navHidden = false;

  if (nav) {
    lenis.on('scroll', ({ scroll }: { scroll: number }) => {
      if (scroll > 50) nav.classList.add('nav-scrolled');
      else nav.classList.remove('nav-scrolled');

      if (scroll > lastNavScroll && scroll > 200 && !navHidden) {
        gsap.to(nav, { y: -80, duration: 0.4, ease: 'power3.in' });
        navHidden = true;
      } else if (scroll < lastNavScroll && navHidden) {
        gsap.to(nav, { y: 0, duration: 0.35, ease: 'power2.out' });
        navHidden = false;
      }
      lastNavScroll = scroll;
    });
  }

  if (!prefersReducedMotion) {
    const heroTitle = document.querySelector('main h1');
    if (heroTitle) {
      gsap.from(heroTitle, { y: 20, autoAlpha: 0, duration: 0.8, ease: 'power2.out', delay: 0.15 });
    }

    document.querySelectorAll('main .grid').forEach((grid) => {
      const isShowcase = grid.classList.contains('items-center') && grid.querySelector('h3');

      if (isShowcase) {
        const imageWrap = grid.querySelector('.aspect-\\[16\\/10\\]');
        const textCol = grid.querySelector('h3')?.closest('div');

        if (imageWrap) {
          gsap.from(imageWrap, {
            scale: 0.96, autoAlpha: 0, duration: 0.7, ease: 'power2.out',
            scrollTrigger: { trigger: grid, start: 'top 80%', once: true },
          });
          gsap.fromTo(imageWrap, { yPercent: 5 }, {
            yPercent: -5, ease: 'none',
            scrollTrigger: { trigger: grid, start: 'top bottom', end: 'bottom top', scrub: true },
          });
        }

        if (textCol) {
          const textEls = textCol.querySelectorAll(':scope > span, :scope > h3, :scope > p');
          if (textEls.length) {
            gsap.from(textEls, {
              y: 18, autoAlpha: 0, duration: 0.5, ease: 'power2.out', stagger: 0.1,
              scrollTrigger: { trigger: grid, start: 'top 78%', once: true },
            });
          }
          gsap.fromTo(textCol, { y: 20 }, {
            y: -20, ease: 'none',
            scrollTrigger: { trigger: grid, start: 'top bottom', end: 'bottom top', scrub: true },
          });
        }
      } else {
        const children = grid.querySelectorAll(':scope > div');
        if (children.length > 1) {
          gsap.from(children, {
            y: 16, autoAlpha: 0, duration: 0.5, ease: 'power2.out', stagger: 0.08,
            scrollTrigger: { trigger: grid, start: 'top 85%', once: true },
          });
        }
      }
    });

    document.querySelectorAll('main .border-t').forEach((el) => {
      gsap.from(el, {
        y: 16, autoAlpha: 0, duration: 0.6, ease: 'power2.out',
        scrollTrigger: { trigger: el, start: 'top 90%', once: true },
      });
    });

    document.querySelectorAll('.magnetic').forEach((el) => {
      el.addEventListener('mousemove', (e) => {
        const rect = (el as HTMLElement).getBoundingClientRect();
        const x = (e as MouseEvent).clientX - rect.left - rect.width / 2;
        const y = (e as MouseEvent).clientY - rect.top - rect.height / 2;
        gsap.to(el, { x: x * 0.15, y: y * 0.15, duration: 0.3, ease: 'power2.out' });
      });
      el.addEventListener('mouseleave', () => {
        gsap.to(el, { x: 0, y: 0, duration: 0.5, ease: 'elastic.out(1, 0.5)' });
      });
    });
  }
</script>
