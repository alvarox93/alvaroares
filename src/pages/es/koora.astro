---
import BaseLayout from '@layouts/BaseLayout.astro';
import Navigation from '@components/Navigation.astro';
import { useTranslations, defaultLang, type Language } from '@i18n/ui';

const lang = (Astro.currentLocale ?? defaultLang) as Language;
const t = useTranslations(lang);
const backHref = lang === defaultLang ? '/' : '/es';
---

<BaseLayout
  title={lang === 'es' ? 'Koora.studio — Álvaro Ares' : 'Koora.studio — Álvaro Ares'}
  transitionLine1={t('transition.koora.line1')}
  transitionLine2={t('transition.koora.line2')}
>
  <Navigation />

  <main class="bg-warm min-h-screen">
    <div class="max-w-[1200px] mx-auto px-xl lg:px-3xl">

      <!-- Back -->
      <a href={backHref} class="inline-block text-ghost text-[11px] font-medium tracking-[0.14px] uppercase hover:text-ink transition-colors duration-200 pt-2xl lg:pt-3xl mb-2xl">
        {t('nav.backToHome')}
      </a>

      <!-- Hero -->
      <section class="relative pb-2xl">
        <div class="hero-blob" style="top: -60px; right: -80px;"></div>

        <span class="relative text-ghost text-[11px] font-medium tracking-[0.14px] uppercase mb-sm block">{t('koora.meta')}</span>
        <h1 class="relative text-[clamp(42px,6vw,76px)] font-light leading-[0.98] tracking-[-0.05em] text-ink text-balance mb-lg max-w-[800px]">
          {t('koora.heading')}
        </h1>
        <p class="relative text-[clamp(17px,2vw,22px)] leading-[1.65] text-muted max-w-[640px] mb-3xl">
          <strong class="text-ink font-medium">{t('koora.lede')}</strong>{t('koora.ledeBold')}
        </p>

        <!-- Showreel -->
        <div class="relative aspect-[16/9] bg-canvas rounded-2xl border border-border-light overflow-hidden shadow-sm">
          <video
            class="absolute inset-0 w-full h-full object-cover"
            controls
            playsinline
            poster="[POSTER_URL]"
          >
            <source src="[VIDEO_URL]" type="video/mp4" />
          </video>
          <div class="absolute bottom-0 left-0 right-0 p-lg bg-gradient-to-t from-black/80 to-transparent">
            <span class="text-canvas/80 text-[13px] font-medium">
              {t('koora.video.caption.showreel')}
            </span>
          </div>
        </div>
      </section>

      <!-- Metrics -->
      <section class="mb-section-mobile lg:mb-section">
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-sm lg:gap-lg">
          <div class="bg-canvas rounded-xl border border-border-light p-lg lg:p-xl">
            <span class="font-accent text-[clamp(36px,4.5vw,64px)] font-bold leading-none tracking-[-0.04em] text-ink block mb-xs">{t('koora.stats.years.value')}</span>
            <span class="text-ghost text-[12px] lg:text-[13px] font-medium leading-tight block">{t('koora.stats.years')}</span>
          </div>
          <div class="bg-canvas rounded-xl border border-border-light p-lg lg:p-xl">
            <span class="font-accent text-[clamp(36px,4.5vw,64px)] font-bold leading-none tracking-[-0.04em] text-ink block mb-xs">{t('koora.stats.projects.value')}</span>
            <span class="text-ghost text-[12px] lg:text-[13px] font-medium leading-tight block">{t('koora.stats.projects')}</span>
          </div>
          <div class="bg-canvas rounded-xl border border-border-light p-lg lg:p-xl">
            <span class="font-accent text-[clamp(36px,4.5vw,64px)] font-bold leading-none tracking-[-0.04em] text-ink block mb-xs">{t('koora.stats.countries.value')}</span>
            <span class="text-ghost text-[12px] lg:text-[13px] font-medium leading-tight block">{t('koora.stats.countries')}</span>
          </div>
          <div class="bg-canvas rounded-xl border border-border-light p-lg lg:p-xl">
            <span class="font-accent text-[clamp(36px,4.5vw,64px)] font-bold leading-none tracking-[-0.04em] text-ink block mb-xs">{t('koora.stats.languages.value')}</span>
            <span class="text-ghost text-[12px] lg:text-[13px] font-medium leading-tight block">{t('koora.stats.languages')}</span>
          </div>
        </div>
      </section>

      <!-- Narrative -->
      <section class="mb-section-mobile lg:mb-section">
        <div class="mb-3xl">
          <span class="text-ghost text-[11px] font-medium tracking-[0.14px] uppercase mb-sm block">{t('koora.narrative.label')}</span>
          <h2 class="text-[clamp(28px,3.5vw,44px)] font-light leading-[1.06] tracking-[-0.04em] text-ink text-balance max-w-[600px]">
            {t('koora.narrative.heading')}
          </h2>
        </div>

        <!-- Block 01 — International reach -->
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-xl items-start mb-section-mobile lg:mb-section relative">
          <span class="hidden lg:block absolute -top-8 -left-6 text-[120px] font-accent font-bold leading-none tracking-[-0.06em] text-ink/[0.03] select-none pointer-events-none">01</span>
          <div class="lg:col-span-7">
            <div class="relative aspect-[16/9] bg-canvas rounded-xl border border-border-light overflow-hidden">
              <video
                class="absolute inset-0 w-full h-full object-cover"
                controls
                playsinline
                poster="[POSTER_URL]"
              >
                <source src="[VIDEO_URL]" type="video/mp4" />
              </video>
              <div class="absolute bottom-0 left-0 right-0 p-md bg-gradient-to-t from-black/70 to-transparent">
                <span class="text-canvas/80 text-[12px] font-medium">
                  {t('koora.video.caption.international')}
                </span>
              </div>
            </div>
          </div>
          <div class="lg:col-span-4 lg:col-start-9 lg:pt-3xl">
            <span class="text-ghost text-[10px] font-medium tracking-[0.08px] uppercase px-2.5 py-1 border border-border rounded-sm mb-md inline-block">{t('koora.narrative1.tag')}</span>
            <h3 class="text-[clamp(22px,2.5vw,30px)] font-light leading-[1.18] tracking-[-0.03em] text-ink text-balance mb-sm">
              {t('koora.narrative1.title')}
            </h3>
            <p class="text-muted text-[15px] leading-[1.75]">
              {t('koora.narrative1.body')}
            </p>
          </div>
        </div>

        <!-- Block 02 — Multilingual -->
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-xl items-start mb-section-mobile lg:mb-section relative">
          <span class="hidden lg:block absolute -top-8 -right-6 text-[120px] font-accent font-bold leading-none tracking-[-0.06em] text-ink/[0.03] select-none pointer-events-none">02</span>
          <div class="lg:col-span-4 lg:order-1 lg:pt-3xl">
            <span class="text-ghost text-[10px] font-medium tracking-[0.08px] uppercase px-2.5 py-1 border border-border rounded-sm mb-md inline-block">{t('koora.narrative2.tag')}</span>
            <h3 class="text-[clamp(22px,2.5vw,30px)] font-light leading-[1.18] tracking-[-0.03em] text-ink text-balance mb-sm">
              {t('koora.narrative2.title')}
            </h3>
            <p class="text-muted text-[15px] leading-[1.75]">
              {t('koora.narrative2.body')}
            </p>
          </div>
          <div class="lg:col-span-7 lg:col-start-6 lg:order-2">
            <div class="relative aspect-[16/9] bg-canvas rounded-xl border border-border-light overflow-hidden">
              <video
                class="absolute inset-0 w-full h-full object-cover"
                autoplay
                loop
                muted
                playsinline
              >
                <source src="/kooraExtract_1.webm" type="video/webm" />
              </video>
            </div>
          </div>
        </div>

        <!-- Block 03 — Consistency — centered, editorial -->
        <div class="max-w-[680px] mx-auto text-center py-section-mobile lg:py-section relative">
          <span class="hidden lg:block absolute top-0 left-1/2 -translate-x-1/2 text-[140px] font-accent font-bold leading-none tracking-[-0.06em] text-ink/[0.025] select-none pointer-events-none">03</span>
          <span class="relative text-ghost text-[10px] font-medium tracking-[0.08px] uppercase px-2.5 py-1 border border-border rounded-sm mb-lg inline-block">{t('koora.narrative3.tag')}</span>
          <h3 class="relative text-[clamp(24px,2.8vw,34px)] font-light leading-[1.15] tracking-[-0.03em] text-ink text-balance mb-md">
            {t('koora.narrative3.title')}
          </h3>
          <p class="relative text-muted text-[16px] leading-[1.8]">
            {t('koora.narrative3.body')}
          </p>
        </div>

        <!-- Block 04 — Pipeline -->
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-xl items-start relative">
          <span class="hidden lg:block absolute -top-8 -left-6 text-[120px] font-accent font-bold leading-none tracking-[-0.06em] text-ink/[0.03] select-none pointer-events-none">04</span>
          <div class="lg:col-span-7">
            <div class="relative aspect-[16/9] bg-canvas rounded-xl border border-border-light overflow-hidden">
              <video
                class="absolute inset-0 w-full h-full object-cover"
                controls
                playsinline
                poster="[POSTER_URL]"
              >
                <source src="[VIDEO_URL]" type="video/mp4" />
              </video>
              <div class="absolute bottom-0 left-0 right-0 p-md bg-gradient-to-t from-black/70 to-transparent">
                <span class="text-canvas/80 text-[12px] font-medium">
                  {t('koora.video.caption.pipeline')}
                </span>
              </div>
            </div>
          </div>
          <div class="lg:col-span-4 lg:col-start-9 lg:pt-3xl">
            <span class="text-ghost text-[10px] font-medium tracking-[0.08px] uppercase px-2.5 py-1 border border-border rounded-sm mb-md inline-block">{t('koora.narrative4.tag')}</span>
            <h3 class="text-[clamp(22px,2.5vw,30px)] font-light leading-[1.18] tracking-[-0.03em] text-ink text-balance mb-sm">
              {t('koora.narrative4.title')}
            </h3>
            <p class="text-muted text-[15px] leading-[1.75]">
              {t('koora.narrative4.body')}
            </p>
          </div>
        </div>
      </section>

      <!-- Industries -->
      <section class="mb-section-mobile lg:mb-section">
        <div class="border-t border-border-light pt-2xl">
          <p class="text-center text-ghost text-[11px] font-medium tracking-[0.14px] uppercase mb-xl">
            {t('koora.clients.label')}
          </p>
          <div class="overflow-hidden">
            <div class="marquee-track">
              <div class="flex items-center gap-4xl shrink-0 px-2xl">
                <span class="text-[15px] font-medium tracking-[0.02px] text-muted/40 whitespace-nowrap">{t('koora.clients.line1')}</span>
                <span class="text-[15px] font-medium tracking-[0.02px] text-muted/40 whitespace-nowrap">{t('koora.clients.line2')}</span>
                <span class="text-[15px] font-medium tracking-[0.02px] text-muted/40 whitespace-nowrap">{t('koora.clients.line3')}</span>
                <span class="text-[15px] font-medium tracking-[0.02px] text-muted/40 whitespace-nowrap">{t('koora.clients.line4')}</span>
                <span class="text-[15px] font-medium tracking-[0.02px] text-muted/40 whitespace-nowrap">{t('koora.clients.line5')}</span>
                <span class="text-[15px] font-medium tracking-[0.02px] text-muted/40 whitespace-nowrap">{t('koora.clients.line6')}</span>
              </div>
              <div class="flex items-center gap-4xl shrink-0 px-2xl">
                <span class="text-[15px] font-medium tracking-[0.02px] text-muted/40 whitespace-nowrap">{t('koora.clients.line1')}</span>
                <span class="text-[15px] font-medium tracking-[0.02px] text-muted/40 whitespace-nowrap">{t('koora.clients.line2')}</span>
                <span class="text-[15px] font-medium tracking-[0.02px] text-muted/40 whitespace-nowrap">{t('koora.clients.line3')}</span>
                <span class="text-[15px] font-medium tracking-[0.02px] text-muted/40 whitespace-nowrap">{t('koora.clients.line4')}</span>
                <span class="text-[15px] font-medium tracking-[0.02px] text-muted/40 whitespace-nowrap">{t('koora.clients.line5')}</span>
                <span class="text-[15px] font-medium tracking-[0.02px] text-muted/40 whitespace-nowrap">{t('koora.clients.line6')}</span>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- CTA -->
      <section class="border-t border-border-light pt-2xl pb-section-mobile lg:pb-section text-center">
        <h2 class="text-[clamp(24px,3vw,36px)] font-light leading-[1.15] tracking-[-0.03em] text-ink text-balance mb-sm">
          {t('koora.portfolio.heading')}
        </h2>
        <p class="text-muted text-[16px] leading-[1.6] mb-xl max-w-[480px] mx-auto">
          {t('koora.portfolio.subheading')}
        </p>
        <a
          href="https://koora.studio"
          target="_blank"
          rel="noopener noreferrer"
          class="magnetic inline-flex items-center justify-center px-6 py-3 bg-ink text-canvas text-[14px] font-medium tracking-[-0.2px] rounded-lg transition-colors duration-300 hover:bg-ink/85"
        >
          {t('koora.portfolio.button')}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="ml-sm"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
        </a>
        <p class="text-ghost text-[12px] mt-md">
          {t('koora.portfolio.cta')}
        </p>
      </section>

    </div>
  </main>

  <div class="noise-overlay"></div>
</BaseLayout>

<script>
  import Lenis from 'lenis';
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const lenis = new Lenis({
    duration: 1.2,
    easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
    touchMultiplier: 2,
  });

  lenis.on('scroll', ScrollTrigger.update);
  gsap.ticker.add((time) => { lenis.raf(time * 1000); });
  gsap.ticker.lagSmoothing(0);

  const nav = document.getElementById('main-nav');
  let lastNavScroll = 0;
  let navHidden = false;

  if (nav) {
    lenis.on('scroll', ({ scroll }: { scroll: number }) => {
      if (scroll > 50) nav.classList.add('nav-scrolled');
      else nav.classList.remove('nav-scrolled');

      if (scroll > lastNavScroll && scroll > 200 && !navHidden) {
        gsap.to(nav, { y: -80, duration: 0.4, ease: 'power3.in' });
        navHidden = true;
      } else if (scroll < lastNavScroll && navHidden) {
        gsap.to(nav, { y: 0, duration: 0.35, ease: 'power2.out' });
        navHidden = false;
      }
      lastNavScroll = scroll;
    });
  }

  if (!prefersReducedMotion) {
    const heroHeading = document.querySelector('main h1');
    if (heroHeading) {
      gsap.from(heroHeading, { y: 24, autoAlpha: 0, duration: 0.8, ease: 'power2.out', delay: 0.1 });
    }

    const heroLede = heroHeading?.closest('section')?.querySelector('p');
    if (heroLede && heroHeading) {
      gsap.from(heroLede, { y: 16, autoAlpha: 0, duration: 0.7, ease: 'power2.out', delay: 0.25 });
    }

    const heroVideo = document.querySelector('section:first-of-type .aspect-\\[16\\/9\\]');
    if (heroVideo) {
      gsap.from(heroVideo, {
        scale: 0.96,
        autoAlpha: 0,
        duration: 0.95,
        ease: 'power3.out',
        delay: 0.2,
      });
    }

    const statsSection = document.querySelector('section:nth-of-type(2)');
    if (statsSection) {
      const statsCards = statsSection.querySelectorAll(':scope .grid > div');
      gsap.from(statsCards, {
        y: 24,
        autoAlpha: 0,
        duration: 0.55,
        ease: 'power2.out',
        stagger: 0.1,
        scrollTrigger: { trigger: statsSection, start: 'top 80%', once: true },
      });
    }

    const narrativeSection = document.querySelector('section:nth-of-type(3)');
    if (narrativeSection) {
      const narrativeLabel = narrativeSection.querySelector(':scope > div:first-child span');
      const narrativeHeading = narrativeSection.querySelector(':scope > div:first-child h2');
      if (narrativeLabel) {
        gsap.from(narrativeLabel, {
          y: 12, autoAlpha: 0, duration: 0.5, ease: 'power2.out',
          scrollTrigger: { trigger: narrativeLabel, start: 'top 88%', once: true },
        });
      }
      if (narrativeHeading) {
        gsap.from(narrativeHeading, {
          y: 16, autoAlpha: 0, duration: 0.7, ease: 'power2.out',
          scrollTrigger: { trigger: narrativeHeading, start: 'top 85%', once: true },
        });
      }
    }

    document.querySelectorAll('section:nth-of-type(3) .grid').forEach((grid) => {
      const video = grid.querySelector('.aspect-\\[16\\/9\\]');
      const textCol = grid.querySelector('h3')?.closest('div');
      const bigNum = grid.querySelector('span[class*="120px"]');

      if (bigNum) {
        gsap.from(bigNum, {
          autoAlpha: 0, duration: 1.2, ease: 'power3.out',
          scrollTrigger: { trigger: grid, start: 'top 85%', once: true },
        });
      }

      if (video) {
        gsap.from(video, {
          scale: 0.95, autoAlpha: 0, duration: 0.75, ease: 'power2.out',
          scrollTrigger: { trigger: grid, start: 'top 78%', once: true },
        });
        gsap.fromTo(video, { yPercent: 6 }, {
          yPercent: -6, ease: 'none',
          scrollTrigger: { trigger: grid, start: 'top bottom', end: 'bottom top', scrub: true },
        });
      }

      if (textCol) {
        const textEls = textCol.querySelectorAll(':scope > span, :scope > h3, :scope > p');
        if (textEls.length) {
          gsap.from(textEls, {
            y: 18, autoAlpha: 0, duration: 0.5, ease: 'power2.out', stagger: 0.1,
            scrollTrigger: { trigger: grid, start: 'top 76%', once: true },
          });
        }
      }
    });

    const centeredBlock = narrativeSection?.querySelector('.max-w-\\[680px\\]');
    if (centeredBlock) {
      const bigNum = centeredBlock.querySelector('span[class*="140px"]');
      if (bigNum) {
        gsap.from(bigNum, {
          autoAlpha: 0, duration: 1.2, ease: 'power3.out',
          scrollTrigger: { trigger: centeredBlock, start: 'top 85%', once: true },
        });
      }
      const innerEls = centeredBlock.querySelectorAll(':scope > span:not([class*="140px"]), :scope > h3, :scope > p');
      gsap.from(innerEls, {
        y: 24, autoAlpha: 0, duration: 0.6, ease: 'power2.out', stagger: 0.12,
        scrollTrigger: { trigger: centeredBlock, start: 'top 80%', once: true },
      });
    }

    const marqueeSection = document.querySelector('section:nth-of-type(4)');
    if (marqueeSection) {
      gsap.from(marqueeSection.querySelectorAll(':scope > div > p, :scope > div > div'), {
        y: 16, autoAlpha: 0, duration: 0.6, ease: 'power2.out', stagger: 0.1,
        scrollTrigger: { trigger: marqueeSection, start: 'top 88%', once: true },
      });
    }

    const ctaSection = document.querySelector('section.border-t:last-of-type');
    if (ctaSection) {
      gsap.from(ctaSection.querySelectorAll(':scope > *'), {
        y: 16, autoAlpha: 0, duration: 0.6, ease: 'power2.out', stagger: 0.1,
        scrollTrigger: { trigger: ctaSection, start: 'top 88%', once: true },
      });
    }

    document.querySelectorAll('.magnetic').forEach((el) => {
      el.addEventListener('mousemove', (e) => {
        const rect = (el as HTMLElement).getBoundingClientRect();
        const x = (e as MouseEvent).clientX - rect.left - rect.width / 2;
        const y = (e as MouseEvent).clientY - rect.top - rect.height / 2;
        gsap.to(el, { x: x * 0.15, y: y * 0.15, duration: 0.3, ease: 'power2.out' });
      });
      el.addEventListener('mouseleave', () => {
        gsap.to(el, { x: 0, y: 0, duration: 0.5, ease: 'elastic.out(1, 0.5)' });
      });
    });
  }
</script>
